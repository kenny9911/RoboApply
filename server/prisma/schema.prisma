  identifiedGaps     Json
  /// Recommended SeekerTrainingModule slugs in order.
  recommendedModules String[] @default([])

  /// Locale at compute time.
  language String?

  computedAt DateTime @default(now())

  seekerProfile SeekerProfile @relation(fields: [seekerProfileId], references: [id], onDelete: Cascade)

  @@index([seekerProfileId, computedAt])
  @@index([seekerProfileId, targetRole])
