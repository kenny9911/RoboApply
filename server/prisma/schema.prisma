/// Consent records. One row per (seeker, consent type, grant/revoke event).
/// Audit-grade — append-only. Revocation inserts a new row, never mutates
/// the prior grant.
model SeekerConsentRecord {
  id              String @id @default(cuid())
  seekerProfileId String

  /// Closed enum (see lib/seekerConsentTypes.ts):
  /// 'seeker_app_optin' | 'biometric_video' | 'biometric_interview' |
  /// 'auto_apply' | 'external_board_share' | 'transactional_email' |
  /// 'marketing_email' | 'ai_assistance'.
  consentType  String
  granted      Boolean
  ipAddress    String?
  userAgent    String?
  /// Hash of the consent prose the user actually saw. Lets legal prove "this
  /// version of the disclosure was shown" without retaining the IP/UA forever.
  proseHash    String?
  proseVersion String?

  createdAt DateTime @default(now())

  seekerProfile SeekerProfile @relation(fields: [seekerProfileId], references: [id], onDelete: Cascade)

  @@index([seekerProfileId, consentType, createdAt])
  @@index([consentType, granted])
