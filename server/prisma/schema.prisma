/// Persisted Agent Alex eval suite runs. One row per `runSuite()` invocation
/// from the admin UI ("Run eval"), the CLI script (`npm run agent-alex:eval`),
/// or any future scheduled job. Per-case results are stored as JSON in
/// `cases` so the schema doesn't need to evolve when we add new categories.
model AgentAlexEvalRun {
  id                 String    @id @default(cuid())
  tier               String /// 't1' | 't2' — string instead of enum so adding a tier is a code-only change
  triggeredById      String? /// admin user that hit "Run eval"; null for scheduled / CLI runs
  triggerSource      String /// 'admin-ui' | 'cli' | 'scheduled'
  configEnvironment  String /// 'production' | 'development' — which profile the run exercised
  startedAt          DateTime  @default(now())
  finishedAt         DateTime?
  totalCases         Int       @default(0)
  passed             Int       @default(0)
  failed             Int       @default(0)
  errored            Int       @default(0)
  totalInputTokens   Int       @default(0)
  totalOutputTokens  Int       @default(0)
  providersExercised String[] /// e.g. ['gemini','claude'] or ['claude'] when only one provider is configured
  cases              Json /// CaseRunResult[] from the runner
