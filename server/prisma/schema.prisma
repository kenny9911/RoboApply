model Resume {
  id                    String    @id @default(cuid())
  userId                String
  recruiterUserId       String?
  name                  String
  email                 String?
  phone                 String?
  currentRole           String?
  experienceYears       String?
  summary               String?   @db.Text // AI-generated professional summary
  highlight             String? // One-line highlight for card display
  resumeText            String    @db.Text
  parsedData            Json?
  insightData           Json?
  jobFitData            Json?
  // ── Talent Hub AI-First intelligence (additive, nullable) ────────────────
  // See docs/talent-ai-first/. Written ONLY by TalentIntelligenceService.
  // talentIntelligence holds the unified TalentIntelligence JSON object
  // (version 2 — backend/src/types/talentIntelligence.ts); insightData /
  // jobFitData remain the shared per-agent caches it reuses. talentScore +
  // talentStage are denormalized scalars for fast list/feed sort & filter.
  // talentJobSetHash = sha256(sorted open-job-id list) at last JobFit run,
  // for reverse-match staleness detection. lastOutreachDrafts caches up to 3
  // recent OutreachTemplatesAgent drafts. talentStageUpdatedAt drives the
  // "going cold" aging lane; talentIntelligenceUpdatedAt drives the 30-day TTL.
  talentIntelligence          Json?
  talentIntelligenceUpdatedAt DateTime?
  talentScore                 Int?
  talentStage                 String?
  talentStageUpdatedAt        DateTime?
  talentJobSetHash            String?
  lastOutreachDrafts          Json?
  fileName              String?
  fileSize              Int?
  fileType              String?
  originalFileProvider  String?
  originalFileKey       String?
  originalFileName      String?
  originalFileMimeType  String?
  originalFileSize      Int?
  originalFileChecksum  String?
  originalFileStoredAt  DateTime?
  contentHash           String?
  // External-system identifier for idempotent upsert via the partner-facing
  // POST /api/v1/external/resumes/import endpoint (e.g. GoHire's resume id).
  // Scoped by (userId, source, externalId) so the same external id under
  // different external systems doesn't collide. Null for resumes uploaded
  // via the in-product UI / Talent Hub / Auto-Loader.
  externalId            String?
  status                String    @default("active")
  source                String    @default("upload")
  tags                  String[]  @default([])
  notes                 String?   @db.Text
  preferences           Json?
  // ResumeSemanticTagAgent output — see backend/src/types/semanticLabels.ts.
  // tagSet is the denormalized flat array used for index-backed queries
  // (GIN index applied via apply-indexes.ts). Always rebuilt from
  // semanticLabels via buildTagSet() — never written by hand.
  semanticLabels        Json?
  semanticLabelsVersion String?
  tagSet                String[]  @default([])
  // Match v2 — raw normalized keyword pool for lexical overlap against JDs.
  // Distinct from tagSet (which holds namespaced semantic enums); keywordSet
  // is the unprefixed, alias-normalized vocabulary of skills/tools/tech the
  // candidate demonstrates. Built deterministically at upload time from
  // parsedData + semanticLabels via ResumeKeywordService.buildResumeKeywordSet().
  // GIN-indexed for future tag-search use. See docs/prd-match-v2.md.
  keywordSet            String[]  @default([])
  keywordSetVersion     String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user                   User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  recruiterUser          User?                 @relation("ResumeRecruiter", fields: [recruiterUserId], references: [id], onDelete: SetNull)
  resumeJobFits          ResumeJobFit[]
  jobMatches             JobMatch[]
  jobResumeMatches       JobResumeMatch[]
  resumeVersions         ResumeVersion[]
  agentCandidates        AgentCandidate[]
  tasks                  Task[]
  goHireInterviews       GoHireInterview[]
  autoLoaderFiles        AutoLoaderFile[]
  // Seeker app — master resumes (1:N with SeekerProfile.masterResume) and
  // tailored variants. See docs/job-seeker-engineering-spec.md §4.
  seekerProfilesAsMaster SeekerProfile[]       @relation("SeekerMasterResume")
  seekerResumeVersions   SeekerResumeVersion[] @relation("SeekerResumeVersionBase")
  // RoboApply — one mission pins one resume (SetNull if the resume is later
  // deleted). The relation lives on RoboApplyMission.resumeId.
  roboApplyMissions      RoboApplyMission[]    @relation("RoboApplyMissionResume")

  @@unique([userId, contentHash])
  @@unique([userId, source, externalId])
  @@index([userId])
  @@index([recruiterUserId])
  @@index([userId, status])
  @@index([userId, status, createdAt])
  @@index([name])
  @@index([contentHash])
  @@index([originalFileKey])
  @@index([createdAt])
  @@index([semanticLabelsVersion])
  @@index([externalId])
  // Talent Hub AI-First — sort by score, filter by stage, "going cold" aging.
  @@index([userId, talentScore])
  @@index([userId, talentStage])
  @@index([userId, talentStage, talentStageUpdatedAt])
  @@index([talentStage, talentStageUpdatedAt])
}

model ResumeVersion {
