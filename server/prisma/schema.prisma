  /// 'subscription_upgraded' | 'subscription_canceled' | 'data_export_requested'.
  eventType String
  payload   Json?
  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  seekerProfile SeekerProfile @relation(fields: [seekerProfileId], references: [id], onDelete: Cascade)

  @@index([seekerProfileId, createdAt])
  @@index([eventType, createdAt])
