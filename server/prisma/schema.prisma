  enabled     Boolean   @default(false)
  /// All-up pause toggle (Scenario 11 — vacation).
  paused      Boolean   @default(false)
  pausedUntil DateTime?

  /// Filters JSON: { minScore, minSalary, maxSalary, salaryCurrency,
  /// locationsAllowed, remoteOnly, excludeKeywords, requireRemote, ... }.
  filters Json @default("{}")

