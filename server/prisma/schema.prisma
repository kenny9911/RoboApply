/// Activity log — audit trail of consent-revoking events, auto-apply
/// submissions, deletions, board OAuth grants/revocations.
model SeekerActivityLog {
  id              String @id @default(cuid())
  seekerProfileId String

  /// 'auto_apply_submit' | 'manual_apply' | 'consent_granted' | 'consent_revoked'
