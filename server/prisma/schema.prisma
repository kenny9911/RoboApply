model Job {
  id                    String    @id @default(cuid())
  userId                String
  hiringRequestId       String?
  title                 String
  department            String?
  location              String?
  workType              String? // remote, hybrid, onsite
  employmentType        String? // full-time, part-time, contract, internship
  experienceLevel       String? // entry, mid, senior, lead, executive
  education             String? // 学历要求: high_school, associate, bachelor, master, phd, none
  headcount             Int       @default(1) // 招聘人数
  salaryMin             Int?
  salaryMax             Int?
  salaryCurrency        String?   @default("USD")
  salaryText            String?   @db.Text // Free-text salary description, e.g. "base3000+补贴600+绩效1000"
  companyName           String?
  // Optional FK to the Client (Company) profile this job is for. When set, it is
  // the AUTHORITATIVE association (used to resolve the client's 招聘与用人规则 /
  // Candidate Selection Rules into matching + evaluation). When null, resolution
  // falls back to matching `companyName` ↔ Company.name (recruiter-scoped). See
  // backend/src/lib/clientSelectionRules.ts. onDelete: SetNull — deleting a
  // client nulls the link, never deletes the job.
  companyId             String?
  description           String?   @db.Text
  qualifications        String?   @db.Text // 任职要求
  hardRequirements      String?   @db.Text // 硬性要求
  niceToHave            String?   @db.Text // 优先条件 / 加分项
  benefits              String?   @db.Text // 福利待遇
  requirements          Json? // { mustHave: [], niceToHave: [] }
  parsedData            Json? // AI-parsed JD cache
  salaryPeriod          String?   @default("monthly") // monthly, yearly
  locations             Json? // Array of { country, city }
  interviewMode         String?   @default("standard") // standard, question_bank
  passingScore          Int?      @default(60) // 20-80 — interview evaluation ONLY (面试评估通过分); match-side gating uses matchInviteScore
  // 匹配邀约线 — resume-match invitable bar (stage-1 recall gate), decoupled from
  // the interview passingScore. 55-80 server clamp; floor 55 because screening
  // placeholder rows persist score=50 and any bar <=50 floods AI推荐 with
  // un-hydrated fake scores. Resolve via lib/matchInviteScore.ts ONLY.
  matchInviteScore      Int?      @default(60) // 55-80
  interviewLanguage     String?   @default("en")
  interviewDuration     Int?      @default(30) // minutes: 15,30,45,60
  interviewRequirements String?   @db.Text // 面试要求
  evaluationRules       String?   @db.Text // 评估规则
  notes                 String?   @db.Text // 内部备注，不展示给候选人
  aiInsights            Json? // Cached AI insights report (Tavily-enriched)
  aiInsightsLang        String? // Language code the report was generated in (e.g., "zh-TW")
  aiInsightsAt          DateTime? // When insights were last generated
  // AI-synthesized ≤300-char role summary for the JD header (lazy-generated on
  // first detail-init view, cached; falls back to a client-side excerpt while null).
  roleSummary           String?   @db.Text
  roleSummaryLang       String? // detected JD language the summary was written in
  roleSummaryAt         DateTime? // regenerated when null or stale vs. contentUpdatedAt
  // ── AI Toolkit cache (overview tab) ──────────────────────────────────────
  // Each artifact below is an LLM output cached on the job. Generated on-demand
  // from `POST /api/v1/jobs/:id/<tool>` (see backend/src/routes/jobs.ts). Cache
  // hit when artifact != null AND not force=true. Stale-banner driven on the
  // frontend by comparing `<tool>At` vs Job.updatedAt.
  jdAudit               Json? // { score: 0-100, findings: [{severity, code, message, fixHint, field, proposed}], language }
  jdAuditAt             DateTime?
  jdAuditLang           String?
  sourcingKit           Json? // SourcingStrategyResult — boolean strings, target companies, channels
  sourcingKitAt         DateTime?
  sourcingKitLang       String?
  interviewKit          Json? // InterviewKit — questionAreas, systemPrompt, scoring rubric
  interviewKitAt        DateTime?
  interviewKitLang      String?
  idealProfile          Json? // IdealCandidateProfile — must-haves, core skills, exemplar past roles
  idealProfileAt        DateTime?
  idealProfileLang      String?
  hmIntake              Json? // HmIntakeOutput — questions to ask the hiring manager
  hmIntakeAt            DateTime?
  hmIntakeLang          String?
  outreachTemplates     Json? // OutreachTemplatesOutput — cold-message templates
  outreachTemplatesAt   DateTime?
  outreachTemplatesLang String?
  altTitles             Json? // AltTitlesOutput — alternative job titles
  altTitlesAt           DateTime?
  altTitlesLang         String?
  closingBrief          Json? // ClosingBriefOutput — candidate-facing close-call playbook
  closingBriefAt        DateTime?
  closingBriefLang      String?
  status                String    @default("draft") // draft, open, paused, closed, filled
  publishedAt           DateTime?
  closedAt              DateTime?
  lastMatchedAt         DateTime? // Stamped by Job Bank auto-match on publish
  matchConfigHash       String? // sha1 of material JD fields; skip-guard for re-match
  matchWeights          Json? // { skills, experience, domain, softSkills, education, stability } 0-100
  // Phase 4 v3 (Jeff persona — retained search) — per-job override of the
  // recruiter's User.matchingPreferences. Lets the recruiter set a
  // different stale-cutoff for one specific job (e.g. an executive search
  // where October-2025 candidates are MORE valuable, not less).
  // Shape (all optional):
  //   { excludeOlderThanDays?: number,
  //     includeAlreadyMatched?: boolean,
  //     /* future: cap?, talentPoolFilters? */ }
  // Read precedence: per-job override > per-user default. See
  // backend/src/services/JobBankMatchService.ts resolveExclusionOptions.
  matchOverrides        Json?
  notificationPrefs     Json? // { newTierA, staleAdvance, funnelAnomaly, dailyStandup } bool map
  // Phase 5 — JobSemanticTagAgent output. Replaces the JD-text-extraction logic
  // in SemanticTagPreFilter with structured set algebra.
  // requiredTagSet: hard predicates a candidate's tagSet must contain (e.g.
  //   ['lang:python', 'category:engineering', 'seniority:senior+']).
  // preferredTagSet: soft signals for ranking but not exclusion.
  semanticLabels        Json?
  semanticLabelsVersion String?
  requiredTagSet        String[]  @default([])
  preferredTagSet       String[]  @default([])
  // Match v2 — raw normalized keyword sets for lexical overlap against
  // candidate resumes. requiredKeywordSet are must-have skills/tools (drawn
  // from semanticLabels.hardSkills/hardTools where required=true), used as
  // an additional rule in SemanticTagPreFilter and fed as a precomputed
  // signal to MatchAgent. preferredKeywordSet are nice-to-haves. Built
  // deterministically via JobKeywordService.
  requiredKeywordSet    String[]  @default([])
  preferredKeywordSet   String[]  @default([])
  keywordSetVersion     String?
  // Optional link to an Online Assessment. When set, RoboHire auto-invites
  // candidates to take this assessment after their AI interview completes.
  linkedAssessmentId    String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  // Tracks the last time JD prose / structural content was changed (title,
  // description, qualifications, hardRequirements, niceToHave, benefits,
  // education, salary, ...). Distinct from `updatedAt` because writing an
  // AI artifact (jdAudit, sourcingKit, ...) also bumps `updatedAt` — that
  // would falsely mark every other cached artifact as stale. The PATCH
  // endpoint sets this explicitly only when the user edits content fields.
  contentUpdatedAt      DateTime?

  user               User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  hiringRequest      HiringRequest?       @relation(fields: [hiringRequestId], references: [id], onDelete: SetNull)
  company            Company?             @relation(fields: [companyId], references: [id], onDelete: SetNull)
  linkedAssessment   Assessment?          @relation("JobLinkedAssessment", fields: [linkedAssessmentId], references: [id], onDelete: SetNull)
  jobMatches         JobMatch[]
  jobResumeMatches   JobResumeMatch[]
  matchingSessions   MatchingSession[]
  agents             Agent[]
  alexSession        AgentAlexSession?
  tasks              Task[]
  goHireInterviews   GoHireInterview[]
  // Phase 3 — AI Auto-Pilot. Both are 1:1 (a job has at most one Brief and one
  // Auto-Invite config). Cascading delete keeps audit clean if the job dies.
  matchBrief         JobMatchBrief?
  autoInviteConfig   JobAutoInviteConfig?
  autoLoaderTasks    AutoLoaderTaskJob[]
  // Seeker app — read-side relations from the candidate-facing product.
  // Recruiter-side code never reads these arrays; they exist only so Prisma
  // can resolve the named relations declared on SeekerJobMatch /
  // SeekerApplication. See docs/job-seeker-engineering-spec.md §4.
  seekerJobMatches   SeekerJobMatch[]     @relation("SeekerJobMatchJob")
  seekerApplications SeekerApplication[]  @relation("SeekerApplicationJob")
  // RoboApply — one run per (mission, jobContentHash) but multiple over a
  // job's lifetime. Backref so RoboApplyRun.job FK resolves.
  roboApplyRuns      RoboApplyRun[]       @relation("RoboApplyRunJob")

  @@index([userId])
  @@index([hiringRequestId, updatedAt])
  @@index([status])
  @@index([userId, status])
  @@index([userId, createdAt])
  @@index([userId, status, createdAt]) // job-bank/page-init findMany sort
  @@index([semanticLabelsVersion])
  @@index([companyId])
}

model JobMatch {
  id            String    @id @default(cuid())
  jobId         String
  resumeId      String
  score         Int?
  grade         String? // A+, A, B+, B, C, D, F (deep-match verdict)
  tier          String? // A, B, C (screening tier — orthogonal to grade)
  matchData     Json? // Full ResumeMatchAgent output
  source        String    @default("ai_match") // ai_match, applied, agent_sourced, manual
  status        String    @default("new") // new, reviewed, shortlisted, applied, rejected, invited
  // Phase 2 v3 — preserves AI-推荐 bucket membership through tier-downgrade
  // rescores. Without this column, a row that was tier='A' (in AI 推荐) and
  // gets re-scored to tier='C' would silently drop out of AI 推荐 even if
  // the recruiter had already actioned it (e.g. status='invited') — breaking
  // the v2 invariant `count(AI推荐) = count(待处理) + count(已处理)`.
  // Set at-screening-time on INSERT; preserved on rescore UPDATE (column-
  // whitelisted out of the rescore update list).
  aiRecommended Boolean   @default(false)
  starred       Boolean   @default(false) // HR bookmark; surfaces in 已标星 filter
  reviewedAt    DateTime?
  reviewedBy    String?
  viewedAt      DateTime? // First HR-view (for "AI new recommendations" inbox filter)
  viewedBy      String?
  appliedAt     DateTime?
  appliedBy     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // ── Action-First Matching v2 (see docs/prd-jobbank-matching-workflow-v2.md) ──
  // Recruiter decision capture for the 邀约 / 不推进 / 待定 action triplet.
  // status='rejected' carries (rejectionReason, rejectionCode) — codes are a
  // closed set in lib/matchActionStatus.ts. status='on_hold' is the new value
  // for 待定. invitedAt is the de-dup key for double-clicked invites (30s window).
  rejectionReason String?   @db.Text
  rejectionCode   String?
  actionTakenAt   DateTime?
  actionTakenBy   String?
  invitedAt       DateTime?
  holdAt          DateTime?
  rejectedAt      DateTime?

  // Deep-dive lazy hydration state (see candidateMatchHydrator.ts).
  // hydrationStartedAt acts as a DB-backed in-flight marker that survives
  // process restarts — atomically claimed via tryClaimHydration() so a stale
  // marker (>3min) can be reclaimed by another request without races.
  hydrationStartedAt   DateTime?
  hydrationCompletedAt DateTime?
  hydrationError       Json? // { code, message, attemptedAt, canRetry }

  job          Job                @relation(fields: [jobId], references: [id], onDelete: Cascade)
  resume       Resume             @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  calibrations MatchCalibration[]

  @@unique([jobId, resumeId])
  @@index([jobId])
  @@index([resumeId])
  @@index([score])
  @@index([status])
  @@index([jobId, score])
  @@index([jobId, status, grade])
  @@index([jobId, status, viewedAt])
  @@index([jobId, source, createdAt])
  @@index([jobId, tier]) // job-bank/page-init groupBy tier aggregate
  @@index([jobId, status, actionTakenAt]) // pending-aging banner: pending rows older than X hours
  // Phase 2 v3 — bucket count: AI 推荐 = WHERE jobId=? AND aiRecommended=true.
  // Phase 1B leaves source='applied' rows out of AI 推荐 by aiRecommended=false.
  @@index([jobId, aiRecommended])
  // Cross-job inbox query in /job-bank/page-init (jobBank.ts ~L292):
  //   WHERE source='ai_match' AND status='new' AND viewedAt IS NULL
  //         AND grade IN ('A+','A')  ORDER BY score DESC, createdAt DESC
  // Without this index Postgres seq-scans the full JobMatch table (22K+ rows
  // and growing) and filters in memory — the dominant query in batch 1.
  // The composite (source, status, score) lets the planner do an index range
  // scan on `source='ai_match' AND status='new'` then walk the score btree
  // descending, applying viewedAt/grade as cheap re-checks per row.
  @@index([source, status, score])
}

/// Deep-match queue (docs/design-spec-deep-match-queue.md). One row per
/// (jobId,resumeId) deep-match unit — the FIRST-CLASS, durable lifecycle record
/// that replaces the implicit hydration* columns + matchData.phase +
/// isScreeningOnly heuristic + the in-memory progress map. Status is the single
/// source of truth; an atomic row-lease (mirrors RuntimeLock) drives execution.
/// Phase 1 = shadow (dual-written, not yet read). lib/deepMatchQueue.ts is the
/// sole writer. JobMatch.hydrationCompletedAt becomes a projection of
/// status='succeeded'.
enum DeepMatchStatus {
  queued
  leased
  running
  succeeded
  failed
  dead_letter
  canceled
  skipped_prefiltered
}

model DeepMatchJob {
  id         String          @id @default(cuid())
  jobId      String
  resumeId   String
  jobMatchId String? // the JobMatch this drives (1:1 via the same (jobId,resumeId) key)
  status     DeepMatchStatus @default(queued)

  // Atomic lease (mirrors RuntimeLock). ONE budget — leaseExpiresAt = leasedAt
  // + callBudget — replaces the three drifting hydration-timeout constants.
  leaseOwner     String? // `${hostname}:${pid}:${uuid}` — the claiming worker
  leasedAt       DateTime?
  leaseExpiresAt DateTime?

  // Retry + provenance + observability.
  attempt     Int     @default(0)
  maxAttempts Int     @default(3)
  lastError   Json? // { code, message, canRetry, at }
  enqueuedBy  String  @default("unknown") // eager_v3 | batch_orchestrator | scan | candidate_open | manual | requeue
  priority    Int     @default(0) // higher drains first (recruiter-open boost)
  billable    Boolean @default(true)
  apiKeyId    String?
  requestId   String?
  sessionId   String? // → MatchingSession

  enqueuedAt DateTime  @default(now())
  startedAt  DateTime?
  finishedAt DateTime?
  durationMs Int?
  costUsd    Float?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([jobId, resumeId])
  @@index([status])
  @@index([status, priority, enqueuedAt]) // drainer claim order
  @@index([jobId, status]) // per-job queue counts
  @@index([leaseExpiresAt]) // expired-lease reclaim sweep
}

/// Recruiter feedback on the AI verdict for a specific JobMatch — the
/// calibration loop. One row per (matchId, userId): the latest click
/// upserts; toggling 👍↔👎 updates the existing row rather than appending.
/// Feeds future model evals; never queried on the request path.
model MatchCalibration {
  id             String   @id @default(cuid())
  matchId        String
  userId         String
  /// 'agree' | 'disagree'
  verdict        String
  /// when verdict='disagree': closed set in lib/matchCalibration.ts —
  /// 'overweighted_skills' | 'overweighted_experience' | 'overweighted_domain'
  /// | 'overweighted_preference' | 'underweighted_potential' | 'wrong_verdict' | 'other'
  disagreeReason String?
  note           String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  match JobMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([matchId, userId])
  @@index([matchId])
  @@index([userId])
  @@index([createdAt])
}

/**
 * Append-only audit log for resume×job match completions. Coexists with
 * JobMatch (which holds the canonical "current state" + recruiter pipeline);
 * JobResumeMatch records every match event so re-matches preserve history.
 * One row per ResumeMatchAgent (or screening) completion. Never updated.
 * jobId is nullable so the public POST /match-resume endpoint (which has
 * no Job entity) can still log the event.
 */
model JobResumeMatch {
  id       String  @id @default(cuid())
  resumeId String
  jobId    String?
  userId   String?

  // Summary (denormalized from `result` for fast filtering / listings)
  score                Int?
  grade                String? // A+ / A / B+ / B / C / D / F
  tier                 String? // A / B / C (screening tier)
  verdict              String? // overallFit.verdict
  hiringRecommendation String? // overallFit.hiringRecommendation
  oneLiner             String? @db.Text // candidateSummary.oneLiner
  disqualified         Boolean @default(false)
  phase                String  @default("full") // "screening" | "full"

  // Full result blob (MatchResult or screening payload)
  result Json

  // Source / orchestration linkage
  source     String  @default("ai_match") // ai_match | direct_api | agent_sourced | manual
  agentName  String  @default("ResumeMatchAgent")
  modelName  String?
  sessionId  String?
  batchRunId String?
  requestId  String?

  // Cost & telemetry (filled when LoggerService snapshot is available)
  promptTokens     Int?
  completionTokens Int?
  estimatedCost    Float?
  durationMs       Int?

  matchedAt DateTime @default(now())
  createdAt DateTime @default(now())

  resume   Resume            @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  job      Job?              @relation(fields: [jobId], references: [id], onDelete: SetNull)
  user     User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  session  MatchingSession?  @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  batchRun MatchingBatchRun? @relation(fields: [batchRunId], references: [id], onDelete: SetNull)

  @@index([resumeId, matchedAt(sort: Desc)])
  @@index([jobId, matchedAt(sort: Desc)])
  @@index([resumeId, jobId, matchedAt(sort: Desc)])
  @@index([userId, matchedAt(sort: Desc)])
  @@index([sessionId])
  @@index([batchRunId])
  @@index([matchedAt])
  @@index([phase, matchedAt])
}

model Interview {
  id              String    @id @default(cuid())
  userId          String
  jobId           String?
  resumeId        String?
  hiringRequestId String?
  candidateId     String?
  candidateName   String
  candidateEmail  String?
  jobTitle        String?
  jobDescription  String?   @db.Text
  resumeText      String?   @db.Text
  status          String    @default("scheduled") // queued, sending, scheduled, in_progress, completed, cancelled, expired, failed
  type            String    @default("ai_video") // ai_video, ai_audio, ai_text
  scheduledAt     DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  duration        Int? // seconds
  accessToken     String?   @unique // unique token for candidate to join
  roomId          String? // LiveKit room ID
  transcript      Json? // Array of { role, content, timestamp }
  recordingUrl    String?
  gohireUserId    String? // GoHire user_id returned from invitation API
  metadata        Json?
  // Set when ensureEvaluationForInterview() or another auto-eval path decided
  // NOT to run the evaluation. Currently the only value is
  // 'duration_too_short' (interview ran for < 30% of Job.interviewDuration).
  // Surfaces in the interview-hub list as a badge so recruiters know why no
  // evaluation was generated.
  autoEvalSkipReason String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  hiringRequest HiringRequest?        @relation(fields: [hiringRequestId], references: [id], onDelete: SetNull)
  candidate     Candidate?            @relation(fields: [candidateId], references: [id], onDelete: SetNull)
  evaluations   InterviewEvaluation[] // v2: multiple revisions per interview; active = latest by revision DESC
  dialogTurns   InterviewDialogTurn[]
  tasks         Task[]
  invitation    Invitation?

  @@index([userId])
  @@index([status])
  @@index([userId, status])
  @@index([accessToken])
  @@index([userId, createdAt])
  @@index([hiringRequestId])
  @@index([candidateId])
  @@index([resumeId])
  @@index([gohireUserId])
  @@index([autoEvalSkipReason])
  @@index([jobId, status]) // job-bank/page-init groupBy active interviews per job
}

model InterviewDialogTurn {
  id          String   @id @default(cuid())
  interviewId String
  candidateId String?
  userId      String
  role        String
  speakerName String?
  content     String   @db.Text
  timestamp   DateTime
  sequence    Int
  createdAt   DateTime @default(now())

  interview Interview  @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  candidate Candidate? @relation(fields: [candidateId], references: [id], onDelete: SetNull)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([interviewId, sequence])
  @@index([interviewId, timestamp])
  @@index([candidateId, timestamp])
  @@index([userId, timestamp])
}

// Unified Interview Evaluation (v2) — canonical evaluation record for ALL
// sources (LiveKit interviews, GoHire imports, external API calls, manual).
// Full spec: docs see plan file unified-evaluation-v2.
//
// Revisions: re-evaluations create NEW rows (not in-place updates) so a client
// who has already seen a report keeps seeing the same v1. The latest revision
// per (interviewId | goHireInterviewId) is the active one. Use
// EvaluationPersistenceService for all writes — never call upsert directly.
//
// Source links: exactly one of (interviewId | goHireInterviewId) is set, or
// neither (stateless external-API caller that opted into persist).
model InterviewEvaluation {
  id                   String    @id @default(cuid())

  // Source links — exactly one of (interviewId | goHireInterviewId) is set
  interviewId          String?
  goHireInterviewId    String?
  userId               String // recruiter who owns this row
  jobId                String?
  resumeId             String?

  // Scoring
  overallScore         Int?
  grade                String?
  verdict              String? // strong_hire | hire | weak_hire | no_hire | disqualified
  confidenceScore      Int? // 0-100, agent's confidence in its own assessment
  evidenceQualityScore Int? // 0-100, how much of the transcript supported claims

  // Payloads
  evaluationData       Json? // UnifiedEvaluation — full canonical shape. M2 `decisionReason` (≤140 chars) lives at evaluationData.decisionReason.
  passes               Json? // { eval, reflect, refine, totalLatencyMs, models } — intermediate pass artifacts for audit/debug
  summary              String?   @db.Text // internal-facing 1-paragraph
  clientSummary        String?   @db.Text // client share-page paragraph
  hiringManagerSummary Json? // { headline: string, bullets: string[] } — for email
  strengths            Json? // Array<{ statement, evidence }>
  weaknesses           Json? // Array<{ statement, evidence }>

  // Versioning
  schemaVersion        String    @default("v2.0")
  promptVersion        String    @default("v2.0")
  revision             Int       @default(1)
  previousEvaluationId String?
  revisionNotes        String?   @db.Text

  // Disqualification gating — when any Critical must-have FAILs, this is true
  // and share-link mint refuses unless the recruiter explicitly overrides.
  disqualified         Boolean   @default(false)

  // Share state
  shareToken           String?   @unique
  shareExpiresAt       DateTime?
  shareViewCount       Int       @default(0)
  lastSharedAt         DateTime?
  shareAudience        String? // 'client' | 'manager' | null

  // Cache
  cachedHtmlReport     String?   @db.Text
  cachedHtmlReportAt   DateTime?

  // Audit
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  // Relations
  interview          Interview?            @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  goHireInterview    GoHireInterview?      @relation(fields: [goHireInterviewId], references: [id], onDelete: Cascade)
  user               User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  previousEvaluation InterviewEvaluation?  @relation("EvaluationRevision", fields: [previousEvaluationId], references: [id])
  revisions          InterviewEvaluation[] @relation("EvaluationRevision")
  accessLogs         EvaluationAccessLog[]
  shareEvents        EvaluationShareEvent[]

  @@index([interviewId])
  @@index([goHireInterviewId])
  @@index([userId])
  @@index([jobId])
  @@index([resumeId])
  @@index([overallScore])
  @@index([verdict])
  @@index([revision])
  // DB-level at-most-once enforcement (AR-EVAL-IDEMPOTENCY). Two processes (the API
  // /transcript handler and the agent-runtime eval-sweeper) can both pass the
  // check-then-act `evaluations.length === 0` guard and both try to write the first
  // revision (revision=1). Without a DB constraint that produced two concurrent
  // revisions + double LLM cost. Uniqueness on (source, revision) makes the second
  // first-revision insert fail (P2002) so saveEvaluation degrades it to
  // already_evaluated. Postgres treats NULL as distinct, so the interviewId-bound
  // and goHireInterviewId-bound rows never collide cross-source.
  @@unique([interviewId, revision])
  @@unique([goHireInterviewId, revision])
}

// 2026-06 Question Grader — persistent, cross-candidate cache of the
// candidate-BLIND rubric (answer key) for an interview question. Keyed by
// hash(question + jobTitle + level + RUBRIC_PROMPT_VERSION) so every candidate
// asked the same question on a req is graded against the identical frozen
// criteria (comparability + stability + cost). Cache-only; safe to truncate.
model InterviewQuestionRubric {
  id        String   @id @default(cuid())
  hashKey   String   @unique
  version   String
  jobId     String?
  // Human-readable question text for the browsable Q→ideal-answer bank.
  question  String?  @db.Text
  payload   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([version])
  @@index([jobId])
}

// 2026-06 Question Grader — persisted transcript segmentation. Keyed by
// hash(transcript + SEGMENT_PROMPT_VERSION) so the SAME transcript always
// segments into the IDENTICAL question set across runs / processes / instances.
// This is the primary run-to-run stability guarantee (segmentation drift was
// the largest hidden variance source). Doubles as the per-interview Q&A bank.
// Cache-only; safe to truncate.
model InterviewTranscriptSegment {
  id        String   @id @default(cuid())
  hashKey   String   @unique
  version   String
  payload   Json     // QuestionUnit[] : [{ qid, questionText, candidateAnswerText, category, timestampSeconds }]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([version])
}

// 2026-06 Question Grader — full graded RESULT (scored per-question items +
// capability profile) cached by hash(transcript + job + all stage versions + k).
// This is the run-to-run DETERMINISM guarantee: a given (transcript, job) is
// graded ONCE; re-evaluations return the identical result (0 LLM calls) until a
// version bump or forceRegrade. Cache-only; safe to truncate.
model InterviewGraderResult {
  id        String   @id @default(cuid())
  hashKey   String   @unique
  version   String
  payload   Json     // { items: QaAssessmentItem[], capability?: CapabilitySynthesisResult }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([version])
}

// Audit log of every read/share/email/PDF access to an evaluation. Writes
// happen from the public token route, share endpoint, and email send path.
// Best-effort — failures here never roll back the underlying access.
model EvaluationAccessLog {
  id             String   @id @default(cuid())
  evaluationId   String
  accessedAt     DateTime @default(now())
  accessType     String // 'view' | 'pdf' | 'email_sent' | 'email_opened'
  accessorEmail  String?
  accessorIp     String?
  accessorRegion String?
  userAgent      String?  @db.Text

  evaluation InterviewEvaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)

  @@index([evaluationId, accessedAt])
  @@index([accessType])
}

// Recruiter-side share lifecycle events (created/revoked/rotated). Separate
// from access log so we can show "who shared this" vs "who viewed this".
model EvaluationShareEvent {
  id           String   @id @default(cuid())
  evaluationId String
  action       String // 'created' | 'revoked' | 'rotated'
  actorUserId  String
  createdAt    DateTime @default(now())
  notes        String?  @db.Text

  evaluation InterviewEvaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  actor      User                @relation("EvaluationShareEventActor", fields: [actorUserId], references: [id], onDelete: Cascade)

  @@index([evaluationId, createdAt])
  @@index([actorUserId])
}

model ATSIntegration {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider    String // "greenhouse" | "lever" | "ashby" | "bamboohr" | "workable"
  credentials String // encrypted JSON: { apiKey, subdomain, etc. }
  isActive    Boolean   @default(true)
  syncEnabled Boolean   @default(true)
  lastSyncAt  DateTime?
  config      Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  webhookDeliveries WebhookDelivery[]
  syncLogs          ATSSyncLog[]

  @@unique([userId, provider])
  @@index([userId])
}

model ATSSyncLog {
  id            String         @id @default(cuid())
  integrationId String
  integration   ATSIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  direction     String // "inbound" | "outbound"
  entityType    String // "job" | "candidate" | "application"
  entityId      String?
  externalId    String?
  status        String // "success" | "failed" | "skipped"
  error         String?
  payload       Json?
  createdAt     DateTime       @default(now())

  @@index([integrationId])
  @@index([createdAt])
}

model WebhookDelivery {
  id              String          @id @default(cuid())
  integrationId   String?
  integration     ATSIntegration? @relation(fields: [integrationId], references: [id], onDelete: SetNull)
  hiringRequestId String?
  event           String
  url             String
  payload         Json
  status          String // "pending" | "delivered" | "failed"
  statusCode      Int?
  attempts        Int             @default(0)
  maxAttempts     Int             @default(5)
  lastAttemptAt   DateTime?
  nextRetryAt     DateTime?
  response        String?         @db.Text
  createdAt       DateTime        @default(now())

  @@index([status, nextRetryAt])
  @@index([hiringRequestId])
}

model UserActivity {
  id         String   @id @default(cuid())
  userId     String
  sessionId  String
  eventType  String // "page_view" | "click"
  path       String
  element    String?
  elementTag String?
  metadata   Json?
  timestamp  DateTime
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, timestamp])
  @@index([sessionId])
  @@index([timestamp])
}

model MatchingBatchRun {
  id             String    @id @default(cuid())
  userId         String
  title          String?
  status         String    @default("running") // running, completed, failed
  config         Json // { jobIds[], resumeIds[], preFilter?, maxAgents }
  summary        Json? // { jobs[], peakActiveAgents, sessionIds[] }
  totalJobs      Int       @default(0)
  totalTasks     Int       @default(0)
  completedTasks Int       @default(0)
  failedTasks    Int       @default(0)
  filteredTasks  Int       @default(0)
  startedAt      DateTime  @default(now())
  completedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  matchingSessions MatchingSession[]
  jobResumeMatches JobResumeMatch[]

  @@index([userId, createdAt])
  @@index([status])
}

/**
 * Phase 6 — Reusable matching task preset. Stores strictness / fairness /
 * salary-filter / reasoning-visible + an optional default JD snippet so
 * recruiters can kick off repeat matches in one click.
 */
model MatchingTaskTemplate {
  id          String    @id @default(cuid())
  userId      String
  name        String
  description String?
  rules       Json // { strictness, fairnessMask, salaryFilter, reasoningVisible }
  jdSnippet   String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastUsedAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
}

model MatchingSession {
  id         String  @id @default(cuid())
  userId     String
  jobId      String
  batchRunId String?
  title      String?
  status     String  @default("running") // running, completed, failed

  // Configuration snapshot
  config Json // { resumeIds[], preFilter: { locations?, jobTypes?, freeText? } }

  // Pre-filter results
  preFilterModel  String?
  preFilterResult Json? // { passedIds[], excluded: [{ resumeId, reason }], durationMs }

  // Results summary
  totalResumes  Int     @default(0)
  totalFiltered Int     @default(0)
  totalMatched  Int     @default(0)
  totalFailed   Int     @default(0)
  avgScore      Float?
  topGrade      String?

  // Cost tracking
  totalCost     Float @default(0)
  totalTokens   Int   @default(0)
  totalLLMCalls Int   @default(0)

  // Matching rules (Phase 4 — 新建匹配任务)
  strictness       String?   @default("standard") // standard | strict | relaxed
  fairnessMask     Json? // { gender, age, region, photo } bool per axis
  salaryFilter     Boolean   @default(false)
  reasoningVisible Boolean   @default(true)
  aiSummary        String?   @db.Text // One-sentence natural-language summary of the OUTCOME (e.g. "AI 已完成匹配 · 从 50 份简历中筛出 8 份高匹配")
  // One-sentence natural-language summary of the SETTINGS used for this run.
  // Composed at session creation by lib/matchRunSummary.composeRunSummary().
  // Persisted so the matching-history modal can show "what this run was set
  // up to do" without recomputing from raw config blobs.
  runSummary       String?   @db.Text
  summaryData      Json? // { totalScreened, tierA, tierB, tierC, biasFlags[], confidence }
  // Lazy-computed structured analysis from MatchInsightsAgent — replaces the
  // misleading "高匹配" headline with honest qualified/sub-passing counts plus
  // recruiter-facing findings & deep-linked next-step suggestions. Cache key
  // is the MatchingSession itself; new sessions always start with null.
  matchInsights    Json? // MatchInsightsOutput
  matchInsightsAt  DateTime?

  createdAt   DateTime  @default(now())
  completedAt DateTime?
  updatedAt   DateTime  @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  job              Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  batchRun         MatchingBatchRun? @relation(fields: [batchRunId], references: [id], onDelete: Cascade)
  jobResumeMatches JobResumeMatch[]
  runResumes       MatchRunResume[]

  @@index([userId, createdAt])
  @@index([jobId])
  @@index([batchRunId])
}

/// Per-(run, résumé) transparency ledger — ONE durable row for EVERY résumé a
/// run considered, written by the unified match funnel (services/matchTransparency.ts).
/// Enforces the Conservation Invariant: for an explicit-selection run the
/// selected count == the count of MatchRunResume rows, and every row carries a
/// terminal `outcome` + machine `reasonCode` + recruiter-facing `reason`.
/// This is the durable answer to "what happened to résumé X?" for excluded,
/// prefiltered, errored, capped, and persist-failed résumés that otherwise get
/// NO JobMatch row and vanish silently. See docs/prd-match-transparency.md +
/// docs/design-spec-match-transparency.md.
model MatchRunResume {
  id        String @id @default(cuid())
  sessionId String
  resumeId  String
  userId    String
  jobId     String

  // Lifecycle — `stage` is where the résumé stopped, `outcome` is its terminal
  // disposition (taxonomy in docs/prd-match-transparency.md §3).
  stage   String // intake | eligibility | prematch | scoring | persist | done
  outcome String // scored_recommended | scored_below_bar | scored_pending_deepdive | prefiltered | excluded_stale | excluded_engaged | excluded_ineligible | excluded_capped | error_llm | error_persist | error_quota

  // Reason — `reasonCode` is locale-neutral (FE localizes), `reason` is a
  // best-effort human string, `reasonDetail` carries structured evidence
  // ({ rules:[{rule,threshold,actual}] } | { rawError } | { cutoffDays }).
  reasonCode   String?
  reason       String? @db.Text
  reasonDetail Json?

  // Score snapshot (null until/unless scored)
  score      Int?
  grade      String?
  tier       String? // A | B | C | PREFILTERED
  belowBar   Boolean?
  jobMatchId String? // canonical JobMatch row when one exists

  // Forensics
  apiKeyId   String? // mirror per-key billing (CLAUDE.md per-key rule)
  retryable  Boolean  @default(false)
  durationMs Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  session MatchingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, resumeId])
  @@index([sessionId, outcome])
  @@index([resumeId])
  @@index([jobId])
}

model Agent {
  id           String  @id @default(cuid())
  // Human-friendly 6-digit "worker badge" for this agent (100000–999999).
  // Surfaced in the UI and in logs so recruiters and support staff can
  // reference an agent without copy-pasting a CUID. Nullable to allow
  // existing rows to be backfilled idempotently after deploy.
  badgeId      Int?    @unique
  userId       String
  name         String
  description  String // natural-language search criteria
  taskType     String  @default("search_candidates") // search_candidates, match_resumes, + future
  instructions String? // user instructions for what the agent should do
  status       String  @default("active") // active, paused, completed
  jobId        String? // linked job (required for task execution)

  // Search config snapshot
  config Json? // { location?, skills[], experienceMin?, experienceMax?, keywords? }

  // Candidate source selection — { modes: ['instant_search'|'internal_minio'|'external_api'], externalApiConfigId? }
  source Json?

  // Scheduling
  autonomy        String    @default("manual") // manual, scheduled, event
  schedule        String? // cron expression, e.g. "0 9 * * *"
  scheduleEnabled Boolean   @default(false)
  nextRunAt       DateTime?

  // Phase 7 — when true, creating this agent seeded its initial ICP from the
  // owner's UserRecruiterProfile. When false, the user explicitly opted out
  // of cross-agent learning for this particular agent.
  agentInheritsFromProfile Boolean @default(true)

  // Stats
  totalSourced   Int @default(0)
  totalApproved  Int @default(0)
  totalRejected  Int @default(0)
  totalContacted Int @default(0)

  // Calibration loop — recruiter must approve 3 consecutive profiles before
  // the agent goes autonomous. See docs/agent-sourcing-redesign.md §2.
  calibrationState       String    @default("pending") // pending | calibrating | calibrated
  consecutiveLikes       Int       @default(0)
  calibrationCompletedAt DateTime?

  lastRunAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  job           Job?                @relation(fields: [jobId], references: [id], onDelete: SetNull)
  candidates    AgentCandidate[]
  runs          AgentRun[]
  activities    AgentActivityLog[]
  idealProfiles AgentIdealProfile[]

  @@index([userId, createdAt])
  @@index([status])
  @@index([scheduleEnabled, nextRunAt])
}

model AgentCandidate {
  id             String    @id @default(cuid())
  agentId        String
  runId          String? // which run produced this candidate
  resumeId       String? // linked resume if exists in system
  name           String
  email          String?
  profileUrl     String? // external profile link
  headline       String? // current role / summary
  matchScore     Float? // 0-100
  source         String? // instant_search, internal_minio, external_api
  reason         String?   @db.Text // LLM "why this candidate" one-liner
  metadata       Json? // per-task type extras (matched skills, etc.)
  status         String    @default("pending") // pending, liked, disliked, invited, contacted, messaged, interviewed, hired, rejected, archived
  outreachSentAt DateTime?
  notes          String?

  // Structured rejection feedback — fuels the next ICP regeneration.
  // See docs/agent-sourcing-redesign.md §3.
  rejectionReason String?  @db.Text
  rejectionTags   String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agent       Agent        @relation(fields: [agentId], references: [id], onDelete: Cascade)
  run         AgentRun?    @relation(fields: [runId], references: [id], onDelete: SetNull)
  resume      Resume?      @relation(fields: [resumeId], references: [id], onDelete: SetNull)
  invitations Invitation[]
  outreach    Outreach[]

  @@index([agentId, status])
  @@index([agentId, createdAt])
  @@index([runId])
}

model AgentRun {
  id            String    @id @default(cuid())
  agentId       String
  triggeredBy   String // user, schedule, event, agent, openclaw
  triggeredById String? // userId, parent runId, or openclaw delivery id
  status        String    @default("queued") // queued, running, completed, failed, cancelled
  startedAt     DateTime?
  completedAt   DateTime?
  error         String?   @db.Text
  stats         Json? // { sourced, matched, liked, disliked, invited, emailed, messaged }

  // Phase 5 — comprehensive logging columns. Aggregated from llm.call.completed
  // events written to AgentActivityLog at run completion.
  tokensIn     Int   @default(0)
  tokensOut    Int   @default(0)
  costUsd      Float @default(0)
  llmCallCount Int   @default(0)
  avgLatencyMs Int   @default(0) // mean per-call latency
  durationMs   Int   @default(0) // total wall-clock (completedAt - startedAt)

  // Heartbeat + watchdog (admin-agent-manager-prd §6, §7).
  // Updated by AgentActivityLogger on every event with a runId so the
  // watchdog can detect runs that have stopped progressing.
  lastHeartbeatAt DateTime?
  swept           Boolean   @default(false) // true if force-failed by sweep
  sweepReason     String? // 'boot' | 'watchdog' | 'admin' | null

  createdAt DateTime @default(now())

  agent      Agent              @relation(fields: [agentId], references: [id], onDelete: Cascade)
  candidates AgentCandidate[]
  activities AgentActivityLog[]

  @@index([agentId, createdAt])
  @@index([status])
  @@index([costUsd])
  @@index([status, lastHeartbeatAt])
}

model AgentCriteriaPreset {
  id        String   @id @default(cuid())
  userId    String
  name      String
  criteria  Json // Array of { id, text, pinned, bucket: 'most'|'least' }
  scope     String   @default("private") // private | shared
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([scope])
}

// AgentIdealProfile — LLM-generated structured representation of the
// recruiter's taste. Synthesized from liked + disliked candidates after each
// triage batch. Used by the matcher (via llmMatcher) to score future runs
// against an evolving baseline rather than only the static JD.
//
// Versioning: every regeneration creates a new row. The latest version is
// always the one with the highest `version` for a given agentId. Older
// versions are kept for audit and rollback. The active row is the one whose
// (agentId, version) maxes out — query with orderBy: { version: 'desc' }.
model AgentIdealProfile {
  id      String @id @default(cuid())
  agentId String // not @unique — versioned history retained for audit
  userId  String
  version Int    @default(1)

  // Structured ICP — see docs/icp-architecture.md §2 for the full shape.
  // Includes: coreSkills[], bonusSkills[], antiSkills[], yearsOfExperience,
  // signals[], anchorCandidateIds[], antiAnchorCandidateIds[], etc.
  profile Json

  // LLM-suggested hard requirements (NOT yet active until user accepts).
  // The actual active hard requirements live on Agent.config.hardRequirements
  // because the user owns them; this column is just a suggestion buffer.
  suggestedHardRequirements Json?

  narrativeSummary      String? @db.Text // 1-2 sentence human-readable digest
  confidence            Float   @default(0) // 0..1, model self-reported
  generatedFromLikes    Int     @default(0)
  generatedFromDislikes Int     @default(0)

  // Audit
  generatedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([agentId, version])
  @@index([agentId, generatedAt])
  @@index([userId])
}

// Phase 7a — Cross-agent aggregated recruiter taste model. One row per user.
// Rebuilt (not incrementally updated) whenever any AgentIdealProfile for the
// user changes. See docs/context-engineering-v7.md §2.1 for the full shape.
model UserRecruiterProfile {
  id     String @id @default(cuid())
  userId String @unique

  // Aggregated taste — frequency-weighted arrays. All shapes documented in the
  // design doc so we can evolve them fast without migrations.
  topSkills       Json // [{skill, weight, lastSeenAt, sourceCount}]
  topAntiSkills   Json // same shape
  topLocations    Json
  topIndustries   Json
  topCompanySizes Json // ['startup' | 'midsize' | 'enterprise']

  // Recurring hard-requirement patterns the user tends to set across agents.
  recurringHardReqs Json // [{description, seenInAgents: string[], suggestApply: boolean}]

  // Stats
  signalsLearned Int      @default(0) // total likes + dislikes across all agents
  agentCount     Int      @default(0)
  lastRebuiltAt  DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Phase 7b — raw implicit signal events captured from candidate cards and
// profile detail views. Append-only. 90-day retention; aggregated into
// MemoryEntry rows via the synthesis worker.
model CandidateInteraction {
  id          String  @id @default(cuid())
  userId      String
  agentId     String?
  runId       String?
  candidateId String // AgentCandidate.id
  resumeId    String?

  eventType  String // viewed, expanded, dwell, contact_copied, link_clicked, scroll_deep
  durationMs Int? // for dwell / time-on-page events
  metadata   Json?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([candidateId])
  @@index([eventType, createdAt])
}

// Phase 7c — the semantic memory primitive. Written by the synthesis worker
// (Phase 7c) or by user actions. Retrieved by ContextRetrievalService with
// cosine similarity (v1 — JS; v7.5 — pgvector).
model MemoryEntry {
  id   String @id @default(cuid())
  kind String // preference | rejection_pattern | hard_req_suggest | anchor | company_wide | synthesized_fact

  // Scope hierarchy — exactly one scope level per memory
  scope   String // user | team | workspace | job
  scopeId String // userId | teamId | workspaceId | jobId

  // Semantic content — the human-readable fact the LLM sees
  content String @db.Text

  // Embedding vector — Json for v1 (JS cosine similarity).
  // Phase 7.5 will add a pgvector column via raw SQL.
  embedding Json // number[] serialized

  // Weight + decay
  weight         Float     @default(1.0) // current effective weight
  baselineWeight Float     @default(1.0) // weight at creation
  reinforceCount Int       @default(1)
  lastSeenAt     DateTime  @default(now())
  expiresAt      DateTime? // null = permanent (rare, user-pinned)

  // Hiring-requirement awareness — nullable, used for semantic job matching
  jobContext Json? // { jobTitle?, industry?, companySize?, role? }

  // Provenance
  sourceEventId String? // AgentCandidate.id, CandidateInteraction.id, or null
  sourceAgentId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([scope, scopeId])
  @@index([kind])
  @@index([expiresAt])
  @@index([scopeId, kind, lastSeenAt])
}

// MemoryAdminAuditLog — every admin action on memory data goes here.
// Durable, immutable, indexed by target so users can see who looked at
// their data and when. This table is the "break-glass" audit trail for
// the Phase 7 Memory Manager feature.
//
// action values:
//   view_profile | view_memories | view_interactions
//   edit_memory | delete_memory | pin_memory | unpin_memory
//   rebuild_profile | reset_profile | export
model MemoryAdminAuditLog {
  id         String  @id @default(cuid())
  adminId    String
  targetType String // memory_entry | user_profile | interaction | user
  targetId   String // memoryId | userId | interactionId
  action     String // see comment above
  reason     String? @db.Text // optional user-provided justification
  changes    Json? // { before: {...}, after: {...} } for edit actions
  ipAddress  String?

  createdAt DateTime @default(now())

  admin User @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId, createdAt])
  @@index([targetType, targetId, createdAt])
  @@index([action, createdAt])
}

model AgentActivityLog {
  id          String   @id @default(cuid())
  agentId     String
  runId       String?
  candidateId String? // AgentCandidate.id (scalar, no FK — survives candidate delete)
  actor       String // system, user:<id>, agent:<id>, openclaw:<instanceId>
  eventType   String // taxonomy in docs/agents-redesign-spec.md §5.3
  severity    String   @default("info") // debug, info, warn, error
  message     String?  @db.Text
  payload     Json?
  // Monotonic per-run sequence so the terminal replays events in dispatch
  // order, even when they land on the DB slightly out of order.
  sequence    Int      @default(0)
  errorCode   String?
  errorStack  String?  @db.Text
  createdAt   DateTime @default(now())

  agent Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  run   AgentRun? @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([agentId, createdAt])
  @@index([runId, createdAt])
  @@index([candidateId])
  @@index([eventType, createdAt])
  @@index([severity, createdAt])
}

model Invitation {
  id               String    @id @default(cuid())
  agentCandidateId String?
  resumeId         String?
  jobId            String
  invitedByUserId  String?
  invitedByAgentId String?
  channel          String // email, sms, openclaw
  loginUrl         String?   @db.Text
  qrcodeUrl        String?   @db.Text
  sentAt           DateTime  @default(now())
  acceptedAt       DateTime?
  interviewId      String?   @unique
  status           String    @default("sent") // sent, opened, accepted, expired, cancelled

  agentCandidate AgentCandidate? @relation(fields: [agentCandidateId], references: [id], onDelete: SetNull)
  interview      Interview?      @relation(fields: [interviewId], references: [id], onDelete: SetNull)

  @@index([jobId, sentAt])
  @@index([agentCandidateId])
  @@index([status])
}

model Outreach {
  id                 String    @id @default(cuid())
  agentCandidateId   String?
  resumeId           String?
  jobId              String?
  initiatedByUserId  String?
  initiatedByAgentId String?
  channel            String // email, openclaw, sms, linkedin
  templateKey        String?
  subject            String?
  body               String    @db.Text
  thread             Json? // [{ role, body, at, externalId? }]
  status             String    @default("draft") // draft, queued, sent, delivered, replied, bounced, failed
  externalId         String? // Resend message id, OpenClaw delivery id
  sentAt             DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  agentCandidate AgentCandidate? @relation(fields: [agentCandidateId], references: [id], onDelete: SetNull)

  @@index([agentCandidateId, createdAt])
  @@index([channel, status])
  @@index([externalId])
}

model ExternalSourceConfig {
  id          String   @id @default(cuid())
  name        String // "LinkedIn Recruiter", "GitHub People", ...
  provider    String // linkedin, github, seekout, fetcher, custom
  enabled     Boolean  @default(true)
  baseUrl     String
  authType    String // api_key, oauth, basic
  credentials Json // encrypted at rest — see CryptoService
  config      Json? // provider-specific knobs
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([enabled, provider])
}

model SourceConfig {
  id                   String   @id @default(cuid())
  workspaceId          String?  @unique // null = global default
  instantSearchEnabled Boolean  @default(true)
  internalMinioEnabled Boolean  @default(false)
  externalApiEnabled   Boolean  @default(false)
  minioBucket          String?
  updatedAt            DateTime @updatedAt
}

/// GoHire interview records imported from CSV export
model GoHireInterview {
  id                    String    @id @default(cuid())
  gohireUserId          String // candidate UUID in GoHire
  candidateName         String // 候选人姓名
  candidateEmail        String? // 用户邮箱（登录名称）
  interviewDatetime     DateTime // 面试开始时间
  interviewEndDatetime  DateTime? // 面试结束时间
  duration              Int? // 面试时长 (minutes)
  videoUrl              String?   @db.Text // gohire_interview_video_filepath
  recruiterName         String? // 招聘人员姓名
  recruiterEmail        String? // 招聘人员邮箱
  recruiterId           String? // gohire_recruiter_id
  jobTitle              String? // 职位名称
  jobDescription        String?   @db.Text // 职位描述
  jobRequirements       String?   @db.Text // 任职要求
  interviewRequirements String?   @db.Text // 面试要求
  resumeUrl             String?   @db.Text // 简历下载地址
  transcriptUrl         String?   @db.Text // 面试记录下载地址 — uses truncated 7-char log_id; prefer requestIntroductionId
  requestIntroductionId String?   @db.VarChar(36) // 面试记录id from CSV (full UUID); GoHire chat_dialog?request_introduction_id=<uuid> bypasses their broken log_id auth path
  parsedResumeText      String?   @db.Text // Cached parsed resume markdown
  lastLoginAt           DateTime? // 最近登录时间
  invitedAt             DateTime? // 邀约时间
  transcript            String?   @db.Text // Fetched/generated transcript
  evaluationData        Json? // Evaluation result JSON
  evaluationScore       Int? // Quick-access score (0-100)
  evaluationVerdict     String? // strong_hire, hire, weak_hire, no_hire
  evaluationShareToken  String?   @unique // Share token for public evaluation report
  // Set when an auto-eval path skipped this row. Currently the only value is
  // 'duration_too_short' (interview duration < 30% of Job.interviewDuration).
  autoEvalSkipReason    String?
  // Atomic at-most-once guard for the recruiter "evaluation completed" email.
  // Claimed (false→true) in EvaluationEmailService.onEvaluationPersisted right
  // before the send, so the completion email fires exactly once — and only
  // after the evaluation report actually exists. Import (Phase 1) no longer
  // emails on its own; it waits for this. See docs/prd-evaluation-completion-email.md.
  completionEmailSent   Boolean   @default(false)

  // Foreign key links to core entities (populated during CSV import pipeline)
  candidateUserId        String? // FK → User (candidate account)
  userId                 String? // FK → User (recruiter/owner)
  resumeId               String? // FK → Resume (parsed resume in TalentHub)
  jobId                  String? // FK → Job (linked job posting)
  resumeProcessingStatus String? @default("pending") // pending, processing, completed, failed, skipped
  resumeProcessingError  String? @db.Text // Error message if resume processing failed
  importBatchId          String? // Groups records from same CSV upload

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  candidateUser User?                 @relation("GoHireCandidateUser", fields: [candidateUserId], references: [id], onDelete: SetNull)
  recruiterUser User?                 @relation("GoHireRecruiterUser", fields: [userId], references: [id], onDelete: SetNull)
  resume        Resume?               @relation(fields: [resumeId], references: [id], onDelete: SetNull)
  job           Job?                  @relation(fields: [jobId], references: [id], onDelete: SetNull)
  evaluations   InterviewEvaluation[] // v2: canonical evaluation rows (latest by revision DESC = active)

  @@index([candidateName])
  @@index([candidateEmail])
  @@index([recruiterEmail])
  @@index([jobTitle])
  @@index([interviewDatetime])
  @@index([gohireUserId])
  @@index([evaluationScore])
  @@index([candidateUserId])
  @@index([userId])
  @@index([resumeId])
  @@index([jobId])
  @@index([importBatchId])
  @@index([resumeProcessingStatus])
  @@index([autoEvalSkipReason])
}

model GoHireImportBatch {
  id                     String   @id @default(cuid())
  adminUserId            String // Who triggered the import
  fileName               String? // Original CSV filename
  totalRows              Int // Total data rows in CSV
  overwrite              Boolean  @default(false) // User chose to overwrite existing records — read by Phase 2 to replace Resume + JobMatch rows instead of just linking
  autoEvaluate           Boolean  @default(false) // Admin opt-in: after Phase 2, run AI evaluation on qualifying interviews (≥50% of Job.interviewDuration)
  phase1Completed        Boolean  @default(false) // Sync phase done
  phase2Completed        Boolean  @default(false) // Async resume processing done
  phase3Completed        Boolean  @default(false) // Auto-evaluation done (only relevant when autoEvaluate=true)
  usersCreated           Int      @default(0)
  usersLinked            Int      @default(0)
  jobsCreated            Int      @default(0)
  jobsLinked             Int      @default(0)
  resumesCreated         Int      @default(0)
  resumesFailed          Int      @default(0)
  resumesPending         Int      @default(0)
  interviewsCreated      Int      @default(0)
  interviewsUpdated      Int      @default(0)
  interviewsSkipped      Int      @default(0)
  // Phase 3 (auto-evaluation) counters
  evaluationsRequested   Int      @default(0) // Candidates that passed gating and entered the eval loop
  evaluationsCompleted   Int      @default(0) // LLM eval succeeded + persisted
  evaluationsSkipped     Int      @default(0) // Gated out before LLM call (no job, no duration, below threshold, no transcript)
  evaluationsFailed      Int      @default(0) // LLM eval errored OR transcript fetch failed
