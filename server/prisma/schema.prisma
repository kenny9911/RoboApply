/// Profile video recording. Multiple takes per seeker — Free has limited
/// re-records (1 base + 1 re-record = 2 lifetime), Premium unlimited (see §10).
model SeekerProfileVideo {
  id              String @id @default(cuid())
  seekerProfileId String

  /// Client-provided id correlating /profile-video/init and /profile-video/finalize.
  /// Lower-cased hex prefix + cuid; unique per row so collisions are impossible.
  uploadId String? @unique

  /// R2 key for the recording (storage path is per-user-scoped; never
  /// guessable from outside). Path: `seeker/{userId}/profile-video/{uploadId}.{ext}`
  storageKey      String
  /// Cached presigned read URL (regenerated on read since presigns expire).
  durationSeconds Int?
  fileSize        Int?
  mimeType        String?

  /// AI-generated summary + transcript.
  transcript          String? @db.Text
  /// {
  ///   summary: string,             // 2-3 sentences
  ///   talkingPoints: string[],     // 3-5 bullets
  ///   language: string,            // ISO locale tag
  ///   highlightSuggestion: { startMs, endMs, rationale }?,
  ///   inferredVoice: string,       // 'warm' | 'energetic' | 'measured' | ...
  ///   deliveryFlags: string[],     // 'fast' | 'monotone' | 'unclear'
  ///   paceWpm: number?
  /// }
  summary             Json?
  summaryAgentVersion String?

  /// 'pending' | 'recording' | 'uploading' | 'processing' | 'ready' | 'failed' | 'archived'
  /// Legacy values 'recording' / 'uploading' kept for backward compat;
  /// new uploads use 'pending' → 'processing' → 'ready' | 'failed'.
  status String @default("pending")

  /// Failure mode message (when status='failed').
  processingError String? @db.Text

  /// Trimming metadata (in/out points in ms).
  trimStartMs Int?
  trimEndMs   Int?

  /// Whether this take is the seeker's "active" take. Only one row per
  /// seekerProfile has activeTake=true at a time. Older takes auto-purge
  /// after 30 days per retention policy.
  activeTake Boolean @default(false)

  /// Soft-delete marker. The R2 object is purged at delete-time but the
  /// row survives so per-lifetime quota counting (Free: 1 base + 1 re-record)
  /// remains correct even after the seeker deletes a take.
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  seekerProfile SeekerProfile @relation(fields: [seekerProfileId], references: [id], onDelete: Cascade)

  @@index([seekerProfileId, activeTake])
  @@index([seekerProfileId, createdAt])
  @@index([seekerProfileId, deletedAt])
  @@index([status])
}

/// Premium subscription. 1:1 with SeekerProfile — distinct from
/// recruiter-side `User.subscriptionTier` which is for the hiring product.
///
/// LOCKED 2026-05-14: 3-tier model (`free` / `premium` $3.99 / `premium_plus`
/// $9.99). See docs/prd-job-seeker-app.md § Pricing & Tiers and the
/// SeekerSubscriptionTier enum above.
model SeekerSubscription {
  id              String @id @default(cuid())
  seekerProfileId String @unique

  /// Free row is created implicitly at SeekerProfile creation — present for
  /// ledger consistency. Use the SeekerSubscriptionTier enum, not free-text.
  tier        SeekerSubscriptionTier @default(free)
  status      String                 @default("active") // active | past_due | canceled | trialing
  market      String? // 'us' | 'cn' | 'tw' | 'jp' | 'eu' | 'other'
  currency    String? // 'USD' | 'CNY' | 'TWD' | 'JPY' | 'EUR'
  amountMinor Int? // monthly price in minor units (cents/fen/yen)

  /// Stripe IDs — null for free.
  stripeCustomerId     String?
  stripeSubscriptionId String? @unique
  stripePriceId        String?

  trialEnd          DateTime?
  startedAt         DateTime?
  currentPeriodEnd  DateTime?
  cancelAtPeriodEnd Boolean   @default(false)
  canceledAt        DateTime?

  /// Mock-interview credit balance (1 credit = 20 min; other durations pro-rated).
  /// Set to the plan allotment on purchase/renewal (no rollover). Debited at the
  /// end of each mock interview. Free tier gets a lazy monthly grant. Authoritative
  /// reads/writes go through MockCreditService; every change appends a
  /// MockInterviewCreditLedger row. See docs/roboapply-billing-credits/spec.md.
  mockCredits                Float     @default(0)
  /// When the current allotment was granted (period anchor for free-tier monthly
  /// re-grant + display "renews on").
  mockCreditsRenewedAt       DateTime?
  /// The allotment granted for the current period (for "X of N credits" display).
  mockCreditsPeriodAllotment Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  seekerProfile SeekerProfile @relation(fields: [seekerProfileId], references: [id], onDelete: Cascade)

  @@index([seekerProfileId])
  @@index([status])
}

/// Immutable audit ledger for mock-interview credit movements. One row per
/// grant / debit / refund / expire / admin adjustment. Never mutated — reversals
/// insert a sibling row. The running balance lives on SeekerSubscription.mockCredits;
/// this table reconstructs how it got there. Written only by MockCreditService.
model MockInterviewCreditLedger {
  id               String   @id @default(cuid())
  seekerProfileId  String
  userId           String // denormalized for per-user queries
  delta            Float // +grant / −debit (credits)
  balanceAfter     Float
  reason           String // grant_purchase | grant_renewal | grant_free_monthly | signup_bonus | debit_interview | refund | admin_adjust | expire
  tier             String?
  relatedSessionId String? // InterviewSession id for debit/refund (idempotency key)
  source           String? // stripe | alipay | system | admin
  metadata         Json?
  createdAt        DateTime @default(now())

  seekerProfile SeekerProfile @relation(fields: [seekerProfileId], references: [id], onDelete: Cascade)

  @@index([seekerProfileId, createdAt])
  @@index([userId, createdAt])
  @@index([relatedSessionId])
}

/// Auto-apply settings. 1:1 with SeekerProfile.
model SeekerAutoApplySettings {
  id              String @id @default(cuid())
