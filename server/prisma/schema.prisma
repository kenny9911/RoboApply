model Company {
  id          String   @id @default(cuid())
  userId      String
  name        String
  industry    String?
  size        String? // e.g. "50-200", "1000+"
  location    String?
  website     String?
  notes       String?  @db.Text
  openJobs    Int      @default(0)
  totalPlaced Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Extended profile (see docs/prd-company-research-agent.md).
  // Most rich fields are JSON columns because their shape is still evolving
  // and we never query by sub-field. TypeScript interfaces live in
  // backend/src/types/companyProfile.ts.
  legalName               String?
  logoUrl                 String?
  founded                 Int?
  companyType             String? // "public" | "private" | "startup" | "nonprofit" | "government" | "subsidiary"
  ticker                  String?
  headcount               Int?
  subIndustry             String?
  description             String?   @db.Text
  about                   String?   @db.Text
  mission                 String?   @db.Text
  vision                  String?   @db.Text
  values                  Json?     // string[]
  culture                 Json?     // CompanyCulture
  personnelPolicy         Json?     // CompanyPersonnelPolicy
  hiringPreferences       Json?     // CompanyHiringPreferences
  compensationPhilosophy  Json?     // CompanyCompensationPhilosophy
  techStack               Json?     // string[]
  recentNews              Json?     // CompanyNewsItem[]
  fundingInfo             Json?     // CompanyFundingInfo
  leadership              Json?     // CompanyLeader[]
  competitors             Json?     // string[]
  growthSignals           Json?     // CompanyGrowthSignals
  awards                  Json?     // CompanyAward[]
  socials                 Json?     // CompanySocials
  glassdoorRating         Float?
  internalNotes           String?   @db.Text // recruiter-private; NEVER sent to AI
  // 招聘与用人规则 — recruiter/client-authored candidate-selection rules. Free-text,
  // one rule per entry. Shape: CompanyHiringRule[] = { id, text, enabled,
  // createdAt, updatedAt } (see backend/src/types/companyProfile.ts). Enabled
  // rules are resolved by companyName↔Job.companyName (recruiter-scoped) and
  // injected as a "Candidate Selection Rules" prompt block into BOTH resume
  // matching (ResumeMatchAgent / MatchAgent) and interview evaluation
  // (UnifiedEvaluationAgent). Resolver: backend/src/lib/clientSelectionRules.ts.
  hiringRules             Json?     // CompanyHiringRule[]
  lastResearchedAt        DateTime?
  researchSources         Json?     // CompanyResearchSource[]
  researchVersion         Int       @default(0)

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  contacts Contact[]
  jobs     Job[]     // Jobs linked to this client via Job.companyId (SetNull on delete)

  @@index([userId])
  @@index([name])
  @@index([createdAt])
