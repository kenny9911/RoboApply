// Per-market rate config for pay-per-use overages. Source of truth for
// the price a user pays when they exceed a tier cap. Per-user admin
// overrides live on User.overageRateOverrides and win over this table.
// Seeded at first boot with the matrix in
// docs/prd-multicurrency-overage-billing.md §5.1.
model OverageRate {
  id          String   @id @default(cuid())
  market      String // 'cn' | 'tw' | 'jp' | 'other'
  sku         String // 'resume_match' | 'interview' | 'agent_run_resume'
  currency    String // 'CNY' | 'TWD' | 'JPY' | 'USD'
  amountMinor Int // price per unit in minor units (fen/cent/yen/twd)
  updatedAt   DateTime @updatedAt
  updatedBy   String? // admin userId; null = seed

  @@unique([market, sku])
}

// Append-only ledger of every overage debit. Immutable once inserted —
// admin waives insert a sibling reversal row rather than mutating the
// original. See OverageBillingService for the double-entry pattern.
model OverageCharge {
  id                String          @id @default(cuid())
  userId            String
  sku               String
  market            String // snapshot of user.market at charge time
  currency          String // snapshot, redundant with market but self-documenting
  amountMinor       Int
  balanceAfterMinor Int // topUpBalanceMinor AFTER this debit, for reconciliation
  requestId         String? // ApiRequestLog.requestId that triggered it
  status            String          @default("charged") // 'charged' | 'voided'
  reversalOfId      String?         @unique
  reversalOf        OverageCharge?  @relation("OverageReversal", fields: [reversalOfId], references: [id])
  reversals         OverageCharge[] @relation("OverageReversal")
  waivedBy          String? // admin userId when status became 'voided'
  waiveReason       String?
  createdAt         DateTime        @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, status])
  @@index([requestId])
}

// Immutable audit log of every quota deduction across all SKUs
// (resume_match, interview, agent_alex_text, agent_alex_voice). One row
// per debited unit. Append-only — admin reversals/waives MUST insert a
// sibling reversal row, never mutate. Mirrors the OverageCharge ledger
// pattern.
//
// Why a separate table?
//   • User.{resumeMatchesUsed, interviewsUsed} is a counter that gets
//     reset every period. Once reset, you cannot tell what was billed.
//   • OverageCharge only captures overage debits, not plan-quota debits.
//   • ApiRequestLog captures the request but not whether quota was
//     debited (the request might have been quota-blocked pre-LLM, or it
//     might have been a free SKU like screening).
//   • This table is the join key between request / overage charge /
//     counter snapshot so finance ops can answer "did this user
//     actually pay for this match / interview / Alex turn?".
//
// Sources of truth (the only places that write rows):
//   • lib/matchBilling.ts                        → resume_match
//   • middleware/usageMeter.ts                   → interview (single + batch)
//   • middleware/requestAudit.ts                 → agent_alex_text (post-completion)
//   • index.ts WS handler                        → agent_alex_voice
//
// See docs/prd-resume-match-quota-rule.md.
model UsageDeductionLog {
  id     String @id @default(cuid())
  userId String
  // Set when the billed operation was driven by an API-key request (rh_...).
  // Null for cookie/JWT (UI) requests and non-HTTP contexts (cron/worker/seeker).
  // Enables per-API-key billing reconciliation alongside per-user.
  apiKeyId String?
  // 'resume_match' | 'interview' | 'agent_alex_text' | 'agent_alex_voice'.
  // Free-form so new SKUs can be added without a migration.
  sku    String
  // Almost always 1; reserved for future batch ops that must commit
  // multiple units atomically. The batch-interview path today writes one
  // row per resume even though the counter is updated atomically — keeps
  // per-unit forensic detail.
  units  Int    @default(1)
  // 'plan' | 'overage' | 'free_tier'. Tells finance whether the unit
  // came from the user's plan quota, their wallet (overage), or a
  // free-tier user under their lifetime cap.
  source String

  // Snapshot of effective tier + counter state AT TIME OF DEBIT, so a
  // future plan change or counter reset doesn't make this row hard to
  // interpret. Counter snapshots are nullable for SKUs without a single
  // direct counter (e.g. agent_alex which sums two sources at query time).
  tierAtCommit  String?
  usedBefore    Int?
  usedAfter     Int?
  limitAtCommit Int?

  // Overage path: snapshot of charge amount + link to the immutable
  // OverageCharge ledger row. Null on the plan-quota path.
  costMinor       Int?
  currency        String?
  overageChargeId String?

  // Canonical PLATFORM cost-to-serve in USD for this unit — our spend, NOT
  // what the user is charged (that's costMinor on the overage path). Derived
  // from real token usage × rate card (LLM) + STT/TTS/egress for interviews.
  // This is the single SUM()-able cost column for profitability analytics
  // (RoboApply admin console). Null only for legacy rows the backfill could
  // not resolve; 0 for BYOK rows (platform pays nothing). See
  // docs/roboapply-admin-billing/technical-design.md §1.1.
  platformCostUsd Float?

  // Correlation. requestId is shared with ApiRequestLog/LLMCallLog so a
  // single LLM cost / billing / API row can be joined into one record
  // by ops or admin debug tools.
  requestId       String?
  apiRequestLogId String?

  // Optional related entity ('job' / 'resume' / 'interview' /
  // 'agent_alex_session' / etc.). Free-form so new entities can join later.
  relatedEntityType String?
  relatedEntityId   String?

  // SKU-specific extras (resumeId, jobId, sessionId, wsSessionId,
  // batchSize, endpoint, etc.). Use sparingly; promote to a typed column
  // if a field is queried frequently.
  metadata Json?

  createdAt DateTime @default(now())

  user          User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  apiRequestLog ApiRequestLog? @relation(fields: [apiRequestLogId], references: [id], onDelete: SetNull)
  apiKey        ApiKey?        @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([userId, sku, createdAt])
  @@index([sku, createdAt])
  @@index([apiKeyId])
  @@index([apiKeyId, createdAt])
  @@index([requestId])
  @@index([apiRequestLogId])
  @@index([overageChargeId])
}

// GoHire Agents add-on — monthly Stripe subscription, priced per market.
