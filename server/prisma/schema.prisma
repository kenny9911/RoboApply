  monthlyCap Int @default(300)

  /// Per-board toggles {board: bool}. Honors a tier's board availability.
  boardPreferences Json @default("{}")

  /// Floor match score — auto-apply will NOT submit below this even if
  /// a match qualifies otherwise (Risk R14).
  floorMatchScore Int @default(60)

  /// Resume-version selection policy: 'tailor_each' | 'pick_closest' | 'master'.
  resumeStrategy String @default("tailor_each")

  /// Allow profile-video attachment to external submissions (per-application
  /// toggle is also available — this is the default).
  attachProfileVideo Boolean @default(false)

