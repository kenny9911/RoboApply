// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
//
// Runtime traffic uses the Neon pooler (pgbouncer transaction mode)
// configured in src/lib/prisma.ts. Migrations / `prisma db push` must
// bypass the pooler — DDL over transaction-mode pgbouncer silently
// no-ops multi-statement changes — so prisma.config.ts points db push
// at the direct (non-pooler) Neon endpoint via DIRECT_DATABASE_URL.

generator client {
  provider            = "prisma-client"
  output              = "../src/generated/prisma"
  // Force ESM .js import extensions in the generated client. The default
  // is "inferred from environment", which produces .ts extensions in some
  // build contexts (notably Render's Linux Docker build) and breaks at
  // runtime with `Cannot find module .../class.ts`. Pinning to "js" makes
  // the generated TypeScript emit cleanly to .js after tsc compiles to dist/.
  moduleFormat        = "esm"
  importFileExtension = "js"
}

datasource db {
  provider = "postgresql"
}

model Team {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members     User[]
  teamMembers TeamMember[]
  invitations TeamInvitation[]

  @@index([name])
}

model TeamMember {
  id        String   @id @default(cuid())
  userId    String
  teamId    String
  role      String   @default("member") // member, lead
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
  @@index([userId])
  @@index([teamId])
}

model TeamInvitation {
  id        String   @id @default(cuid())
  teamId    String
  email     String
  invitedBy String
  status    String   @default("pending") // pending, accepted, declined
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  team    Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  inviter User @relation("TeamInviter", fields: [invitedBy], references: [id])

  @@unique([teamId, email])
  @@index([email])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  name         String?
  phone        String?
  jobTitle     String?
  company      String?
  avatar       String?
  role         String   @default("user") // 'user', 'internal', 'agency', 'admin', 'candidate', 'sales', or 'customer_success' — PRIMARY role; gates permissions. Invariant: roles[0] === role.
  roles        String[] @default(["user"]) // Full role list; superset of [role]. See docs/prd-user-multi-role-candidate.md.
  // Hard admin-disable flag. False = cannot log in at all. Distinct from
  // subscription expiration (which is computed from subscriptionStatus +
  // currentPeriodEnd and only restricts LLM features, not login). Flipped by
  // the admin /users/:id/disable + /enable endpoints. See
  // docs/prd-resume-match-quota-rule.md and the subscriptionGate helper.
  isActive     Boolean  @default(true)
  provider     String? // 'email', 'google', 'github', 'linkedin'
  providerId   String?
  teamId       String?
  // SCRM owner assignment — each customer (a recruiter User) gets a CS owner and
  // a sales owner, both pointing at internal staff Users (role customer_success /
  // sales). SetNull so reassigning or deleting a staff member never deletes the
  // customer or their CS data. See docs/prd-copilot-suite.md §7.2 and the
  // "SCRM / CS Copilot" models near the end of this file.
  assignedSalesId String?
  assignedCsId    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Subscription / Stripe
  stripeCustomerId               String?   @unique
  subscriptionTier               String    @default("free") // free, starter, growth, business, custom
  subscriptionStatus             String    @default("active") // active, past_due, canceled
  subscriptionId                 String?
  // Informational start of the current paid period. Admin-settable (offline-
  // payment modal + the "Billing period" tile). Display/audit only — the END
  // date (currentPeriodEnd) remains the single field that drives late-payment/
  // overdue, the grace lock, and the anniversary roll-forward. Null for users
  // whose period start was never explicitly recorded.
  currentPeriodStart             DateTime?
  currentPeriodEnd               DateTime?
  // Billing cadence: 'monthly' | 'quarterly' | 'annual' | null. Drives the
  // anniversary reset cron — when currentPeriodEnd lapses, AnniversaryUsageResetService
  // rolls it forward by this interval. Set on subscription create/update from
  // the Stripe Price's `recurring.interval` + `interval_count`. Null for free
  // tier and brand-new users; cron treats null as 'monthly' as a defensive
  // default (safe for existing users until backfill runs).
  billingInterval                String?
  // Per-user grace-period override (days). When a paid subscription's
  // currentPeriodEnd lapses (or Stripe flips status to past_due), the user
  // keeps AI access for this many days before evaluateSubscriptionGate locks
  // them — usage keeps counting during the window. Null = fall back to the
  // global default (AppConfig `subscription_grace_days` ?? env
  // SUBSCRIPTION_GRACE_DAYS ?? 5). Admin-settable per user via
  // POST /admin/users/:id/set-billing-period. See lib/subscriptionGate.ts +
  // lib/subscriptionGraceConfig.ts.
  subscriptionGraceDays          Int?
  trialEnd                       DateTime?
  // Last time User.resumeMatchesUsed / interviewsUsed / assessmentInvitesUsed
  // were zeroed. Set by `resetUsageCounters()` so admins can see "did this
  // user actually get reset on the last anniversary?" Useful for diagnosing
  // missed-webhook cases like 刘林's (May 2026 — counter at 1000/1000 with
  // lastUsageResetAt null = never reset since signup).
  lastUsageResetAt               DateTime?
  // Reset markers for log-derived monthly counters. When set, the
  // counting functions in AgentAlexQuotaService.countAgentAlexTurns and
  // AgentQuotaService.countRuns floor their createdAt window at
  // MAX(monthStart, resetAt). Stamped by the admin reset-usage endpoint
  // (and ONLY by it — webhook renewals don't touch these because the
  // natural UTC-month-boundary handles the next reset automatically).
  alexTurnsResetAt               DateTime?
  agentRunsResetAt               DateTime?
  interviewsUsed                 Int       @default(0)
  resumeMatchesUsed              Int       @default(0)
  topUpBalance                   Float     @default(0)
  customMaxInterviews            Int? // Admin override for max interviews (null = use plan default)
  customMaxMatches               Int? // Admin override for max matches (null = use plan default)
  // Agent quota overrides — see docs/agent-quota-system.md. All null-defaults
  // fall back to the tier defaults in AgentQuotaService.ts; admin UI + API
  // can set an absolute override (e.g. grandfather grants, ops-granted bumps).
  customMaxAgents                Int? // cap on Agent.count() (null = use plan default)
  customMaxAgentRunsPerDay       Int? // cap on AgentRun created in user-local day
  customMaxAgentRunsPerMonth     Int? // cap on AgentRun created in user-local month
  customMaxAgentRunsTotal        Int? // lifetime cap (used by Free tier + grants)
  customMaxResumesPerRun         Int? // cap on résumés processed in a single run
  // Agent Alex text-chat turn overrides. Tier defaults live in
  // AgentAlexQuotaService.ts (Free = 12 lifetime, Starter/Growth/Business =
  // 200/800/2000 per UTC month). Null falls back to tier default.
  customMaxAgentAlexTurnsMonthly Int?
  customMaxAgentAlexTurnsTotal   Int?

  // Seeker profile-video lifetime override. Tier defaults: Free = 2 (1 base
  // + 1 re-record), Premium / Premium Plus = null (unlimited). Counts all
  // SeekerProfileVideo rows for the seeker, including soft-deleted ones, so
  // a Free seeker who has hit the cap can't reset it by deleting takes.
  // Admin sets to bump a specific seeker; null falls back to tier default.
  customMaxSeekerProfileVideoRecords Int?

  // File Vault — see docs/prd-file-vault.md.
  // BigInt because tier=custom + admin override can push past Int.MAX (2 GiB).
  // storageBytesUsed is mutated atomically inside a Prisma transaction by
  // lib/storageBilling.ts at upload-finalize and hard-delete time. Trash
  // counts toward quota — bytes only released when the row is purged.
  storageBytesUsed      BigInt  @default(0)
  customMaxStorageBytes BigInt?

  // Copilot Suite — see docs/prd-copilot-suite.md.
  // GDPR Art. 22 opt-out from autonomous / AI-driven outreach. Transactional
  // email (receipts, password reset, etc.) still sends; CS Copilot playbooks
  // check this before queuing autonomous messages.
  aiAssistanceOptIn  Boolean  @default(true)
  // Actions the user has white-listed so Agent Alex's ActionAgent can execute
  // them without the per-action confirmation card. E.g. ["invite_candidate"].
  autoConfirmActions String[] @default([])

  // Online-assessment invitation quota — see docs/prd-online-assessments.md §4.10.
  // Counts `AssessmentInvitation` rows whose send attempt succeeded. Reset
  // monthly alongside interview invites. Null override = tier default.
  assessmentInvitesUsed             Int  @default(0)
  maxAssessmentInvitesMonthly       Int?
  customMaxAssessmentInvitesMonthly Int?

  // Multi-currency overage billing — see docs/prd-multicurrency-overage-billing.md.
  // Market drives which currency & per-unit rates apply. Derived at signup
  // from Accept-Language; admin-editable. Never re-derived runtime-side.
  market                   String  @default("other") // 'cn' | 'tw' | 'jp' | 'other'
  // Balance in minor units (fen / cents / yen / twd-integers) of `market`
  // currency. Coexists with the legacy USD `topUpBalance` during Phase 1
  // migration; after Phase 2 this is the source of truth.
  topUpBalanceMinor        Int     @default(0)
  // Feature opt-in. Paid tiers default true (blocked if wallet empty);
  // Free default false (no overage path). User-configurable in Billing.
  overageEnabled           Boolean @default(true)
  // Optional self-serve cap on month-to-date overage spend, in minor
  // units of user.market currency. Null = no cap. Admin can also set.
  overageMonthlyCapMinor   Int?
  // Admin-only per-user rate overrides. JSON map of PayPerUseSku →
  // amountMinor in user.market currency. Missing key => market default.
  overageRateOverrides     Json?
  // One-time consent ack for the in-product overage banner.
  firstOverageAcknowledged Boolean @default(false)

  // Alan (Bulk Hiring) prepaid credit balance. 1 credit = 5 Alan sessions, so
  // each new session debits 0.2. Free tier gets a lazy monthly top-up to the
  // configured allotment; admins can grant more. Authoritative reads/writes go
  // through AlanCreditService; every change appends an AlanCreditLedger row.
  alanCredits          Float     @default(0)
  alanCreditsRenewedAt DateTime? // UTC-month anchor for the lazy free-credit grant

  overageCharges     OverageCharge[]
  usageDeductionLogs UsageDeductionLog[]
  alanCreditLedger   AlanCreditLedger[]
  goHireAgentSeats   GoHireAgentSeat[]

  // v2 unified evaluations the user owns + share-event audit
  interviewEvaluations  InterviewEvaluation[]
  evaluationShareEvents EvaluationShareEvent[] @relation("EvaluationShareEventActor")

  team                               Team?                        @relation(fields: [teamId], references: [id], onDelete: SetNull)
  hiringRequests                     HiringRequest[]
  sessions                           Session[]
  hiringSessions                     HiringSession[]
  apiKeys                            ApiKey[]
  usageRecords                       ApiUsageRecord[]
  apiRequestLogs                     ApiRequestLog[]
  llmCallLogs                        LLMCallLog[]
  topUpRecords                       TopUpRecord[]
  alipayOrders                       AlipayOrder[]
  subscriptionRenewals               SubscriptionRenewal[]
  resumes                            Resume[]
  recruiterResumes                   Resume[]                     @relation("ResumeRecruiter")
  adminAdjustmentsReceived           AdminAdjustment[]            @relation("AdminAdjustmentsReceived")
  adminAdjustmentsMade               AdminAdjustment[]            @relation("AdminAdjustmentsMade")
  externalPaymentsReceived           ExternalPayment[]            @relation("ExternalPaymentsReceived")
  externalPaymentsRecorded           ExternalPayment[]            @relation("ExternalPaymentsRecorded")
  externalPaymentsVoided             ExternalPayment[]            @relation("ExternalPaymentsVoided")
  atsIntegrations                    ATSIntegration[]
  jobs                               Job[]
  interviews                         Interview[]
  interviewDialogTurns               InterviewDialogTurn[]
  matchingBatchRuns                  MatchingBatchRun[]
  matchingSessions                   MatchingSession[]
  matchingTaskTemplates              MatchingTaskTemplate[]
  activities                         UserActivity[]
  resumeVersions                     ResumeVersion[]
  interviewRoomConfigVersionsCreated InterviewRoomConfigVersion[] @relation("InterviewRoomConfigVersionsCreated")
  agents                             Agent[]
  agentCriteriaPresets               AgentCriteriaPreset[]
  agentIdealProfiles                 AgentIdealProfile[]
  userRecruiterProfile               UserRecruiterProfile?
  candidateInteractions              CandidateInteraction[]
  memoryAdminAuditLogs               MemoryAdminAuditLog[]
  teamMemberships                    TeamMember[]
  teamInvitations                    TeamInvitation[]             @relation("TeamInviter")
  alexSessions                       AgentAlexSession[]
  alexVoiceTurns                     AgentAlexVoiceTurn[]
  matchPrefilters                    MatchPrefilter[]
  resumeImportBatches                ResumeImportBatch[]
  assessments                        Assessment[]
  contacts                           Contact[]
  companies                          Company[]
  tasksAssigned                      Task[]                       @relation("TaskAssignee")
  tasksCreated                       Task[]                       @relation("TaskCreator")
  notifications                      Notification[]
  goHireInterviewsAsCandidate        GoHireInterview[]            @relation("GoHireCandidateUser")
  goHireInterviewsAsRecruiter        GoHireInterview[]            @relation("GoHireRecruiterUser")
  jobResumeMatches                   JobResumeMatch[]
  autoActionAuditLogs                AutoActionAuditLog[]
  fileVaultFolders                   FileVaultFolder[]
  fileVaultFiles                     FileVaultFile[]
  fileVaultAuditLogsAsOwner          FileVaultAuditLog[]          @relation("FileVaultAuditOwner")
  fileVaultAuditLogsAsActor          FileVaultAuditLog[]          @relation("FileVaultAuditActor")
  llmKeys                            UserLLMKey[]
  autoLoaderAgents                   AutoLoaderAgent[]
  autoLoaderTasks                    AutoLoaderTask[]

  // SCRM / CS Copilot. Self-relations: this customer's assigned sales/CS owner,
  // and (inverse) the customers a staff user owns. Plus the customer's CS data.
  // See the "SCRM / CS Copilot" model block near the end of this file.
  assignedSales          User?                 @relation("UserAssignedSales", fields: [assignedSalesId], references: [id], onDelete: SetNull)
  assignedCs             User?                 @relation("UserAssignedCs", fields: [assignedCsId], references: [id], onDelete: SetNull)
  salesAssignedCustomers User[]                @relation("UserAssignedSales")
  csAssignedCustomers    User[]                @relation("UserAssignedCs")
  customerProfile        CustomerProfile?      @relation("CustomerProfileUser")
  healthSnapshots        HealthScoreSnapshot[] @relation("HealthScoreSnapshotUser")
  customerInteractions   CustomerInteraction[] @relation("CustomerInteractionCustomer")
  crmAlertsAsCustomer    CrmAlert[]            @relation("CrmAlertCustomer")
  crmAlertsAssigned      CrmAlert[]            @relation("CrmAlertAssignee")
  crmEmailDraftsReceived CrmEmailDraft[]       @relation("CrmEmailDraftRecipient")
  crmEmailDraftsApproved CrmEmailDraft[]       @relation("CrmEmailDraftApprover")
  crmEmailDraftsRejected CrmEmailDraft[]       @relation("CrmEmailDraftRejecter")
  supportTicketsAsCustomer SupportTicket[]     @relation("SupportTicketCustomer")
  supportTicketsAssigned   SupportTicket[]     @relation("SupportTicketAssignee")
  playbookRuns           PlaybookRun[]         @relation("PlaybookRunCustomer")

  // Seeker app — /job-seeker candidate-facing product. 1:1 SeekerProfile is
  // created lazily on first /job-seeker visit. Cascade hard-delete happens
  // via SeekerDeletionService after the 7d soft-delete grace period.
  // See docs/prd-job-seeker-app.md + docs/job-seeker-engineering-spec.md.
  seekerProfile               SeekerProfile?              @relation("SeekerProfileUser")
  seekerOnboardingInterviews  SeekerOnboardingInterview[] @relation("SeekerOnboardingInterviewUser")

  // RoboApply — V1 fully-automatic-default candidate product. One mission per
  // user, lifetime. Lives behind the seeker-style boundary in
  // backend/src/roboapply/*. See docs/roboapply/02-architecture.md §6.
  roboApplyMission            RoboApplyMission?

  // RoboApply V2 — candidate-facing companion to RoboHire. Lives behind a
  // separate decoupled boundary in backend/src/roboapply/v2/*. See
  // docs/roboapply/v2/04-backend-spec.md §2.
  raCareerGoal      RACareerGoal?
  raTrackerEntries  RATrackerEntry[]
  raResumeVariants  RAResumeVariant[]
  raSavedSearches   RASavedSearch[]
  raCareerInsights  RACareerInsight[]
  raJobMatchScores  RAJobMatchScore[]
  raIntegrations    RAIntegration[]
  raMockSessions    RAMockSession[]

  // Interview Engine — standalone real-time AI voice-interview service
  // (backend/src/interview-engine/*). Powers /mock-interview and the external
  // API. Decoupled from RoboApply; the FK owner is the human user OR the API
  // key owner for external sessions.
  interviewSessions InterviewSession[]

  // Password reset
  passwordResetToken  String?   @unique
  passwordResetExpiry DateTime?

  // Email verification (signup confirmation). `emailVerified` defaults to TRUE on
  // purpose: prod applies schema with `prisma db push` at container start and has
  // no migration hook to run a backfill, so a `@default(false)` would mark every
  // EXISTING user unverified and risk locking them out. With `@default(true)` the
  // column add grandfathers all current rows as verified, and ONLY
  // AuthService.signup() (email/password) explicitly writes `false`. OAuth user
  // creation explicitly writes `true`. See docs/design-spec-signup-email-verification.md.
  emailVerified            Boolean   @default(true)
  emailVerifiedAt          DateTime?
  emailVerificationToken   String?   @unique // sha256 of the raw token emailed to the user
  emailVerificationExpiry  DateTime?
  // Explicit issue time of the live token. Used for the per-recipient resend
  // cooldown so it is independent of EMAIL_VERIFICATION_TTL_HOURS (which can be
  // changed by an admin and would otherwise corrupt a back-computed issue time).
  emailVerificationIssuedAt DateTime?

  // Action-First Matching v2 — per-user defaults for re-match and talent-pool
  // picker. Shape lives in backend/src/lib/matchingPreferences.ts. Defaults are
  // applied server-side in GET so the frontend can treat as always-present.
  matchingPreferences Json?

  @@index([email])
  @@index([provider, providerId])
  @@index([teamId])
  @@index([createdAt])
  @@index([assignedSalesId])
  @@index([assignedCsId])
}

// Per-user LLM API keys ("Bring Your Own Key").
// One row per (user, provider). When present + active, RoboHire routes
// the user's LLM calls through their key instead of the platform key,
// stamps `byok=true` on ApiRequestLog/LLMCallLog with `cost=0`, and
// short-circuits matchBilling / AgentAlexQuotaService so the user's
// plan counters are not consumed. See docs/prd-byok.md.
model UserLLMKey {
  id             String    @id @default(cuid())
  userId         String
  // openai | anthropic | google | deepseek | moonshot | minimax | openrouter | ollama | newapi
  provider       String
  // Optional user-supplied nickname (e.g. "team OpenAI prod").
  label          String?
  // base64( IV || AuthTag || AES-256-GCM-ciphertext ) via lib/crypto.ts.
  // Decrypted only inside byokService.resolve() at request time; never
  // logged, never returned to the frontend.
  encryptedKey   String    @db.Text
  // Optional base URL override. Required for ollama/newapi (self-hosted)
  // and minimax (which has region-specific endpoints). For direct
  // providers (openai/anthropic/google), null means "use the provider
  // SDK default endpoint". SSRF-validated server-side.
  baseUrl        String?
  isActive       Boolean   @default(true)
  // Last time the test-on-save probe ran.
  lastTestedAt   DateTime?
  // 'ok' | 'failed'.
  lastTestStatus String?
  // Provider error message from the last failed probe (truncated).
  lastTestError  String?   @db.Text
  // Bumped each time LLMService.chat actually uses this row.
  lastUsedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId])
  @@index([provider])
}

// System-level LLM provider credentials (the "system DB key" tier), managed by
// admins from /product/admin/llm-settings. This is the platform default that
// sits BETWEEN per-user BYOK (UserLLMKey, wins) and the .env fallback (loses):
// resolution precedence is  user BYOK -> system DB key -> env.
//
// One row per provider (global, not per-environment — a single running instance
// has one set of provider keys). The encrypted key mirrors UserLLMKey exactly so
// it reuses the same lib/crypto.ts AES-256-GCM lifecycle. A DECRYPT FAILURE here
// must DEGRADE TO ENV (never throw) — unlike UserLLMKey — so a wrong/rotated
// FIELD_ENCRYPTION_KEY can never black out all platform LLM traffic. See
// docs/llm-settings-db/ and lib/llm/systemCredentials.ts.
model SystemLLMKey {
  id             String    @id @default(cuid())
  // openai | anthropic | google | deepseek | moonshot | minimax | openrouter | ollama | newapi
  // NOTE: stored as 'moonshot'; the LLM stack's internal 'kimi' type normalizes to it.
  provider       String    @unique
  label          String?
  // base64( IV || AuthTag || AES-256-GCM-ciphertext ) via lib/crypto.ts. May be
  // '' for keyless self-hosted gateways (ollama). Never logged / returned to a client.
  encryptedKey   String    @db.Text
  // Optional base URL override (proxy / self-hosted / region). Required for
  // ollama/newapi/minimax. SSRF-validated server-side (validateBaseUrl).
  baseUrl        String?
  isActive       Boolean   @default(true)
  // Per-provider behavioural tuning that used to live in env, e.g. DeepSeek:
  // { thinkingMode: 'enabled'|'disabled', reasoningEffort: 'high'|'max', proxyKey }.
  // Travels with the credential (independent of which key is used).
  tuning         Json?
  lastTestedAt   DateTime?
  lastTestStatus String?
  lastTestError  String?   @db.Text
  lastUsedAt     DateTime?
  // Admin userId of the last writer (for audit cross-reference).
  updatedBy      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([provider])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
}

model HiringRequest {
  id                    String    @id @default(cuid())
  userId                String
  title                 String
  clientName            String?
  requirements          String    @db.Text
  jobDescription        String?   @db.Text
  status                String    @default("active") // active, paused, closed
  webhookUrl            String?
  intelligenceData      Json?
  intelligenceUpdatedAt DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  candidates    Candidate[]
  resumeJobFits ResumeJobFit[]
  jobs          Job[]
  interviews    Interview[]

  @@index([userId])
  @@index([status])
  @@index([userId, status])
  @@index([userId, createdAt])
}

model Candidate {
  id               String   @id @default(cuid())
  hiringRequestId  String
  name             String
  email            String
  resumeText       String   @db.Text
  matchScore       Int?
  status           String   @default("pending") // pending, screening, interviewed, shortlisted, rejected
  evaluationReport Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  externalAtsId       String?
  externalAtsProvider String?

  hiringRequest HiringRequest         @relation(fields: [hiringRequestId], references: [id], onDelete: Cascade)
  interviews    Interview[]
  dialogTurns   InterviewDialogTurn[]

  @@index([hiringRequestId])
  @@index([status])
  @@index([email])
  @@index([hiringRequestId, status])
  @@index([hiringRequestId, matchScore])
  @@index([externalAtsId])
}

model HiringSession {
  id        String   @id @default(cuid())
  userId    String
  title     String?
  messages  Json     @default("[]")
  status    String   @default("active") // active, completed, archived
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([userId, updatedAt])
}

model ApiKey {
  id         String    @id @default(cuid())
  userId     String
  name       String
  key        String    @unique
  prefix     String // First 8 chars for display (rh_xxxx...)
  lastUsedAt DateTime?
  expiresAt  DateTime?
  scopes     String[]  @default(["read", "write"])
  isActive   Boolean   @default(true)
  /// Soft-delete lifecycle: 'active' (default) or 'deleted'. We never HARD-delete
  /// an API key, because the four usage/billing tables (ApiUsageRecord,
  /// ApiRequestLog, LLMCallLog, UsageDeductionLog) each carry an apiKeyId FK with
  /// onDelete: SetNull — a hard delete would null per-key cost attribution on
  /// every historical row, forever. Soft delete preserves that linkage so finance
  /// can bill per (userId, apiKeyId) indefinitely. A deleted key always has
  /// isActive=false too (so the auth layer rejects it), is hidden from owner +
  /// admin lists, and no longer counts toward the per-user key cap.
  status     String    @default("active")
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  usageRecords  ApiUsageRecord[]
  requestLogs   ApiRequestLog[]
  llmCallLogs   LLMCallLog[]
  deductionLogs UsageDeductionLog[]

  @@index([key])
  @@index([userId])
  @@index([status])
}

model ApiUsageRecord {
  id               String   @id @default(cuid())
  userId           String
  apiKeyId         String?
  requestId        String?
  endpoint         String
  method           String
  statusCode       Int      @default(200)
  promptTokens     Int      @default(0)
  completionTokens Int      @default(0)
  totalTokens      Int      @default(0)
  cost             Float    @default(0)
  model            String?
  provider         String?
  durationMs       Int      @default(0)
  createdAt        DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  apiKey ApiKey? @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([apiKeyId])
  @@index([createdAt])
  @@index([endpoint])
  @@index([userId, createdAt])
  @@index([apiKeyId, createdAt])
}

model ApiRequestLog {
  id               String   @id @default(cuid())
  requestId        String?
  userId           String?
  apiKeyId         String?
  endpoint         String
  method           String
  module           String
  apiName          String
  statusCode       Int      @default(200)
  durationMs       Int      @default(0)
  promptTokens     Int      @default(0)
  completionTokens Int      @default(0)
  totalTokens      Int      @default(0)
  llmCalls         Int      @default(0)
  cost             Float    @default(0)
  // True if at least one LLM call inside this request used a user-supplied
  // BYOK key. When true, `cost` is 0 even if tokens were consumed — the
  // user's external provider was billed, not the platform.
  byok             Boolean  @default(false)
  provider         String?
  model            String?
  ipAddress        String?
  userAgent        String?
  requestPayload   Json?
  responsePayload  Json?
  createdAt        DateTime @default(now())

  user               User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  apiKey             ApiKey?             @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)
  llmCallLog         LLMCallLog[]
  usageDeductionLogs UsageDeductionLog[]

  @@index([requestId])
  @@index([userId])
  @@index([apiKeyId])
  @@index([createdAt])
  @@index([endpoint])
  @@index([module])
  @@index([apiName])
  @@index([provider])
  @@index([model])
  @@index([userId, createdAt])
  @@index([module, createdAt])
  @@index([apiName, createdAt])
}

model LLMCallLog {
  id               String   @id @default(cuid())
  requestId        String?
  apiRequestLogId  String?
  userId           String?
  // Set when the parent request was authenticated with an API key (rh_...).
  // Null for cookie/JWT (UI) requests and non-HTTP contexts (cron/worker).
  // Lets finance attribute per-LLM-call token cost per API key, not just per user.
  apiKeyId         String?
  endpoint         String
  module           String
  status           String   @default("success")
  provider         String
  model            String
  promptTokens     Int      @default(0)
  completionTokens Int      @default(0)
  totalTokens      Int      @default(0)
  cost             Float    @default(0)
  // True when this LLM call was routed through a user-supplied BYOK key.
  // `cost` is forced to 0 in that case (the user's external provider was
  // billed, not the platform). See docs/prd-byok.md.
  byok             Boolean  @default(false)
  durationMs       Int      @default(0)
  requestMessages  Json?
  requestOptions   Json?
  responsePreview  String?  @db.Text
  errorMessage     String?  @db.Text
  createdAt        DateTime @default(now())

  apiRequestLog ApiRequestLog? @relation(fields: [apiRequestLogId], references: [id], onDelete: SetNull)
  user          User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  apiKey        ApiKey?        @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)

  @@index([requestId])
  @@index([apiRequestLogId])
  @@index([userId])
  @@index([apiKeyId])
  @@index([apiKeyId, createdAt])
  @@index([createdAt])
  @@index([endpoint])
  @@index([module])
  @@index([provider])
  @@index([model])
  @@index([module, createdAt])
}

