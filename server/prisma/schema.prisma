  updatedAt              DateTime @updatedAt

  @@index([adminUserId])
  @@index([createdAt])
}

// Tracks async resume batch uploads (up to 100 files per batch).
// Per-file state lives inside `items` JSON — one row per upload batch, updated
// as each file moves through extracting → parsing → saving → done phases.
// Frontend polls GET /upload-batch/:id/status every ~1.5s to render progress.
model ResumeImportBatch {
  id                   String    @id @default(cuid())
  userId               String
  jobId                String? // Optional: apply all successful resumes to this job
  totalFiles           Int
  status               String    @default("processing") // processing | completed | failed
  extractingCount      Int       @default(0)
  parsingCount         Int       @default(0)
  savingCount          Int       @default(0)
  createdCount         Int       @default(0) // new Resume rows inserted (verified by re-read)
  updatedCount         Int       @default(0) // existing Resume rows overwritten (verified)
  personDuplicateCount Int       @default(0) // awaiting user overwrite/skip choice
  errorCount           Int       @default(0)
  verifiedCount        Int       @default(0) // createdCount + updatedCount, after save verification
  items                Json // Array<ResumeImportItem> — see ResumeBatchImportService.ts
  errorMessage         String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  completedAt          DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status])
}

model AgentAlexSession {
  id           String   @id @default(cuid())
  userId       String
  title        String   @default("New Chat")
  messages     Json     @default("[]") // ChatMessage[]
  requirements Json     @default("{}") // HiringRequirements
  linkedJobId  String?  @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
  linkedJob Job? @relation(fields: [linkedJobId], references: [id], onDelete: SetNull)

  @@index([userId, updatedAt])
}

// Bulk Hiring ("Alan") — the public, client-facing AI intake funnel for
// high-volume / multi-position recruitment. Sessions are anonymous by default
// (userId is null for logged-out visitors); a logged-in enterprise user gets
// their id stamped for later association. `campaign` holds the structured
// multi-position brief (BulkHiringCampaign), `messages` the chat transcript.
// `turnCount` is the per-session cap that protects the public LLM endpoint.
// No User relation on purpose — keeps the model self-contained and lets
// anonymous rows exist without a back-relation edit on the big User model.
model AlanSession {
  id           String   @id @default(cuid())
  userId       String?
  title        String   @default("批量招聘需求")
  status       String   @default("active") // active | submitted | updated (edited after a submit)
  campaign     Json     @default("{}") // BulkHiringCampaign
  messages     Json     @default("[]") // ChatMessage[] — full transcript, persisted so the client can reopen a session and continue
  turnCount    Int      @default(0)
  contactName  String?
  contactEmail String?
  // Stable timestamp of the FIRST submit (set once when status → submitted;
  // refreshed on an explicit re-submit). null while status is 'active'.
  submittedAt  DateTime?

  // Usage + cost accounting (accrued across every turn of the session). Tokens
  // and platformCostUsd come from the direct-Anthropic chat stream + suggestion
  // calls; creditsCharged is the prepaid Alan credit consumed (1 credit = 5
  // sessions, so a session normally costs 0.2, charged once at creation).
  // See AlanCreditService + AlanCreditLedger for the authoritative credit audit.
  totalInputTokens  Int     @default(0)
  totalOutputTokens Int     @default(0)
  totalCostUsd      Float   @default(0)
  creditsCharged    Float   @default(0)
  lastModel         String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId, updatedAt])
  @@index([status, updatedAt])
}

/// Immutable audit ledger for Alan (Bulk Hiring) prepaid-credit movements. One
/// row per grant / debit / refund / admin adjustment. Never mutated — reversals
/// insert a sibling row. The running balance lives on User.alanCredits; this
/// table reconstructs how it got there. Written only by AlanCreditService.
/// Pricing rule: 1 credit = 5 Alan sessions ⇒ each new session debits 0.2.
model AlanCreditLedger {
  id               String   @id @default(cuid())
  userId           String
  delta            Float // +grant / −debit (credits)
  balanceAfter     Float
  reason           String // grant_free_monthly | grant_admin | signup_bonus | debit_session | refund | admin_adjust
  relatedSessionId String? // AlanSession id for debit/refund (idempotency key)
  source           String? // system | admin
  metadata         Json?
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([relatedSessionId])
}

// One row per completed voice "turn" (model responded to a user utterance).
// Text turns are counted from ApiRequestLog; voice turns can't reuse that
// because the live WS doesn't pass through the audit middleware. Kept as a
// slim append-only log so AgentAlexQuotaService can sum text + voice at
// query time without reset logic. See AgentAlexQuotaService.ts comments.
model AgentAlexVoiceTurn {
  id          String   @id @default(cuid())
  userId      String
  // WS connection id (one connection can have many turns). Handy for the
  // "2-hour call burned 180 turns" diagnostic; not used by quota math.
  wsSessionId String
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// ────────────────────────────────────────────────────────────────────────────
// MatchPrefilter — Agent Alex matching v2 checkpoint state.
//
// When Alex detects sourcing intent, the LLM calls `prefilter_talent_pool`
// (free, no LLM cost) which writes a row here capturing the funnel: which
// resumes passed the keyword screen and what the user's criteria were.
//
// The row's `id` is then handed to the user as the "prefilterId". When the
// user clicks "立即开始匹配" in the chat card, the frontend POSTs to
// /api/v1/agent-alex/match/run with that id. The backend looks up this row,
// validates ownership + freshness, then runs `runFullMatch()` over the
// stored resumeIds — billed as 1 usage.
//
// Why a DB table instead of an in-memory Map: Render scales the backend
// horizontally and we deploy multiple times a day. An in-memory cache would
// confuse mid-flow recruiters every time their next request lands on a
// different instance or after a deploy.
//
// Rows are short-lived (TTL = 10 min by default, controlled via expiresAt).
// A cleanup sweep on JobsRegistry deletes expired rows nightly. `consumed`
// is set to true after a successful runFullMatch so the same prefilterId
// can't be reused — defense against double-billing if the user clicks twice.
// ────────────────────────────────────────────────────────────────────────────
model MatchPrefilter {
  id               String    @id @default(cuid())
  userId           String
  // Optional — when present, ties the prefilter to a specific Alex session
  // so the audit trail shows which conversation triggered the match.
  sessionId        String?
  // Snapshot of the criteria used for the keyword filter. Required so the
  // full-match phase reuses the same JD text the user saw the funnel for.
  criteria         Json
  // Resume IDs that survived the keyword pre-filter, ordered by recency.
  // The full-match phase iterates this exact list — no re-filter.
  resumeIds        String[]
  // Funnel telemetry shown in the PrefilterSummaryCard.
  totalPool        Int
  passedPrefilter  Int
  // Top exclusion reasons, e.g. ["missing Python (210)", "missing Node.js (63)"].
  exclusionReasons Json      @default("[]")
  // Sample names ("张三 (Python, 5y)", ...) — top 3 displayed in the card.
  sampleNames      Json      @default("[]")
  // Set true when runFullMatch successfully starts. Single-use semantics
  // prevent double-billing on accidental double-clicks.
  consumed         Boolean   @default(false)
  consumedAt       DateTime?
  // Resulting agent id (set after runFullMatch creates the Agent). Lets the
  // UI link the match results back to the prefilter row for "show me the
  // candidates from this match" navigation.
  agentId          String?
  createdAt        DateTime  @default(now())
  expiresAt        DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([expiresAt]) // cleanup sweep
  @@index([sessionId])
}

model Task {
  id          String  @id @default(cuid())
  userId      String // assignee
  createdById String? // who/what created it (null = system)

  // Classification
  type         String // evaluate_interview, review_evaluation, hiring_decision, review_matches, shortlist_candidates, send_interview_invite, follow_up_invitation, interview_reminder, run_matching, review_agent_candidates, publish_job, close_stale_job, stale_pipeline, sync_gohire_interviews, reparse_resume
  category     String // pipeline, evaluation, sourcing, communication, admin
  assigneeType String @default("human") // human | agent

  // Content
  title       String
  description String? @db.Text
  actionUrl   String? // deep link to relevant page
  actionLabel String? // button text for the primary action

  // Context links
  jobId             String?
  resumeId          String?
  interviewId       String?
  candidateId       String?
  matchingSessionId String?
  agentId           String?
  hiringRequestId   String?

  // Priority & SLA
  priority    String    @default("medium") // critical, high, medium, low
  dueAt       DateTime?
  slaDeadline DateTime?
  escalatedAt DateTime?

  // Status
  status        String    @default("pending") // pending, in_progress, completed, dismissed, expired, auto_completed
  completedAt   DateTime?
  completedBy   String? // userId or 'system'
  dismissReason String?
  result        Json? // outcome data

  // Trigger
  triggerEvent    String // what event spawned this
  triggerData     Json? // event context snapshot
  isAutoGenerated Boolean @default(true)

  // Archive
  archivedAt DateTime? // set 7 days after completed/dismissed

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user          User           @relation("TaskAssignee", fields: [userId], references: [id], onDelete: Cascade)
  createdBy     User?          @relation("TaskCreator", fields: [createdById], references: [id], onDelete: SetNull)
  job           Job?           @relation(fields: [jobId], references: [id], onDelete: SetNull)
  resume        Resume?        @relation(fields: [resumeId], references: [id], onDelete: SetNull)
  interview     Interview?     @relation(fields: [interviewId], references: [id], onDelete: SetNull)
  notifications Notification[]

  @@index([userId, status])
  @@index([userId, priority])
  @@index([type, status])
  @@index([status, dueAt])
  @@index([jobId])
  @@index([interviewId])
  @@index([resumeId])
  @@index([archivedAt])
  @@index([createdAt])
  @@index([userId, category, status]) // job-bank/page-init communication tasks lookup
}

model TaskAutomationRule {
  id                 String   @id @default(cuid())
  userId             String? // null = global default
  taskType           String   @unique // maps to task type enum
  enabled            Boolean  @default(true)
  assigneeType       String   @default("human") // human | agent
  autoExecute        Boolean  @default(false) // for agent tasks: execute immediately?
  slaHours           Int? // SLA deadline in hours
  priority           String   @default("medium") // default priority
  escalateAfterHours Int? // hours after creation to escalate
  emailNotify        Boolean  @default(false) // send email on creation?
  config             Json? // extra type-specific config
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([taskType])
  @@index([userId])
}

model Notification {
  id         String    @id @default(cuid())
  userId     String // recipient
  taskId     String? // linked task
  type       String // task_created, task_overdue, task_escalated, task_completed, interview_completed, interview_completed_digest
  title      String
  message    String?
  // i18n: optional translation keys + interpolation params. When titleKey is
  // present the frontend renders t(titleKey, params) and falls back to the
  // English `title` column when the key is missing (legacy rows, or notifications
  // that wrap user-typed content like manually-created tasks).
  titleKey   String?
  messageKey String?
  params     Json?
  actionUrl  String?
  read       Boolean   @default(false)
  readAt     DateTime?
  emailSent  Boolean   @default(false)
  dedupKey   String?   @unique // app-level idempotency key (e.g. interview_completed:<interviewId>)
  createdAt  DateTime  @default(now())

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task? @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([userId, read])
  @@index([userId, createdAt])
  @@index([taskId])
}

model Contact {
  id              String    @id @default(cuid())
  userId          String
  firstName       String
  lastName        String
  email           String?
  phone           String?
  jobTitle        String?
  contactType     String    @default("client") // hiring_manager, client, vendor, reference
  companyId       String?
  notes           String?   @db.Text
  lastContactedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

