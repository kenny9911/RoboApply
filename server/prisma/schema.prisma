/// In-app notifications + outbound email/push (Pattern 4 — passive monitoring).
/// Mirrors recruiter-side Notification model but in a separate table.
model SeekerNotification {
  id              String @id @default(cuid())
  seekerProfileId String

  /// 'recruiter_viewed' | 'interview_scheduled' | 'auto_apply_failed' |
  /// 'weekly_summary' | 'training_due' | 'cap_warning' | 'consent_revoked'.
  type String

  title    String
  body     String? @db.Text
  /// Deep-link path within /job-seeker/* — e.g. '/job-seeker/applications/abc'.
  deepLink String?

  /// Linked entity for backref ('application' / 'mock' / 'subscription' / etc).
  relatedEntityType String?
  relatedEntityId   String?

  readAt      DateTime?
  emailSentAt DateTime?

  createdAt DateTime @default(now())

  seekerProfile SeekerProfile @relation(fields: [seekerProfileId], references: [id], onDelete: Cascade)

  @@index([seekerProfileId, readAt])
  @@index([seekerProfileId, createdAt])
  @@index([type])
}

// ============================================================================
//  RoboApply (V1 — fully-automatic-default candidate product)
// ----------------------------------------------------------------------------
//  Mission Control product layered on top of the seeker stack. One mission per
//  user, lifetime. Wraps SeekerAutoApplyService (Greenhouse + Lever OAuth) to
//  produce auto-applied runs on a time-gated cron (05:00 matcher → 07:00 user-
//  local digest → 09:00 user-local submitter). See docs/roboapply/02-architecture.md.
//
//  Boundary: tables are additive; the only writes happen inside
//  backend/src/roboapply/* (seeker-style sibling boundary). All RoboApply quota
//  goes through the existing UsageDeductionLog ledger using new SKUs
//  (`roboapply_intent` / `roboapply_cover_letter` / `roboapply_digest`) plus
//  the underlying `resume_match` / `seeker_apply` debits.
// ============================================================================

enum RoboApplyReviewMode {
  auto
  review_first
}

enum RoboApplyRunStatus {
  queued
  previewing
  submitted
  skipped_by_user
  failed
  undone
}

enum RoboApplyBoardAdapter {
  greenhouse
  lever
  manual_link
}

/// 1 mission per user, lifetime. Created on RoboApply onboarding complete;
/// pause is via `pausedUntil` (null = active). Intent edits bump `intentVersion`
/// which is folded into the cover-letter cache key so stale-intent letters get
/// excluded from future selection per arch §12.
model RoboApplyMission {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Intent — prose + parsed structured form
  intentText      String   @db.Text
  parsedIntent    Json?
  intentVersion   Int      @default(1) // bumps on each save; cache-key salt
  intentParsedAt  DateTime?

  // Tier + behaviour
  tier                    SeekerSubscriptionTier @default(free) // free | premium | premium_plus
  reviewMode              RoboApplyReviewMode    @default(auto)
  dailyCap                Int                    @default(3)
  coverLetterToneOverride String?                @db.Text // Premium+ only

  // State machine
  enabled       Boolean   @default(true)
  pausedUntil   DateTime? // null = not paused; future date = paused-until; far-future = indefinite
  pausedReason  String?
  timezone      String    @default("UTC") // IANA TZ string captured at onboarding
  locale        String    @default("en")

  // Resume snapshot — which resume the mission is using. SetNull if the
  // recruiter-side Resume row is hard-deleted; the mission keeps its history.
  resumeId String?
  resume   Resume? @relation("RoboApplyMissionResume", fields: [resumeId], references: [id], onDelete: SetNull)

  // Scheduler bookkeeping — used by the catchup sweep + missed-window detect.
  nextSweepAt        DateTime?
  lastDigestSentAt   DateTime?
  lastSubmissionAt   DateTime?

  // Telemetry
  totalSubmitted Int @default(0)
  totalSkipped   Int @default(0)
  totalUndone    Int @default(0)
  totalFailed    Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  runs    RoboApplyRun[]
  digests RoboApplyDigest[]

  // Cron-pickup partial index — matcher scans missions where enabled+unpaused
  // AND nextSweepAt is due. Postgres treats `pausedUntil IS NULL` AS-IS in the
  // index expression — Prisma encodes this as a multi-column index; the
  // matcher SQL adds the IS-NULL or LTE-now filter.
  @@index([enabled, pausedUntil, nextSweepAt])
  @@index([timezone, enabled])
  @@index([userId])
}

/// One auto-apply attempt. Created in `queued` by the matcher, transitions to
/// `previewing` after cover-letter authoring, then `submitted`/`failed`/
/// `skipped_by_user`/`undone` per the state machine.
model RoboApplyRun {
  id        String           @id @default(cuid())
  missionId String
  mission   RoboApplyMission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  // What we're submitting
  jobId          String? // FK to Job — nullable to allow `manual_link` runs that don't have a Job row
  job            Job?    @relation("RoboApplyRunJob", fields: [jobId], references: [id], onDelete: SetNull)
  jobContentHash String  // for dedup; matches Job.contentHash when jobId is set
  // Snapshot of the resume text submitted (post-tailoring). Stored verbatim
  // for the transparency screen so we don't drift if the source resume
  // changes later.
  resumeId           String
  tailoredResumeText String  @db.Text

  // Cover letter — produced by RoboApplyAuthorAgent (Opus 4.7) and verified by
  // RoboApplyCitationGuardAgent (via SeekerResumeTailorAgent's claim-guard).
  coverLetter       String   @db.Text
  coverLetterModel  String  // 'anthropic/claude-opus-4-7' or sonnet fallback
  coverLetterCost   Decimal? @db.Decimal(10, 6) // forensic — UsageDeductionLog is canonical
  // The literal system+user prompt blob that produced the cover letter.
  // Surfaced by `POST /runs/:id/show-prompt` for the transparency screen.
  coverLetterPrompt Json?

  // Matching reasoning
  matchScore       Int
  matchExplanation Json // full MatchResult shape (jsonb)
  rationaleForPick String @db.Text // 1-sentence "why this one" for the digest

  // Scheduling — plannedSubmitAt is always 09:00 user-local; actualSubmitAt is
  // the timestamp the submitter actually fired. catchupSweep moves stale
  // `previewing` runs to `failed` after 6h past plannedSubmitAt.
  plannedSubmitAt DateTime
  actualSubmitAt  DateTime?
  undoneAt        DateTime?
  failedAt        DateTime?
  failureReason   String? // 'cron_missed_window' | 'cover_letter_unavailable' | adapter error codes

  // Adapter
  boardAdapter      RoboApplyBoardAdapter
  boardSubmissionId String? // ID returned by Greenhouse / Lever
  boardResponse     Json? // adapter-specific payload (HTTP status, body fragment, etc.)
  // True iff this run was submitted by SeekerAutoApplyService in simulation
  // mode (no env keys set). Surface to the user as "Will go live once we
  // connect to {Board}".
  simulated         Boolean @default(false)

  status RoboApplyRunStatus @default(queued)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Hard dedup — never two runs for the same (mission, jobContentHash)
  // regardless of status. The 14-day soft-dedup window is enforced in
  // application code (matcher refuses to re-queue).
  @@unique([missionId, jobContentHash])
  // Submitter cron + 9am picker — partial scans rely on the leading
  // `plannedSubmitAt` column ordering for index-only access.
  @@index([status, plannedSubmitAt])
  @@index([missionId, status])
  @@index([missionId, plannedSubmitAt(sort: Desc)])
  @@index([missionId, actualSubmitAt])
}

/// Persisted digest narrative — one per (mission, UTC-day). Source of truth
/// for the morning email and the cached SSE replay on `/mission`. citedRunIds
/// is verified by CitationGuard before persistence; if guard fails, sentences
/// referencing unknown runs are dropped and the digest is still saved with
/// `citationGuardPassed=false`.
model RoboApplyDigest {
  id        String           @id @default(cuid())
  missionId String
  mission   RoboApplyMission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  dayBucketUtc DateTime // truncated to UTC day
  generatedAt  DateTime @default(now())

  emailSubject String
  emailBody    String   @db.Text // markdown — ≤ 600 words
  appNarration String   @db.Text // markdown — ≤ 200 words (the shorter version for /mission)
  // String[] of RoboApplyRun.id values referenced in narration; verified.
  citedRunIds  String[]
  modelUsed    String
  tokenCost    Decimal? @db.Decimal(10, 6)

  // Sent state — null if the digest exists but the email hasn't gone out yet
  // (e.g. the user is in a TZ that hasn't hit 07:00 yet, or send failed).
  sentAt              DateTime?
  citationGuardPassed Boolean   @default(false)

  createdAt DateTime @default(now())

  @@unique([missionId, dayBucketUtc])
  @@index([dayBucketUtc])
}

/// Cover-letter cache. Keyed by sha256(resumeId + jobId + intentVersion +
/// toneOverrideHash). The Opus 4.7 cost model REQUIRES this cache to keep
/// Premium+ inside its $10/MAU/mo ceiling — see arch §8. expiresAt drives a
/// weekly cleanup cron; entries past expiresAt are pruned in a single
/// `deleteMany` sweep.
model RoboApplyCoverLetterCache {
  id String @id @default(cuid())

  /// sha256 of `${resumeId}|${jobId}|${intentVersion}|${toneOverrideHash ?? '-'}`.
  cacheKey String @unique

  /// Component fields persisted for forensics + cache-bust queries.
  resumeId         String
  jobId            String
  intentVersion    Int
  toneOverrideHash String?

  /// Output: the full RoboApplyAuthorOutput shape from
  /// backend/src/roboapply/agents/RoboApplyAuthorAgent.ts.
  output           Json
  modelUsed        String
  tokenCost        Decimal? @db.Decimal(10, 6)
  citationGuardPassed Boolean @default(true) // false rows are cached as fallback letters

  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([expiresAt])
  @@index([resumeId, jobId])
}

//
// ─────────────────────────────────────────────────────────────────────────────
//  RoboApply V2 (candidate-facing companion product)
// ─────────────────────────────────────────────────────────────────────────────
//
// All tables prefixed `RA` to distinguish from V1's `RoboApply*`. The slice
// is strictly additive — no FK changes to any existing table. Lives behind
// the decoupled boundary in backend/src/roboapply/v2/* enforced by
// scripts/check-roboapply-v2-boundary.mjs.
//
// Spec: docs/roboapply/v2/04-backend-spec.md §2 (every column / index here
// must match the spec exactly).
//
// Note on indexes: the spec calls for a `pg_trgm` GIN index on
// `RAJob.titleNormalized` + `RAJob.companyNameNormalized` for fast
// substring search. Prisma 7 does not natively manage GIN-trgm indexes
// via `@@index`, and the seed-data scale (~200 rows) makes a sequential
// scan acceptable for launch. The btree indexes below cover the rest of
// the spec's index requirements. When V2.5 lands live-ingest at 10k+
// rows, add `previewFeatures = ["postgresqlExtensions"]` + an
// `extensions = [pg_trgm]` block to the datasource and a manual
// `CREATE INDEX ... USING gin (...) gin_trgm_ops` migration.
//

/// One row per user. The "Career Goal" card on /home.
model RACareerGoal {
  id                     String    @id @default(cuid())
  userId                 String    @unique
  user                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  targetTitle            String
  targetDate             DateTime? // date-only semantics; ISO YYYY-MM-DD on the wire
  targetSalaryMin        Int?
  targetSalaryMax        Int?
  targetSalaryCurrency   String?   @default("USD")
  weeklyApplicationGoal  Int       @default(5)

  /// { countries: string[], cities: string[], remoteOk: boolean, hybridOk: boolean }
  preferredLocations     Json?
  /// 'remote' | 'hybrid' | 'onsite' | null
  preferredWorkType      String?
  /// 'ic' | 'senior' | 'staff' | 'principal' | 'manager' | 'director' | 'vp' | 'cxo' | null
  seniority              String?
  notesMarkdown          String?   @db.Text

  /// RoboApply V3 extended-preferences blob (RAPreferences minus the fields
  /// goal/auth-profile own). Deep-merged on PATCH. Null until first save —
  /// the RAPreferencesService defaults it for first-time users.
  preferencesBlob        Json?

  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
}

/// The seeded V2 job index. One row per (sourceBoard, externalId).
/// Spec: 04-backend-spec.md §2.2.
model RAJob {
  id                     String    @id @default(cuid())
  externalId             String
  /// 'greenhouse' | 'lever' | 'seed' | 'manual' | 'jsearch'
  sourceBoard            String
  applyUrl               String

  title                  String
  /// lowercased, trimmed — forward-compatible with pg_trgm GIN index (V2.5)
  titleNormalized        String
  companyName            String
  companyNameNormalized  String
  companyLogoUrl         String?

  location               String?
  locationCity           String?
  locationCountry        String?
  /// 'remote' | 'hybrid' | 'onsite'
  workType               String    @default("onsite")
  /// 'full_time' | 'contract' | 'part_time' | 'internship' | null
  employmentType         String?

  salaryMin              Int?
  salaryMax              Int?
  salaryCurrency         String?   @default("USD")
  /// 'year' | 'hour' | 'month'
  salaryPeriod           String?   @default("year")

  description            String    @db.Text
  descriptionPlain       String    @db.Text
  qualifications         String?   @db.Text
  responsibilities       String?   @db.Text
  benefits               String?   @db.Text

  postedAt               DateTime?
  /// Seed-only metadata: `{ companyTier: 'faang' | 'series_b' | …, role: 'pm' | 'swe' | … }`
  seedTags               Json?
  archivedAt             DateTime?

  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  trackerEntries         RATrackerEntry[]
  resumeVariants         RAResumeVariant[] @relation("RAResumeVariantTargetJob")
  keywordExtraction      RAKeywordExtraction?
  matchScores            RAJobMatchScore[]

  @@unique([externalId, sourceBoard])
  @@index([workType, archivedAt])
  @@index([locationCity, archivedAt])
  @@index([postedAt(sort: Desc), archivedAt])
  @@index([salaryMin(sort: Desc), archivedAt])
  @@index([archivedAt])
}

/// User's Job Tracker rows.
/// Spec: 04-backend-spec.md §2.3.
model RATrackerEntry {
  id                 String    @id @default(cuid())
  userId             String
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  jobId              String?
  job                RAJob?    @relation(fields: [jobId], references: [id], onDelete: SetNull)

  /// `{ title, companyName, location?, applyUrl }` captured at add-time so the
  /// row keeps rendering when jobId is null OR the linked RAJob was removed.
  externalSnapshot   Json?

  /// `bookmarked | applying | applied | interviewing | negotiating | accepted | rejected | withdrawn`
  status             String    @default("bookmarked")
  excitementStars    Int       @default(0)
  maxSalary          Int?
  maxSalaryCurrency  String?   @default("USD")
  notesMarkdown      String?   @db.Text
  dateSaved          DateTime  @default(now())
  dateApplied        DateTime?
  deadline           DateTime? // date-only semantics
  followUpAt         DateTime?
  /// 'ra_autoapply' | 'manual' | 'extension' | null
  appliedVia         String?

  /// Optional V1 `RoboApplyRun.id` if created by the V1 auto-apply flow.
  /// Read-only link — no FK constraint to avoid cross-namespace coupling.
  linkedRunId        String?

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  /// Partial-unique semantics ("UNIQUE(userId, jobId) WHERE jobId IS NOT NULL")
  /// are enforced in application code in V2 — Prisma cannot express
  /// partial-unique. Application path: routes/tracker.ts POST checks for
  /// existing (userId, jobId) before insert and returns 409 'duplicate_tracker_entry'.
  @@index([userId, status, updatedAt(sort: Desc)])
  @@index([userId, dateApplied(sort: Desc)])
  @@index([userId, followUpAt])
  @@index([userId, jobId])
  @@index([linkedRunId])
}

/// V2 candidate-owned resumes. Decoupled from the recruiter `Resume` model —
/// V2 stores its own variants and never reads `Resume` directly.
/// Spec: 04-backend-spec.md §2.4.
model RAResumeVariant {
  id                  String    @id @default(cuid())
  userId              String
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  name                String
  /// 'base' | 'tailored_for_jd' | 'from_template'
  kind                String    @default("base")

  /// Required when kind='tailored_for_jd' (validated in application code).
  targetJobId         String?
  targetJob           RAJob?    @relation("RAResumeVariantTargetJob", fields: [targetJobId], references: [id], onDelete: SetNull)

  basedOnVariantId    String?
  basedOnVariant      RAResumeVariant?  @relation("RAResumeVariantBasedOn", fields: [basedOnVariantId], references: [id], onDelete: SetNull)
  derivedVariants     RAResumeVariant[] @relation("RAResumeVariantBasedOn")

  /// For kind='from_template' — e.g. 'fresh_grad_engineering'.
  templateKey         String?

  resumeMarkdown      String    @db.Text
  /// sha256(resumeMarkdown), used as the cache key for RAJobMatchScore.
  resumeContentHash   String

  /// Exactly one variant per user is the "primary" résumé (enforced in app
  /// code via a transaction, not a DB partial-unique index). The first résumé
  /// a user creates/uploads is auto-promoted to primary.
  isPrimary           Boolean   @default(false)
  /// How this variant entered the system: 'upload' | 'scratch' | 'template' |
  /// 'linkedin' | 'tailored'. Drives the resume-card source chip.
  sourceKind          String?
  /// Upload-parse lifecycle for kind='base' uploads: 'parsed' | 'parsing' |
  /// 'failed'. NULL for variants that never went through the parse pipeline.
  parseStatus         String?

  /// Raw extracted text from the uploaded file (pre-parse). Candidate-owned —
  /// never written to the recruiter `Resume` table.
  rawText             String?   @db.Text
  /// Structured parse (ParsedResume JSON) produced by ResumeParseAgent.
  parsedData          Json?
  /// AI-generated recruiter-style pitch summary + one-line highlight.
  summary             String?   @db.Text
  highlight           String?

  /// Reference to the original uploaded file in candidate-scoped object
  /// storage (distinct keyspace from recruiter resume originals). NULL when no
  /// original was retained (scratch / template variants).
  originalFileProvider String?
  originalFileKey      String?
  originalFileName     String?
  originalFileMimeType String?
  originalFileSize     Int?

  /// Most recent match score against targetJobId, denormalised for resume-list
  /// rendering. NULL when no score has been computed.
  matchScoreCached    Int?

  lastEditedAt        DateTime  @default(now())
  createdAt           DateTime  @default(now())
  /// Soft delete (UI hides; admin can recover).
  deletedAt           DateTime?

  matchScores         RAJobMatchScore[]

  @@index([userId, lastEditedAt(sort: Desc)])
  @@index([userId, kind, lastEditedAt(sort: Desc)])
  @@index([userId, isPrimary])
  @@index([targetJobId])
  @@index([resumeContentHash])
}

/// User's saved search queries.
/// Spec: 04-backend-spec.md §2.5.
model RASavedSearch {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  name       String
  /// SearchQuery shape — see spec §5.7 for the keys (title, location, workType, …).
  query      Json

  lastRunAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([userId, createdAt(sort: Desc)])
}

/// Weekly career-insight summary. One row per (userId, weekStartUtc).
/// Spec: 04-backend-spec.md §2.6.
model RACareerInsight {
  id                   String    @id @default(cuid())
  userId               String
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Sunday-anchored UTC date. Date-only semantics on the wire.
  weekStartUtc         DateTime

  /// ≤ 600 words, sanitised markdown.
  summaryMarkdown      String    @db.Text
  /// Every `RATrackerEntry.id` referenced in the narration; CitationGuard
  /// verifies these against the user's tracker rows.
  citedTrackerIds      String[]  @default([])
  /// `{ applicationsCount, interviewsCount, offerCount, weeksToOfferEstimate?, … }`
  metrics              Json?

  /// e.g. 'anthropic/claude-sonnet-4.6'
  modelUsed            String
  /// Forensic; canonical billing record is UsageDeductionLog.
  tokenCost            Decimal?  @db.Decimal(10, 6)
  citationGuardPassed  Boolean   @default(false)
  generatedAt          DateTime  @default(now())
  createdAt            DateTime  @default(now())

  @@unique([userId, weekStartUtc])
  @@index([weekStartUtc])
}

/// LLM keyword extraction for an RAJob. Refreshed weekly by `ra.keywordRefresh`.
/// Spec: 04-backend-spec.md §2.7.
model RAKeywordExtraction {
  id           String   @id @default(cuid())
  jobId        String   @unique
  job          RAJob    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  /// Top 30: `Array<{ keyword: string, importance: 'high'|'medium'|'low', frequency: number }>`
  keywords     Json
  /// e.g. 'anthropic/claude-haiku-4-5'
  modelUsed    String
  tokenCost    Decimal? @db.Decimal(10, 6)
  generatedAt  DateTime @default(now())

  @@index([generatedAt])
}

/// Cached resume × job match score. Spec: 04-backend-spec.md §2.8.
model RAJobMatchScore {
  id                          String   @id @default(cuid())
  userId                      String
  user                        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId                       String
  job                         RAJob    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  resumeVariantId             String
  resumeVariant               RAResumeVariant @relation(fields: [resumeVariantId], references: [id], onDelete: Cascade)

  /// 0–100
  score                       Int
  /// `{ strengths: string[], gaps: string[], rationale: string, signals: { skills, experience, location, salary } }`
  explanation                 Json

  /// Snapshot of the variant's hash at score time; if the variant later
  /// edits, the cache is stale.
  resumeContentHashAtScore    String

  /// e.g. 'anthropic/claude-sonnet-4.6'
  modelUsed                   String
  tokenCost                   Decimal? @db.Decimal(10, 6)
  generatedAt                 DateTime @default(now())

  @@unique([userId, jobId, resumeVariantId])
  @@index([userId, score(sort: Desc)])
  @@index([jobId, score(sort: Desc)])
  @@index([generatedAt])
}

// ── V3 Tier-2 ─────────────────────────────────────────────────────────────

/// One row per (user, provider) integration connection state. Static metadata
/// (display name / description / brand colour) lives in code; this table holds
/// only the connection state + OAuth tokens. See roboapply/v2 integrations.
model RAIntegration {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider     String    // linkedin | gmail | gcal | slack | notion | github
  connected    Boolean   @default(false)
  account      String?   // connected account label, e.g. "maya@chen.io"
  accessToken  String?   @db.Text
  refreshToken String?   @db.Text
  expiresAt    DateTime?
  connectedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([userId, provider])
  @@index([userId])
}

/// A mock-interview session. Questions + transcript + the final score live as
/// JSON on the row (no separate turn table — a session's transcript is read/
/// written whole). status: in_progress | complete.
model RAMockSession {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  role            String
  interviewerId   String
  typeId          String
  format          String    // video | voice

  /// BCP-47 interview language (en | zh | zh-TW | ja | …). Null = legacy/en.
  language        String?
  /// Planned interview length in minutes (from setup). Distinct from
  /// `durationMinutes` below, which is the ACTUAL elapsed time set at score.
  plannedDurationMinutes Int?

  /// The composed master interviewer brief (markdown) produced by the
  /// Interview Prompt Generator pipeline and handed to the live interviewer.
  interviewPrompt String?   @db.Text
  /// Structured generation artifacts: { requirements, strategy, tactics,
  /// questions, interviewerBrief, webSources, model, generatedAt }.
  blueprint       Json?

  /// ordered [{ q, hint, coachTip }] generated at start
  questions       Json
  /// accumulated RAMockTurn[] (them/you), grows per nextTurn
  transcript      Json      @default("[]")
  status          String    @default("in_progress")

  // ── Score (null until the session is scored) ──
  overall         Int?
  delta           Int?
  breakdown       Json?     // [{ key, value, note }]
  strengths       String[]  @default([])
  gaps            String[]  @default([])
  note            String?
  durationMinutes Int?

  startedAt       DateTime  @default(now())
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, status])
}

/// Conversational onboarding chat session (RoboApply "Onboarding Chat v4").
/// One active session per user (app-enforced — bootstrap abandons the prior
/// active row). Persisted so the 7-day restore window, server-enforced caps
/// (turns / rounds / JSearch calls / sessions-per-day), and the funnel
/// metrics survive restarts and multi-instance deploys.
/// Spec: docs/design-spec-roboapply-onboarding-chat.md §5.
model RAOnboardingSession {
  id                   String    @id @default(cuid())
  userId               String
  status               String    @default("active")   // active | completed | skipped | abandoned
  resumeVariantId      String?
  locale               String    @default("en")
  transcript           Json      @default("[]")        // [{role:'user'|'assistant', content, at}]
  draftPreferences     Json      @default("{}")        // OnboardingDraftPreferences
  askedTopics          Json      @default("[]")        // topic enums asked or declined
  openingPrompt        String?   @db.Text
  chips                Json      @default("[]")
  surfacedJobIds       Json      @default("[]")        // RAJob ids, all rounds
  passedJobIds         Json      @default("[]")
  turnCount            Int       @default(0)
  recommendationRounds Int       @default(0)
  jsearchCallCount     Int       @default(0)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  completedAt          DateTime?

  @@index([userId, status])
}

/// Interview Engine session — one real-time AI voice/video mock interview.
///
/// Standalone from RoboApply's RAMockSession (which is the legacy TEXT-chat
/// simulation). This row is the source of truth for a LiveKit-Cloud-backed
/// interview: room + agent dispatch, recording (Egress -> R2), transcript
/// (-> R2), the generated voice-interviewer prompt, and the scored report.
/// Usable by the RoboApply UI AND by external API callers (apiKeyId set).
///
/// Lifecycle (status): created -> live -> finalizing -> completed
///                                       \-> failed / expired
/// See backend/src/interview-engine/ and docs/interview-engine/DESIGN.md.
model InterviewSession {
  id        String @id @default(cuid())
  userId    String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// How the session was created: 'roboapply' (candidate UI), 'recruiter'
  /// (RoboHire SPA), or 'external' (third-party via X-API-Key).
  source    String  @default("roboapply")
  /// Set when created through the external API. Plain scalar (no relation) so
  /// the ApiKey model stays untouched; forensic join is by id.
  apiKeyId  String?
  /// Caller-supplied opaque reference (external API) for their own bookkeeping.
  externalRef String?

  // ── Interview definition ──
  role                   String
  interviewType          String  @default("behavioral") // behavioral|technical|system|case|culture|panel|screening|custom
  personaId              String? // interviewer persona id (from the catalog) or null for custom
  mode                   String  @default("voice")       // voice | video
  /// BCP-47 interview language (en|zh|zh-TW|ja|es|fr|pt|de).
  language               String  @default("en")
  plannedDurationMinutes Int     @default(30)
  /// InterviewCharacteristics blob — see interview-engine/prompt/characteristics.ts
  characteristics        Json?
  /// Resolved native-tone voice { provider, model, voiceId, languageCode, label }.
  voice                  Json?
  candidateName          String?
  resumeContext          String? @db.Text
  /// Optional pasted job description. When present it is AUTHORITATIVE for
  /// requirements/question generation (the blueprint agent rewrites it into a
  /// structured brief; web evidence only supplements gaps).
  jdText                 String? @db.Text

  // ── Generated prompt artifacts (Tavily pipeline + composer) ──
  /// The TTS-friendly voice-interviewer SYSTEM PROMPT handed to the worker.
  interviewPrompt String? @db.Text
  /// Structured generation artifacts { requirements, strategy, tactics,
  /// questions, interviewerBrief, webSources, model, generatedAt }.
  blueprint       Json?
  /// Ordered seed questions [{ q, hint, coachTip }].
  questions       Json    @default("[]")
  /// [{ title, url }] from Tavily.
  webSources      Json?

  // ── LiveKit room + agent dispatch ──
  roomName            String  @unique
  livekitRoomSid      String?
  agentDispatchId     String?
  participantIdentity String?

  status String @default("created") // created|live|finalizing|completed|failed|expired
  error  String?

  // ── Recording (Egress -> R2) ──
  egressId             String?
  recordingKey         String? // R2 object key
  recordingMimeType    String?
  recordingDurationSec Int?
  recordingBytes       Int?

  // ── Transcript ──
  /// Running transcript [{ role:'interviewer'|'candidate', text, ts }].
  transcript     Json    @default("[]")
  /// R2 key for the finalized transcript file (JSON + plaintext sidecar).
  transcriptKey  String?
  transcriptText String? @db.Text

  // ── Scored report (null until scored) ──
  overall   Int?
  breakdown Json?
  strengths String[] @default([])
  gaps      String[] @default([])
  summary   String?  @db.Text
  report    Json?

  // ── Usage & cost metering (per-session; deducted from the monthly limit) ──
  /// Billable PARTICIPATION duration in seconds: the transcript ts span
  /// (first→last turn, any role), 0 when the candidate never spoke, capped by
  /// wall-clock (startedAt → finalize) so a skewed worker timestamp can't
  /// inflate it. The "minutes used" metric. Distinct from recordingDurationSec
  /// (egress file length), which can differ from the live conversation length.
  durationSec      Int?
  /// Aggregate LLM tokens across the WHOLE session: blueprint generation +
  /// live interview (worker LLM) + report evaluation agents.
  promptTokens     Int   @default(0)
  completionTokens Int   @default(0)
  totalTokens      Int   @default(0)
  /// Total computed cost of the session in USD (LLM tokens + STT + TTS audio).
  /// The amount to deduct from the user's monthly allowance; the credit/plan
  /// mapping is applied later (see interview-engine/billing/sessionCost.ts).
  costUsd          Float @default(0)
  /// Per-component cost/usage breakdown:
  ///   { blueprint:{model,promptTokens,completionTokens,usd},
  ///     live:{ llm:{...}, stt:{model,minutes,usd}, tts:{model,characters,minutes,usd} },
  ///     evaluation:{model,promptTokens,completionTokens,usd},
  ///     durationSec, currency, computedAt }
  costBreakdown    Json?

  // ── Live telemetry (diagnostic, never billable) ──
  /// Per-turn latency metrics + worker/client telemetry:
  ///   { worker: { startedAt, joinMs, greeting },
  ///     events:       [...worker per-turn latency events], tail-capped ≤2000,
  ///     clientEvents: [...browser telemetry events],       tail-capped ≤500 }
  liveMetrics      Json?

  // ── Lifecycle timestamps ──
  startedAt DateTime?
  endedAt   DateTime?
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, status])
  @@index([apiKeyId])
  @@index([status])
}

// ════════════════════════════════════════════════════════════════════════
// SCRM / CS Copilot — scoped MVP of docs/prd-copilot-suite.md §7,§9 +
// docs/copilot-architecture.md §2.2/§2.3. The "/crm-ai" workspace.
//
// A "customer" is a recruiter User (role in user|internal|agency). Each gets a
// CS owner + a sales owner (User.assignedCsId / assignedSalesId above).
// onDelete: customer-owned rows Cascade (deleting a customer cleans up their CS
// footprint); every staff FK is SetNull (deleting/reassigning a rep must never
// delete a customer or vacuum the approval queue). AIAuditLog has no FK and is
// append-only (guarded in backend/src/lib/prisma.ts).
// ════════════════════════════════════════════════════════════════════════

// AI-maintained per-customer profile. 1:1 with the customer User. Denormalizes
// the latest health score/tier + last-active so the customer list can sort
// without joining HealthScoreSnapshot or aggregating ApiRequestLog per row.
model CustomerProfile {
  id                  String    @id @default(cuid())
  userId              String    @unique
  narrative           String?   @db.Text // AI-written paragraph
  strengths           String[]
  risks               String[]
  nextBestAction      String?   @db.Text
  segmentLabels       String[] // ['power_user','trial','expansion_candidate',...]
  churnRisk           String? // 'low' | 'medium' | 'high'
  healthScore         Int? // 0-100, denormalized latest snapshot
  healthTier          String? // 'green' | 'yellow' | 'red'
  lastActiveAt        DateTime? // denormalized MAX(ApiRequestLog.createdAt)
  lastRefreshedAt     DateTime? // last AI narrative refresh
  automationPaused    Boolean   @default(false) // per-customer "pause all automation"
  billingContactEmail String?
  notes               String?   @db.Text // CS rep freeform notes
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user User @relation("CustomerProfileUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([healthTier, healthScore])
  @@index([churnRisk])
  @@index([lastActiveAt])
}

// Immutable daily/on-demand health-score history for trend charts.
model HealthScoreSnapshot {
  id              String   @id @default(cuid())
  userId          String
  score           Int // 0-100
  tier            String // 'green' | 'yellow' | 'red'
  trend           String // 'up' | 'flat' | 'down'
  factorBreakdown Json // {productEngagement:38, businessOutcomes:17, ...}
  topFactors      String[]
  topRisks        String[]
  computedAt      DateTime @default(now())

  user User @relation("HealthScoreSnapshotUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, computedAt])
  @@index([tier, computedAt])
}

// Unified customer timeline: every touch (email, note, health change, alert).
model CustomerInteraction {
  id                String   @id @default(cuid())
  customerId        String // User.id of the customer
  type              String // email_sent|email_received|note|health_change|subscription_change|alert_raised
  title             String
  body              String?  @db.Text
  actorType         String // 'customer' | 'ai' | 'human'
  actorId           String? // staff User.id when actorType='human'
  metadata          Json?
  relatedEntityType String? // 'crm_alert' | 'crm_email_draft' | 'health_snapshot' | ...
  relatedEntityId   String?
  createdAt         DateTime @default(now())

  customer User @relation("CustomerInteractionCustomer", fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId, createdAt])
  @@index([type, createdAt])
}

// The CS action queue. One row per (customer, signal, period); dedupeKey makes
// the nightly sweep idempotent.
model CrmAlert {
  id         String    @id @default(cuid())
  customerId String // User.id of the customer
  type       String // inactivity|renewal_due|payment_failed|churn_risk|health_drop
  status     String    @default("open") // open|ack|resolved|dismissed
  severity   String    @default("medium") // low|medium|high
  title      String
  body       String?   @db.Text
  assigneeId String? // CS/sales staff User.id
  dueAt      DateTime?
  dedupeKey  String    @unique // e.g. "renewal_due:<userId>:2026-07"
  metadata   Json?
  ackedAt    DateTime?
  resolvedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  customer       User            @relation("CrmAlertCustomer", fields: [customerId], references: [id], onDelete: Cascade)
  assignee       User?           @relation("CrmAlertAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  crmEmailDrafts CrmEmailDraft[] @relation("CrmEmailDraftAlert")

  @@index([status, severity, dueAt])
  @@index([assigneeId, status])
  @@index([customerId, status])
  @@index([type, status])
}

// AI-drafted customer-facing email awaiting human approval (autonomy=draft) —
// nothing sends without a CS rep clicking Send. Footer added by the service.
model CrmEmailDraft {
  id              String    @id @default(cuid())
  recipientUserId String // User.id of the customer (recipient)
  kind            String // renewal|billing|inactivity|dunning|playbook|campaign
  status          String    @default("drafted") // drafted|approved|sent|rejected
  autonomyUsed    String    @default("draft") // draft|review|auto
  subject         String
  bodyHtml        String    @db.Text // includes AI-disclosure footer
  bodyText        String?   @db.Text
  alertId         String?
  ruleCode        String? // CrmAutomationRule.code OR Playbook.code that generated it
  // Phase 7/5 grouping: a draft can belong to an outbound campaign or a playbook run.
  campaignId      String?
  playbookRunId   String?
  approvedById    String?
  approvedAt      DateTime?
  rejectedById    String?
  rejectedAt      DateTime?
  sentAt          DateTime?
  emailMessageId  String? // Resend message id
  dedupeKey       String?   @unique // idempotency, e.g. "dunning:<userId>:<periodEnd>"
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  recipient  User              @relation("CrmEmailDraftRecipient", fields: [recipientUserId], references: [id], onDelete: Cascade)
  approvedBy User?             @relation("CrmEmailDraftApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  rejectedBy User?             @relation("CrmEmailDraftRejecter", fields: [rejectedById], references: [id], onDelete: SetNull)
  alert      CrmAlert?         @relation("CrmEmailDraftAlert", fields: [alertId], references: [id], onDelete: SetNull)
  campaign   OutboundCampaign? @relation("OutboundCampaignDraft", fields: [campaignId], references: [id], onDelete: SetNull)
  playbookRun PlaybookRun?     @relation("PlaybookRunDraft", fields: [playbookRunId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([recipientUserId, createdAt])
  @@index([kind, status])
  @@index([campaignId])
  @@index([playbookRunId])
}

// Per-trigger automation config (admin-editable from /crm-ai/automation).
model CrmAutomationRule {
  id              String   @id @default(cuid())
  code            String   @unique // renewal_due|billing_reminder|inactivity_checkin|dunning
  name            String
  description     String?  @db.Text
  enabled         Boolean  @default(true)
  autonomy        String   @default("draft") // draft|review|auto
  leadDays        Int? // renewal: fire N days before currentPeriodEnd
  thresholdDays   Int? // inactivity: NOW - lastActiveAt > thresholdDays
  suppressionDays Int      @default(14)
  notifyCs        Boolean  @default(true) // always auto-fire in-app CS notification
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([enabled])
}

// Append-only audit of every AI/automation action. No User FK so it survives
// user deletion; update/delete blocked by the prisma.ts append-only guard.
model AIAuditLog {
  id           String   @id @default(cuid())
  agentName    String // 'CustomerHealthAgent','CustomerEmailDrafterAgent','CrmSweeper',...
  actorUserId  String? // customer the action targeted, OR staff who triggered
  action       String // email_drafted|email_sent|alert_raised|autonomy_toggled|profile_refreshed
  entityType   String? // 'crm_email_draft'|'crm_alert'|'customer_profile'|...
  entityId     String?
  payload      Json
  confidence   Float?
  autonomy     String?
  outcome      String // success|failure|rejected
  errorMessage String?  @db.Text
  createdAt    DateTime @default(now())

  @@index([agentName, createdAt])
  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
}

// ════════════════════════════════════════════════════════════════════════
// SCRM / CS Copilot — Phase 5-7: Playbooks, Support Tickets, Campaigns.
// See docs/scrm-cs-copilot.md (full spec) + docs/copilot-architecture.md §2.
// ════════════════════════════════════════════════════════════════════════

// Declarative lifecycle automation. trigger + steps are JSON (see
// services/crm/PlaybookEngine.ts). Default autonomy 'review' = drafts queue for
// approval; 'auto' sends low-risk transactional steps directly (gated like the
// sweeper). Seeded by PlaybookEngine.seedDefaults().
model Playbook {
  id              String   @id @default(cuid())
  code            String   @unique // 'welcome_day0','onboarding_d3','winback_d30',...
  name            String
  description     String?  @db.Text
  trigger         Json // { event: 'user.signup'|'cron.daily'|..., conditions:{...} }
  steps           Json // [{kind:'draft_email'|'create_alert'|..., ...}]
  autonomy        String   @default("review") // draft|review|auto (default for steps)
  priority        Int      @default(50) // conflict resolution; higher wins
  suppressionDays Int      @default(14) // same playbook can't re-fire on a customer within window
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdBy       String?

  runs PlaybookRun[] @relation("PlaybookRuns")

  @@index([enabled])
}

model PlaybookRun {
  id              String    @id @default(cuid())
  playbookId      String
  customerId      String
  triggeredBy     String // event id or 'manual:<userId>' or 'cron.daily'
  status          String    @default("pending") // pending|running|completed|failed|cancelled
  stepStates      Json // [{index,status,startedAt,completedAt,output}]
  startedAt       DateTime  @default(now())
  completedAt     DateTime?
  suppressedUntil DateTime?

  playbook Playbook        @relation("PlaybookRuns", fields: [playbookId], references: [id], onDelete: Cascade)
  customer User            @relation("PlaybookRunCustomer", fields: [customerId], references: [id], onDelete: Cascade)
  drafts   CrmEmailDraft[] @relation("PlaybookRunDraft")

  @@index([customerId, startedAt])
  @@index([playbookId, startedAt])
  @@index([status])
}

// NOTE: SupportTicket / SupportTicketMessage / EscalationRule already exist
// earlier in this file (prior Copilot Phase-1 scaffolding). Phase 6 reuses them
// and adds the customer/assignee User relations on the existing SupportTicket.

// Grouped outbound initiative. Audience resolved to CrmEmailDraft rows (kind=
// 'campaign', campaignId set) which flow through the same approve/send pipeline.
model OutboundCampaign {
  id             String    @id @default(cuid())
  name           String
  description    String?   @db.Text
  audienceFilter Json // { tier?:string[], healthTier?:string[], churnRisk?:string[], status?:string[] }
  prompt         String?   @db.Text // optional steer for the AI drafter
  autonomy       String    @default("review") // draft|review|auto
  status         String    @default("draft") // draft|materializing|review|sending|completed|cancelled
  scheduledAt    DateTime?
  startedAt      DateTime?
  completedAt    DateTime?
  createdBy      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  drafts CrmEmailDraft[] @relation("OutboundCampaignDraft")

  @@index([status, createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Agent-Runtime — additive models (D5). Prefixed Runtime* to avoid the sourcing
// Agent* collision. No FK into existing tables; correlate by targetId/requestId.
// Pushed by robohire-api ONLY; the runtime tolerates their absence on boot (FR-17).
// See docs/agent-runtime/04-persistence-and-locking-spec.md §1.
// ─────────────────────────────────────────────────────────────────────────────

/// One row per unit of work AND one summary row per cycle (targetId null = cycle summary).
/// Source of truth for retry counting (attempt) and recency dedup (R2 / FR-11).
model RuntimeRun {
  id           String    @id @default(cuid())
  kind         String    // RunKind: 'evaluate_interview' | 'match' | 'reminder' | 'execute_task' | <scaffolded>
  trigger      String    // RunTrigger: 'poll' | 'manual' | 'boot' | 'event'
  status       String    @default("running") // RunStatus: running | completed | skipped | failed | blocked_quota
  targetType   String?   // TargetType: 'interview' | 'job' | 'resume' | 'task' | 'reminder' | null(cycle summary)
  targetId     String?   // null on the cycle-summary row
  dedupKey     String?   // discriminator folded into recency dedup (e.g. reminder window '24h' | 'follow_up')
  userId       String?   // owner of the target, for scoping / billing correlation
  startedAt    DateTime  @default(now())
  finishedAt   DateTime?
  durationMs   Int?
  resultJson   Json?     // produced ids / counters / skip reason
  errorMessage String?   // message-only (NFR-5) — never a stack, never secrets
  attempt      Int       @default(1) // retry counter for this (kind, targetId); FR-12 cap source
  requestId    String?   // correlates to ApiRequestLog / LLMCallLog / UsageDeductionLog
  instanceId   String?   // which runtime replica produced this row (forensics)
  lockKey      String?   // CP-1: exact buildLockKey(...) value acquired for this unit (written at runner.ts:340).
                         // abort_run frees the lease by the STORED key (never reconstructed from run.kind, since
                         // buildLockKey's 1st arg is lockKind≠kind and the match-sweeper's composite/match_job
                         // keys never match a reconstruction). null on cycle-summary rows / non-locked units.
  createdAt    DateTime  @default(now())

  // Recency dedup hot path: "is there a completed run for (kind,targetId[,dedupKey]) since T?"
  @@index([kind, targetId, status, startedAt])
  // Retry gate: "max(attempt) for (kind,targetId)"
  @@index([kind, targetId])
  // Cycle/admin scans + analytics funnels by kind+status over time
  @@index([kind, status, startedAt])
  @@index([startedAt])
}

/// Distributed row-lease (D4). One live row == one held lease for `key`.
/// acquire = conditional upsert with expiry; renew = heartbeat extend; release = delete;
/// reapExpired = deleteMany(expiresAt < now). Connection-agnostic — correct under Neon/PgBouncer.
model RuntimeLock {
  key         String   @id              // e.g. 'evaluate_interview:<interviewId>', 'match:<jobId>:<resumeId>'
  holder      String                    // `${hostname}:${pid}:${uuid}` — the acquiring instance
  acquiredAt  DateTime @default(now())
  expiresAt   DateTime                  // lease TTL; reaper deletes rows past this
  meta        Json?                     // optional: { kind, targetId, attempt } for debugging
  @@index([expiresAt])                  // reaper sweep
  @@index([holder])                     // releaseAllHeld(holder) on shutdown (FR-16)
}

/// Registry + admin-editable config. One row per agent key. Read by AgentConfigResolver
/// (RuntimeAgent.config (DB) ?? env ?? code default). Writes are admin/seed only.
model RuntimeAgent {
  id          String   @id @default(cuid())
  key         String   @unique          // 'eval-sweeper' | 'match-sweeper' | 'reminder-sweeper' | 'task-drainer'
  name        String
  description String?
  enabled     Boolean  @default(true)    // master on/off (AgentConfig.enabled)
  schedule    String?                    // cron expr; null = continuous interval poll
  config      Json?                      // per-agent knobs: { batchSize, concurrency, maxAttempts, lockTtlMs,
                                         //                    recencyWindowMs, pollIntervalMs, lookbackHours }
  lastRunAt   DateTime?                  // updated by the scheduler at cycle start (best-effort)
  nextRunAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/// Cross-process imperative command queue. The API (Agent Manager UI) enqueues a verb;
/// the Operator polls, claims (conditional updateMany pending->claimed), executes, and
/// acks (done/failed). Durable so a command survives an Operator restart between enqueue
/// and execute. expiresAt guards staleness; the RuntimeLock row-lease is the real
/// double-execution backstop (a double run_now still cannot double-process a unit).
model RuntimeCommand {
  id          String    @id @default(cuid())
  agentKey    String?   // target RuntimeAgent.key; null = operator-wide (restart/stop/reload_config-all)
  command     String    // 'run_now'|'pause'|'resume'|'stop'|'restart'|'abort_run'|'reload_config'
  argsJson    Json?     // { runId } for abort_run; { reason } for audit; { ...patch } context
  status      String    @default("pending") // pending | claimed | done | failed | expired
  requestedBy String?   // User.id of the issuing admin (RBAC / audit correlation)
  claimedBy   String?   // Operator instanceId (host:pid:uuid) that claimed it
  claimedAt   DateTime?
  finishedAt  DateTime?
  resultJson  Json?     // ack payload / message-only error
  expiresAt   DateTime  // Operator skips + marks 'expired' once now() > expiresAt
  createdAt   DateTime  @default(now())

  @@index([status, agentKey, createdAt]) // poller hot path: pending for (key|null) oldest-first
  @@index([agentKey, createdAt])         // per-agent command history (detail page)
  @@index([createdAt])                   // global recent-commands feed
}

/// Operator liveness + live scheduler snapshot. One row per running instance, upserted on
/// each heartbeat tick. The Agent Manager reads this for "Operator online/offline", the
/// ACTUAL armed agents (not just the saved RuntimeAgent row), version, and the kill-switch
/// state — the closest thing to a health check for a worker with no HTTP port.
model RuntimeHeartbeat {
  instanceId  String   @id          // host:pid:uuid (matches RuntimeRun.instanceId / RuntimeLock.holder prefix)
  beatAt      DateTime              // bumped each tick; offline := now() - beatAt > staleThresholdMs
  startedAt   DateTime              // when this instance booted
  version     String?               // git sha / build id, for deploy verification
  armedAgents Json?                 // [{ key, isRunning, schedule, nextRunAt }] live snapshot
  disabled    Boolean  @default(false) // AGENT_RUNTIME_DISABLED reflected for the UI
  createdAt   DateTime @default(now())

  @@index([beatAt])                 // "latest live instance" / staleness sweep
}
