// ─── Online Assessments ───────────────────────────────────────────────
// See docs/prd-online-assessments.md. Authors design MCQ assessments that
// candidates take after completing an AI interview (or on a standalone
// link). Scoring is deterministic; AI is only used at authoring time to
// polish questions + generate options.

model Assessment {
  id                String    @id @default(cuid())
  userId            String? // creator; null for system-owned seed templates
  teamId            String? // snapshot at create — drives team visibility
  title             String
  description       String?   @db.Text
  language          String    @default("auto") // auto | en | zh | ...
  passThreshold     Int       @default(60) // 0-100
  timeLimitMinutes  Int? // null = untimed
  scoringMode       String    @default("equal") // equal | weighted
  status            String    @default("draft") // draft | published | archived
  version           Int       @default(1)
  accessToken       String?   @unique // null until published
  publishedAt       DateTime?
  archivedAt        DateTime?
  // Days before an unsubmitted invitation auto-expires. Null = no expiry.
  // Applied at invitation-creation time as expiresAt = now + N days.
  defaultExpiryDays Int?
  // Template flags — see docs/prd-online-assessments-phase4.md §3.1.
  // isTemplate rows are excluded from normal listings (unless requested).
  // isPublic makes a template visible to every user, not only the team.
  // System templates: isTemplate=true, isPublic=true, userId=null.
  isTemplate        Boolean   @default(false)
  templateCategory  String?
  isPublic          Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user        User?                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  questions   AssessmentQuestion[]
  invitations AssessmentInvitation[]
  submissions AssessmentSubmission[]
  linkedJobs  Job[]                  @relation("JobLinkedAssessment")

  @@index([userId, status])
  @@index([teamId, status])
  @@index([status, updatedAt])
}

model AssessmentQuestion {
  id               String   @id @default(cuid())
  assessmentId     String
  orderIndex       Int
  // single_choice | multi_choice | short_answer
  // For short_answer the `options` array is empty and `correctOptionIds`
  // is likewise empty; grading uses the LLM against `modelAnswer` + `rubric`.
  type             String   @default("single_choice")
  prompt           String   @db.Text
  options          Json // [{ id: string, text: string }]
  correctOptionIds Json // string[]
  weight           Int      @default(1)
  explanation      String?  @db.Text
  // Short-answer only. `modelAnswer` is the recruiter's reference answer
  // (not shown to candidates); `rubric` lists grading criteria.
  modelAnswer      String?  @db.Text
  rubric           String?  @db.Text
  // Scale (Likert) question fields — null for other types.
  // See docs/prd-online-assessments-phase4.md §3.3.
  //   scaleMin/Max   — integer bounds (e.g. 1..5 or 1..7)
  //   scaleMinLabel  — label at scaleMin (e.g. "Strongly disagree")
  //   scaleMaxLabel  — label at scaleMax (e.g. "Strongly agree")
  //   expectedValue  — null = informational (weight 0); else ±1 match earns weight
  scaleMin         Int?
  scaleMax         Int?
  scaleMinLabel    String?
  scaleMaxLabel    String?
  expectedValue    Int?
  // Ranking question type — Phase 5. `rankingItems` holds the items the
  // candidate must order, stored in the EXPECTED correct order. Candidate
  // submits their own order via `rankedItemIds`; score = Kendall-tau-style
  // correlation (1.0 = exact match) × weight.
  //   rankingItems: Array<{ id: string, text: string }>
  rankingItems     Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([assessmentId, orderIndex])
}

// One row per candidate invitation. `accessToken` is candidate-specific so
// submissions tie back to the specific interview → job → recruiter chain.
model AssessmentInvitation {
  id             String    @id @default(cuid())
  assessmentId   String
  jobId          String?
  interviewId    String? // LiveKit Interview.id OR GoHireInterview.id
  candidateName  String
  candidateEmail String
  candidatePhone String?
  accessToken    String    @unique
  status         String    @default("pending") // pending | sent | submitted | expired | failed
  sentAt         DateTime?
  submittedAt    DateTime?
  expiresAt      DateTime?
  failureReason  String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([assessmentId, status])
  @@index([jobId])
  @@index([interviewId])
  @@index([candidateEmail])
}

model AssessmentSubmission {
  id                String   @id @default(cuid())
  assessmentId      String
  invitationId      String? // nullable for manual/test submissions
  candidateName     String
  candidateEmail    String
  // Per-question answer entries. Shape varies by question type:
  //   MCQ:          { questionId, selectedOptionIds: string[] }
  //   short_answer: { questionId, textAnswer: string }
  //   scale:        { questionId, scaleValue: number }
  //   ranking:      { questionId, rankedItemIds: string[] }
  answers           Json
  // Preliminary MCQ-only score stored at submit time; updated once async
  // short-answer grading completes. `score` is the final 0-100 value.
  score             Int // 0-100, computed server-side
  passed            Boolean
  // Per-question grading details, written once the grader finishes.
  // Shape: [{ questionId: string, score: number, maxScore: number, commentary?: string }]
  grading           Json?
  // True until the LLM short-answer grading finishes. Recruiters see a
  // "Grading in progress" pill on the submissions list while this is true.
  gradingPending    Boolean  @default(false)
  gradingError      String?
  durationSeconds   Int?
  // Phase 5. Client-captured timing per question — drives analytics "avg
  // time per question" + the anti-cheat "time anomaly" heuristic.
  //   Array<{ questionId: string, durationMs: number }>
  perQuestionTiming Json?
  // Phase 5. Passive integrity signals — no enforcement, just surfaced to
  // recruiter. See docs/prd-online-assessments-phase5.md §3.3.
  //   { tabHiddenCount, pasteCount, fullScreenExitCount, firstVisibleAt, ... }
  antiCheatSignals  Json?
  ipAddress         String?
  userAgent         String?  @db.Text
  submittedAt       DateTime @default(now())

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([assessmentId, submittedAt])
  @@index([invitationId])
}

// ─── Phase 6: Intelligent Talent Inference Platform ─────────────────
// See docs/prd-online-assessments-phase6.md + architecture doc. These
// models layer on top of the existing Assessment* tables; they do not
// replace them. `AssessmentReport` is the join point — one report per
// submission, versioned, produced by the multi-agent supervisor.

model Instrument {
  id               String   @id @default(cuid())
  code             String   @unique // e.g. "big5_fc_v1" — stable identity
  discipline       String // "personality" | "cognitive" | "interest" | "values" | "sjt" | "integrity"
  itemFormat       String // "forced_choice" | "likert" | "mcq" | "timed_cognitive"
  version          String   @default("1.0.0")
  languageCode     String   @default("auto")
  name             String
  description      String?  @db.Text
  targetItemCount  Int      @default(10)
  timeLimitMinutes Int?
  scoringAlgorithm String   @default("classical_test_theory") // CTT for Phase 6.0, IRT in 6.5
  // JSON whitelist of market codes (ISO-3166-2) where the instrument can be
  // offered. Empty array = available globally. Used to gate legally
  // sensitive instruments (psych-risk screens, integrity) per §8 PRD.
  legalGating      Json?
  adverseImpactUrl String? // link to PDF manual
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  items      InstrumentItem[]
  dimensions InstrumentDimension[]
  normGroups NormGroup[]

  @@index([discipline, isActive])
}

model InstrumentItem {
  id                 String   @id @default(cuid())
  instrumentId       String
  dimensionCode      String // matches InstrumentDimension.code — the dimension this item loads on
  locale             String   @default("en")
  itemType           String // "single" | "forced_choice_pair" | "timed_cognitive" | "likert" | "sjt"
  prompt             String   @db.Text
  // Shape depends on itemType. For forced_choice_pair:
  //   [{ id, text, dimensionCode, polarity: +1 | -1 }, { ... }]
  // For likert: labels + min/max
  // For MCQ/cognitive: [{ id, text, correct }]
  options            Json
  // IRT params for Phase 6.5 CAT: { a, b, c, reliability }. Null in 6.0.
  psychometricParams Json?
  orderHint          Int      @default(0)
  createdAt          DateTime @default(now())

  instrument Instrument @relation(fields: [instrumentId], references: [id], onDelete: Cascade)

  @@index([instrumentId, dimensionCode])
  @@index([instrumentId, locale])
}

model InstrumentDimension {
  id             String   @id @default(cuid())
  instrumentId   String
  code           String // e.g. "B5_Conscientiousness"
  label          String // localized display label
  description    String?  @db.Text
  // Scoring weights used when aggregating items → dimension score.
  // Shape: { positive: [itemId], negative: [itemId] } for forced-choice
  //        { itemWeights: {itemId: weight} } for weighted
  scoringWeights Json?
  normGroupId    String?
  // Facet-parent relationship — the Big-Five domain "Conscientiousness"
  // has facets (Order, Self-Discipline, Dutifulness) underneath it.
  parentCode     String?
  createdAt      DateTime @default(now())

  instrument Instrument @relation(fields: [instrumentId], references: [id], onDelete: Cascade)

  @@unique([instrumentId, code])
  @@index([instrumentId, parentCode])
}

model NormGroup {
  id               String   @id @default(cuid())
  name             String // e.g. "US Working Adults 2025"
  instrumentId     String
  sampleSize       Int
  // Demographics JSON: { country, ageRange, gender, industry, collectedAt }
  demographics     Json?
  // Per-dimension percentile lookup:
  //   { dimensionCode: { mean, sd, percentileTable: [p1..p99 raw scores] } }
  percentileLookup Json
  lastUpdatedAt    DateTime @default(now())
  createdAt        DateTime @default(now())

  instrument Instrument @relation(fields: [instrumentId], references: [id], onDelete: Cascade)

  @@index([instrumentId])
}

model CompetencyModel {
  id           String   @id @default(cuid())
  name         String
  industry     String // "saas" | "finance" | ...
  position     String // "sales_ae" | "sde" | ...
  level        String? // "entry" | "senior" | "manager"
  languageCode String   @default("en")
  // Full competency definition. See PRD §4.2:
  //   { competencies: [{ code, name, description, weight,
  //                      linkedInstruments: [{instrumentCode, dimensionCode, weight}],
  //                      greenFlagHeuristics: [string], redFlagHeuristics: [string] }] }
  competencies Json
  version      Int      @default(1)
  // userId null = system-seeded template; non-null = tenant-owned custom model.
  createdBy    String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([industry, position])
  @@index([createdBy])
}

model RoleCatalogEntry {
  id           String   @id @default(cuid())
  code         String   @unique // "saas_account_executive_midmarket"
  label        String
  description  String?  @db.Text
  industry     String
  level        String?
  languageCode String   @default("en")
  // Dimensional ideal profile — weights against instrument dimensions.
  // Shape: { dimensions: [{ code, weight, idealPercentile }] }
  // Used by JobFitAgent to score candidate fit.
  idealProfile Json
  hollandCode  String? // e.g. "ESC" for account execs
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([industry, level])
  @@index([isActive])
}

// One report per submission. Version bumps on regenerate so we keep a
// history + can A/B the agent pipeline.
model AssessmentReport {
  id                    String   @id @default(cuid())
  submissionId          String   @unique
  version               Int      @default(1)
  // The seven upstream blobs — nullable so a degraded run still produces a
  // report with a "some signal missing" banner instead of crashing.
  personalityProfile    Json?
  cognitiveProfile      Json?
  interestProfile       Json?
  valuesProfile         Json?
  competencyRadar       Json?
  jobFitRecommendations Json?
  flags                 Json? // { greenFlags, redFlags }
  narrative             String?  @db.Text
  // Evidence trace: { claim: [{upstream, path}] } — drives click-to-source.
  evidenceTrace         Json?
  interviewProbes       Json?
  // Metadata
  model                 String?
  costUsd               Float    @default(0)
  pipelineVersion       String   @default("6.0.0")
  degraded              Boolean  @default(false)
  generatedAt           DateTime @default(now())

  @@index([submissionId])
  @@index([generatedAt])
}

// ─── Copilot Suite — Phase 1 ────────────────────────────────────────
// See docs/prd-copilot-suite.md and docs/copilot-architecture.md.
//
// Storage choice: Phase 1 uses Json for chunk embeddings (JS-side cosine)
// and ILIKE for keyword match — matches the existing ContextRetrievalService
// pattern and avoids raw-SQL migrations. Phase 2 upgrades to pgvector if the
// chunk count (~12k at 200 articles × 4 langs × 10 chunks) needs it.

/// Knowledge-base article. Source of truth lives at
/// docs/wiki/{lang}/{category}/{slug}.md — the loader syncs repo → DB on push.
model WikiArticle {
  id             String    @id @default(cuid())
  slug           String // shared across languages, e.g. "how-matching-works"
  lang           String // 'en', 'zh', 'zh-TW', 'ja'
  title          String
  summary        String?   @db.Text
  body           String    @db.Text // full markdown
  category       String // "matching", "jobs", "resumes", ...
  subcategory    String?
  tags           String[]
  audience       String[]  @default(["user"]) // 'user', 'admin', 'candidate'
  difficulty     String? // 'beginner', 'intermediate', 'advanced'
  version        Int       @default(1)
  status         String    @default("draft") // 'draft', 'published', 'deprecated'
  sourceFile     String? // repo path that produced this row
  lastReviewedAt DateTime?
  publishedAt    DateTime?
  createdBy      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  chunks   WikiChunk[]
  feedback WikiFeedback[]

  @@unique([slug, lang])
  @@index([lang, category, status])
  @@index([slug])
  @@index([status, publishedAt])
}

/// Section-level chunk of an article. Embeddings stored as JSON float
/// arrays for JS-side cosine; we add pgvector when chunk count demands it.
model WikiChunk {
  id             String      @id @default(cuid())
  articleId      String
  article        WikiArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  seq            Int
  heading        String?
  text           String      @db.Text
  tokens         Int
  embedding      Json? // number[] — OpenAI text-embedding-3-small (1536 dims)
  embeddingModel String      @default("text-embedding-3-small")
  lang           String
  category       String
  updatedAt      DateTime    @updatedAt

  @@index([articleId, seq])
  @@index([lang, category])
}

/// User 👍 / 👎 on an article (from Wiki UI or from inside an Alex turn).
model WikiFeedback {
  id        String       @id @default(cuid())
  articleId String?
  article   WikiArticle? @relation(fields: [articleId], references: [id], onDelete: SetNull)
  userId    String?
  queryText String?      @db.Text
  turnId    String? // AlexTurn.id if feedback came from a chat turn
  rating    String // 'up' | 'down'
  comment   String?      @db.Text
  createdAt DateTime     @default(now())

  @@index([articleId])
  @@index([rating, createdAt])
}

/// Per-turn observability for Agent Alex Pro. One row per user message.
/// Feeds admin analytics, eval regressions, and prompt tuning dashboards.
model AlexTurn {
  id            String   @id @default(cuid())
  sessionId     String
  userId        String
  lane          String // 'requirements' | 'guide' | 'data' | 'action' | 'support' | 'billing'
  confidence    Float // triage confidence 0-1
  locale        String   @default("en")
  userMessage   String   @db.Text
  agentResponse String   @db.Text
  toolCalls     Json? // [{name, args, resultSummary, durationMs}]
  citationSlugs String[]
  tokens        Int?
  costUsd       Float?
  latencyMs     Int?
  outcome       String? // 'resolved' | 'escalated' | 'continued' | 'error'
  ticketId      String? // SupportTicket if escalated
  feedback      String? // 'up' | 'down'
  feedbackText  String?
  createdAt     DateTime @default(now())

  @@index([sessionId, createdAt])
  @@index([userId, createdAt])
  @@index([lane, outcome])
  @@index([createdAt])
}

/// Customer-facing escalation. Alex opens these; CS team resolves them.
/// Inbound email is parsed into this table in Phase 2.
model SupportTicket {
  id                String    @id @default(cuid())
  customerId        String // User.id of the customer
  sourceType        String // 'alex' | 'email' | 'manual'
  alexSessionId     String?
  subject           String
  category          String? // 'billing' | 'bug' | 'how-to' | 'feedback' | 'complaint' | 'other'
  priority          String    @default("normal") // 'low' | 'normal' | 'high' | 'urgent'
  status            String    @default("open") // 'open' | 'in_progress' | 'waiting_customer' | 'resolved' | 'closed'
  assigneeId        String?
  ruleId            String? // EscalationRule that routed this
  slaDueAt          DateTime?
  firstResponseAt   DateTime?
  resolvedAt        DateTime?
  aiDraftReply      String?   @db.Text
  aiDraftConfidence Float?
  aiDraftApproved   Boolean   @default(false)
  sentimentScore    Float? // -1..1
  summary           String?   @db.Text // AI summary for the CS rep
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  messages SupportTicketMessage[]
  // Phase 6 (CS Copilot inbox) — relations to the customer + assigned CS rep.
  customer User  @relation("SupportTicketCustomer", fields: [customerId], references: [id], onDelete: Cascade)
  assignee User? @relation("SupportTicketAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([customerId, status])
  @@index([assigneeId, status])
  @@index([status, priority, slaDueAt])
  @@index([status, createdAt])
}

/// Every message on a SupportTicket — inbound + outbound + internal notes.
model SupportTicketMessage {
  id             String        @id @default(cuid())
  ticketId       String
  ticket         SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  direction      String // 'inbound' (customer) | 'outbound' (robohire)
  authorType     String // 'customer' | 'agent' | 'ai'
  authorId       String?
  body           String        @db.Text
  html           String?       @db.Text
  channel        String // 'alex' | 'email' | 'internal_note'
  emailMessageId String? // Resend id for outbound email
  createdAt      DateTime      @default(now())

  @@index([ticketId, createdAt])
}

/// Admin-configured escalation routing. First rule (by priority desc) whose
/// conditions match a new SupportTicket wins; fallback recipients if none
/// match. Recipients = union(userIds, users-with-roles-in-role-list).
model EscalationRule {
  id                   String   @id @default(cuid())
  name                 String
  description          String?  @db.Text
  conditions           Json // { category?, priority?, lane?, sourceType?, sentiment? }
  recipients           Json // { userIds: string[], roles: string[] }
  fallbackRecipients   Json?
  slaMinutes           Int      @default(240)
  escalateAfterMinutes Int? // auto-re-route to fallback after N min no response
  priority             Int      @default(0) // higher fires first
  enabled              Boolean  @default(true)
  createdBy            String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([enabled, priority])
}

// ────────────────────────────────────────────────────────────────────────────
// Phase 3 — AI Auto-Pilot
//
// Three new models that together let a recruiter put a single job on
// "auto-pilot": describe what to match in plain English, AI parses the brief,
// new résumés get auto-matched, qualified candidates get auto-invited with a
// 30-minute undo window. Spec: docs/prd-ux-redesign-and-ai-autopilot.md.
// ────────────────────────────────────────────────────────────────────────────

/// Per-job auto-match config. 1:1 with Job. Disabled by default.
/// `directive` is the recruiter's NL instruction; `parsedCriteria` is the
/// AI-structured form rendered as editable chips in the UI.
model JobMatchBrief {
  id                String    @id @default(cuid())
  jobId             String    @unique
  enabled           Boolean   @default(false)
  directive         String    @db.Text
  parsedCriteria    Json? // { hardRequirements[], softRequirements[], additionalContext }
  parsedAt          DateTime?
  parsedModel       String? // LLM model id used for parsing — auditable
  // Trigger: 'on_upload_to_job' | 'on_pool_new_resume' | 'manual_sweep'
  triggerMode       String    @default("manual_sweep")
  // Snapshot of matching prefs the user picked at save-time. Schema lives in
  // backend/src/lib/matchingPreferences.ts (excludeOlderThanDays etc).
  filters           Json?
  // Safety caps
  perRunCap         Int       @default(50)
  dailyBudget       Int       @default(200)
  // Last-run telemetry
  lastRanAt         DateTime?
  lastResultSummary Json? // { screened, tierA, fullMatched, errors, creditsCost, creditsSaved }
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([enabled, triggerMode])
}

/// Per-job auto-invite config. Independent toggle from Auto-Match — niche
/// roles often want match-only without auto-emailing. UI strong-constraints:
/// minScore must be >= job.matchInviteScore (the old passingScore+5 rule is
/// dead — stage-1 matching is a recall gate; 60 is a legal auto-invite bar).
model JobAutoInviteConfig {
  id                  String    @id @default(cuid())
  jobId               String    @unique
  enabled             Boolean   @default(false)
  minScore            Int       @default(85)
  // NL hard requirements — parsed by BriefParseAgent.
  hardRequirements    String?   @db.Text
  parsedRequirements  Json?
  parsedAt            DateTime?
  parsedModel         String?
  dailyCap            Int       @default(10)
  invitedToday        Int       @default(0)
  invitedTodayResetAt DateTime?
  undoWindowMinutes   Int       @default(30)
  notifyOn            String    @default("every") // 'every' | 'summary' | 'silent'
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([enabled])
}

/// Every auto-pilot decision is recorded here, before the side-effect happens
/// (for invites — the row is written first, then a delayed sender fires after
/// the undo window). For matches, the row is the after-the-fact audit. Source
/// of truth for "why did the AI do that?" + the undo path.
model AutoActionAuditLog {
  id             String    @id @default(cuid())
  userId         String
  jobId          String
  resumeId       String?
  matchId        String? // JobMatch.id when applicable
  inviteId       String? // GoHireInterview.id when an invite was actually sent
  // 'auto_match' | 'auto_invite' | 'auto_recommend'
  type           String
  // 'pending_undo' | 'committed' | 'undone' | 'failed'
  status         String    @default("pending_undo")
  // Brief / config / candidate snapshot — used to render "view reasoning" UI
  inputsSnapshot Json
  outputs        Json?
  // Economic tracking — see Trust principle in PRD §7
  creditsCost    Int?
  creditsSaved   Int?
  // Undo window
  undoableUntil  DateTime?
  undoneAt       DateTime?
  undoneBy       String?
  undoneReason   String?
  errorMessage   String?
  createdAt      DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([jobId, createdAt])
  @@index([status, undoableUntil]) // queue worker scans this for due jobs
  @@index([type, createdAt])
}

/// Append-only audit ledger for every GoHire invitation event across all
/// invocation surfaces (manual single, batch, auto-invite). Rows are NEVER
/// mutated — a state transition (queued → sent, queued → failed, queued →
/// cancelled) writes a NEW row referencing the same interviewId.
///
/// Source of truth for the test-architect's audit-batch.ts validation: the
/// `Interview` row is mutable (status flips, metadata updates), but this
/// table preserves the full history.
///
/// Also surfaced via admin endpoint for forensics — answers "who invited
/// candidate X to job Y last Tuesday and what did GoHire return?"
model InviteAuditEvent {
  id           String   @id @default(cuid())
  userId       String // recruiter who initiated (job owner for auto-invite)
  interviewId  String? // null for events that pre-date the Interview row (rare)
  jobId        String? // null when invite was JD-only (no Job FK)
  resumeId     String? // null when invite was JD+resumeText-only
  batchId      String? // present for batch + cancel events
  // 'manual_single' | 'batch' | 'auto_invite'
  source       String
  // 'queued' | 'sent' | 'failed' | 'cancelled' | 'skipped_cancelled' |
  // 'auto_invite_committed' | 'auto_invite_undone'
  outcome      String
  // HTTP code from GoHire (non-null on sent/failed when GoHire was called)
  gohireStatus Int?
  // GoHire's `user_id` when the invite succeeded
  gohireUserId String?
  // Human-readable error detail from GoHire (when outcome='failed')
  errorDetail  String?  @db.Text
  // Loose JSON for anything else worth keeping (recruiterEmail, candidateEmail,
  // request payload size, locale, batch index, etc.)
  metadata     Json?
  // Audit-context request id (when fired inside an API request)
  requestId    String?
  createdAt    DateTime @default(now())

  @@index([interviewId])
  @@index([batchId])
  @@index([userId, createdAt])
  @@index([jobId, createdAt])
  @@index([resumeId, createdAt])
  @@index([source, outcome, createdAt])
}

// ════════════════════════════════════════════════════════════════════════════
// SystemJobRun — durable history of every system-cron / scheduled / manual
// background-job execution. Surfaced in the admin Jobs Console.
//
// Each row is one execution of one job (NightlyMaintenance, AgentScheduler
// per-agent fire, Watchdog sweep, etc.). The JobsRegistry writes rows on
// run start + completion. Admin can pause/resume jobs via the registry but
// pause-state itself is in-memory (resets on restart — by design, the boot
// pass picks up the latest schedule fresh).
//
// See: docs/automation-audit-and-nightly-batch-design.md +
//      docs/jobs-console-design.md
// ════════════════════════════════════════════════════════════════════════════

model SystemJobRun {
  id           String    @id @default(cuid())
  // Stable identifier used by the registry. Examples:
  //   'nightly-maintenance', 'agent-run-watchdog',
  //   'auto-invite-sweeper', 'trust-digest-sweeper'
  jobId        String
  // Why the run fired. 'cron-tick' | 'admin-trigger' | 'boot' | 'event' | 'unknown'
  reason       String
  // Lifecycle. 'running' | 'completed' | 'failed' | 'skipped' | 'truncated'
  status       String    @default("running")
  startedAt    DateTime  @default(now())
  finishedAt   DateTime?
  durationMs   Int?
  // Free-form per-job result payload (counters, swept counts, etc.)
  resultJson   Json?
  errorMessage String?
  // Set when an admin triggered the run manually.
  triggeredBy  String?

  @@index([jobId, startedAt])
  @@index([status, startedAt])
  @@index([startedAt])
}

// ════════════════════════════════════════════════════════════════════════════
// File Vault — see docs/prd-file-vault.md and docs/design-spec-file-vault.md.
//
// Two physical models (FileVaultFolder, FileVaultFile) + an audit log. The
// "Resumes/" folder shown in the UI is virtual — synthesized at read time
// from Resume.originalFileKey rows; we do NOT mirror resume rows into
// FileVaultFile to avoid double-counting storage quota and to keep the
// Resume row as the single source of truth for parse lifecycle.
//
// Visibility model (v1): folder-level — owner picks `team` or `private` at
// create time, files inherit. No per-file overrides. Cross-tenant access is
// blocked at the API layer via lib/teamVisibility.ts (404, never 403).
//
// Dedup contract: (userId, contentHash) is unique. A second upload of the
// same bytes by the same user returns the existing row instead of creating
// a duplicate. Cross-user dedup happens at the R2 key layer (same hash →
// same object), but each user keeps their own DB row so rename/move/delete
// are owner-scoped.
// ════════════════════════════════════════════════════════════════════════════

model FileVaultFolder {
  id         String    @id @default(cuid())
  userId     String
  parentId   String? // null = root for this user
  name       String
  // Materialized "/Templates/JDs" path. Recomputed on rename/move by walking
  // the parent chain. Used for breadcrumbs + prefix search. Length-capped at
  // 1024 chars in the service.
  path       String
  // 'team'    → all User rows with same teamId (and admin) can read
  // 'private' → only owner can read
  visibility String    @default("team")
  // 'user'            → ordinary user-created folder
  // 'virtual_resumes' → reserved; v1 Resumes folder is computed at read
  //                     time, no rows of this type are persisted.
  // 'trash'           → reserved; v1 surfaces trash via isTrashed flag, not
  //                     a separate folder.
  type       String    @default("user")
  isTrashed  Boolean   @default(false)
  trashedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent   FileVaultFolder?  @relation("FileVaultFolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children FileVaultFolder[] @relation("FileVaultFolderTree")
  files    FileVaultFile[]

  @@unique([userId, parentId, name])
  @@index([userId, parentId])
  @@index([userId, isTrashed])
  @@index([userId, path])
  @@index([userId, visibility])
}

model FileVaultFile {
  id              String    @id @default(cuid())
  userId          String
  folderId        String? // null = vault root; trashed files keep folderId for restore
  name            String
  mimeType        String
  sizeBytes       BigInt
  // SHA-256 of bytes, lowercase hex. Drives dedup at the user scope and
  // R2 key construction. Resume binaries surfaced through the virtual
  // Resumes folder are not duplicated into this table — their hash is
  // tracked on the Resume row.
  contentHash     String
  // 's3' | 'local' — provider that owns the bytes. Mirrors
  // ResumeOriginalFileStorageService.resolveProviderMode().
  storageProvider String
  // Full R2 key. New uploads use vault/{hash[:2]}/{hash[2:4]}/{hash}.
  storageKey      String
  // 'upload'        → user-uploaded into the vault
  // 'resume_mirror' → reserved; NOT written in v1
  source          String    @default("upload")
  sourceResumeId  String? // populated only when source='resume_mirror' (post-v1)
  // Pointer to a server-rendered plaintext sidecar at
  // vault-parsed/{hash[:2]}/.../{hash}.txt. Lazy-populated on first preview
  // for office formats (DOCX/XLSX). Used for the full-text search index.
  parsedTextRef   String?
  // 'pending' (presigned PUT minted, not yet finalized) | 'ready' (live) |
  // 'abandoned' (>15 min stuck pending — GC candidate)
  uploadStatus    String    @default("ready")
  isTrashed       Boolean   @default(false)
  trashedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  folder FileVaultFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  @@unique([userId, contentHash])
  @@index([userId, folderId, isTrashed])
  @@index([userId, isTrashed, trashedAt])
  @@index([userId, name])
  @@index([userId, uploadStatus])
  @@index([contentHash])
  @@index([storageKey])
  @@index([userId, createdAt])
}

model FileVaultAuditLog {
  id        String   @id @default(cuid())
  userId    String // owner of the affected resource (vault tenant)
  actorId   String // who performed the action (could be admin acting on someone else's vault)
  // 'folder.create' | 'folder.rename' | 'folder.move' | 'folder.trash'
  // | 'folder.restore' | 'folder.purge' | 'folder.visibility_changed'
  // 'file.upload' | 'file.rename' | 'file.move' | 'file.copy'
  // | 'file.trash' | 'file.restore' | 'file.purge'
  // | 'file.download' | 'file.preview' | 'file.share_link_minted'
  // Free-form so post-v1 actions don't need a migration.
  action    String
  fileId    String?
  folderId  String?
  // Snapshot fields so a deleted file's audit row stays interpretable.
  metadata  Json?
  createdAt DateTime @default(now())

  user  User @relation("FileVaultAuditOwner", fields: [userId], references: [id], onDelete: Cascade)
  actor User @relation("FileVaultAuditActor", fields: [actorId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([actorId, createdAt])
  @@index([action, createdAt])
  @@index([fileId])
  @@index([folderId])
}

// =====================================================================
// AutoLoader — folder/bucket polling resume intake automation.
// See docs/prd-auto-loader.md and docs/design-spec-auto-loader.md.
// Two source kinds:
//   - 'local_folder': agent-driven (Electron tray app watches a path).
//   - 's3_bucket':    server-driven (AutoLoaderS3PollerService cron).
// Both kinds funnel into the same task → run → file telemetry pipeline.
// =====================================================================

model AutoLoaderAgent {
  id              String    @id @default(cuid())
  userId          String
  name            String // user-editable device name
  os              String // 'darwin' | 'win32' | 'linux'
  version         String // semver, e.g. '0.1.0'
  apiKeyId        String? // FK to ApiKey for revoke-cascade auditing
  status          String    @default("offline") // 'online' | 'offline' | 'error'
  lastHeartbeatAt DateTime?
  registeredAt    DateTime  @default(now())

  user          User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  folderWatches AutoLoaderFolderWatch[]
  runs          AutoLoaderRun[]

  @@index([userId, status])
  @@index([userId, lastHeartbeatAt])
}

model AutoLoaderTask {
  id                  String    @id @default(cuid())
  userId              String
  name                String
  sourceKind          String    @default("local_folder") // 'local_folder' | 's3_bucket' — IMMUTABLE after creation
  status              String    @default("active") // 'active' | 'paused' | 'error'
  pauseReason         String? // 'quota_exhausted'|'auth_failed'|'no_bound_jobs'|...
  includePatterns     String[]  @default(["*.pdf", "*.docx", "*.doc", "*.txt", "*.md"])
  excludePatterns     String[]  @default(["~$*", ".DS_Store", "*.tmp", "*.crdownload", "*.part"])
  pollIntervalSec     Int       @default(300)
  autoMatch           Boolean   @default(true)
  personDedupBehavior String    @default("skip") // 'skip' | 'flag'
  defaultSource       String    @default("applied") // mirrors JobMatch.source enum
  maxFilesPerDay      Int       @default(500)
  filesUploadedToday  Int       @default(0)
  rolloverAt          DateTime? // when filesUploadedToday last reset
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user          User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs          AutoLoaderTaskJob[]
  folderWatches AutoLoaderFolderWatch[] // populated only when sourceKind='local_folder'
  s3Connectors  AutoLoaderS3Connector[] // populated only when sourceKind='s3_bucket'
  runs          AutoLoaderRun[]

  @@index([userId, status])
  @@index([sourceKind, status])
}

model AutoLoaderTaskJob {
  id     String @id @default(cuid())
  taskId String
  jobId  String

  task AutoLoaderTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  job  Job            @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([taskId, jobId])
  @@index([jobId])
}

model AutoLoaderFolderWatch {
  id         String    @id @default(cuid())
  taskId     String
  agentId    String
  folderPath String // label only — server never opens it
  label      String?
  status     String    @default("active") // 'active' | 'paused' | 'missing' | 'error'
  lastPollAt DateTime?
  createdAt  DateTime  @default(now())

  task  AutoLoaderTask  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  agent AutoLoaderAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  runs  AutoLoaderRun[]

  @@unique([agentId, folderPath])
  @@index([taskId])
}

model AutoLoaderS3Connector {
  id             String    @id @default(cuid())
  taskId         String
  provider       String // 'aws_s3' | 'cloudflare_r2' | 's3_compatible'
  bucketName     String
  prefix         String    @default("") // optional sub-prefix
  region         String? // required for AWS S3
  endpoint       String? // for R2 / MinIO / other S3-compatible
  authMode       String // 'access_key' | 'assume_role'
  encryptedCreds String // AES-256-GCM ciphertext; never returned by API
  roleArn        String? // when authMode='assume_role'
  externalId     String? // when authMode='assume_role'
  lastSeenKey    String? // ListObjectsV2 cursor
  lastPolledAt   DateTime?
  status         String    @default("active") // 'active' | 'paused' | 'error'
  lastError      String?
  label          String?
  createdAt      DateTime  @default(now())

  task AutoLoaderTask  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  runs AutoLoaderRun[]

  @@unique([taskId, provider, bucketName, prefix])
  @@index([status, lastPolledAt])
}

model AutoLoaderRun {
  id               String    @id @default(cuid())
  taskId           String
  sourceKind       String // denormalized for fast filtering
  folderWatchId    String? // XOR with s3ConnectorId (service-layer enforced)
  s3ConnectorId    String?
  agentId          String? // null for s3_bucket runs
  status           String    @default("running") // 'running' | 'completed' | 'failed' | 'aborted'
  startedAt        DateTime  @default(now())
  completedAt      DateTime?
  durationMs       Int?
  filesFound       Int       @default(0)
  filesUploaded    Int       @default(0)
  filesSkipped     Int       @default(0)
  filesFailed      Int       @default(0)
  matchesTriggered Int       @default(0)
  errorSummary     Json?
  meta             Json?

  task        AutoLoaderTask         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  folderWatch AutoLoaderFolderWatch? @relation(fields: [folderWatchId], references: [id], onDelete: SetNull)
  s3Connector AutoLoaderS3Connector? @relation(fields: [s3ConnectorId], references: [id], onDelete: SetNull)
  agent       AutoLoaderAgent?       @relation(fields: [agentId], references: [id], onDelete: SetNull)
  files       AutoLoaderFile[]

  @@index([taskId, startedAt])
  @@index([agentId, startedAt])
  @@index([s3ConnectorId, startedAt])
  @@index([status, startedAt])
}

model AutoLoaderFile {
  id              String    @id @default(cuid())
  runId           String
  taskId          String // denormalized
  sourceFilePath  String // local path OR s3://bucket/key
  fileName        String
  fileSize        Int
  clientHash      String // SHA-256, computed by agent or poller
  status          String // 'uploaded'|'matched'|'skipped'|'failed'|'uploaded_match_pending'
  resumeId        String?
  serverHashHit   Boolean   @default(false)
  personDuplicate Boolean   @default(false)
  skipReason      String? // 'duplicate_hash'|'excluded_pattern'|'unsupported_type'|'file_too_large'|'file_disappeared'|'still_writing'
  jobMatchResults Json? // [{ jobId, jobMatchId, score, grade, tier, latencyMs }]
  errorCode       String?
  errorMessage    String?
  attempts        Int       @default(1)
  startedAt       DateTime
  completedAt     DateTime?
  durationMs      Int?

  run    AutoLoaderRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  resume Resume?       @relation(fields: [resumeId], references: [id], onDelete: SetNull)

  @@index([runId])
  @@index([taskId, completedAt])
  @@index([resumeId])
  @@index([clientHash])
  @@index([status, completedAt])
}

// ============================================================================
//  SEEKER MODELS — see docs/prd-job-seeker-app.md + docs/job-seeker-engineering-spec.md
//  Owned by the /job-seeker product. Always FK to User.id. No bolt-ons to
//  Candidate / HiringRequest / JobMatch / Resume — those are recruiter-side.
//
//  Boundary: NO recruiter-side code may import seeker services. See
//  frontend/src/seeker/README.md and backend/src/seeker/README.md.
//
//  Migration: appended in Phase 0 — Track A5. db:push happens after review
//  per docs/phase-0-kickoff.md.
// ============================================================================

/// Subscription tier — 3-tier model LOCKED 2026-05-14 (docs/phase-0-kickoff.md).
/// Free / Premium ($3.99/mo) / Premium Plus ($9.99/mo). See PRD § Pricing.
enum SeekerSubscriptionTier {
  free
  premium
  premium_plus
  starter
  growth
}

/// Per-user seeker profile. 1:1 with User. Created lazily on first /job-seeker
/// visit OR when an invited candidate opts in via the consent flow.
/// Holds the AI-fused unified profile + opt-in / visibility metadata.
model SeekerProfile {
  id     String @id @default(cuid())
  userId String @unique

  /// Where this seeker came from. 'organic' = direct signup; 'invited' = opted
  /// in from a recruiter interview invitation; 'imported' = backfill.
  source               String  @default("organic") // 'organic' | 'invited' | 'imported'
  invitedByCompanyName String? // for transparency UI when source='invited'
  invitedByInterviewId String? // FK reference (string only — no relation, since recruiter-side Interview can be hard-deleted)

  /// Computed readiness score 0–100, surfaced on home. Driven by completeness
  /// of: resume, preferences, interview, profile video, consent records.
  /// Recomputed on profile-write via SeekerProfileService.recomputeReadiness().
  readinessScore Int @default(0)

  /// AI-fused profile JSON (signals from resume + interview + video).
  /// Shape: { skills: string[], experiences: [...], strengths: [...],
  /// communicationStyle: {...}, languageHints: {...} }.
  /// Rebuilt by SeekerProfileFusionAgent whenever any source signal updates.
  fusedProfile        Json?
  fusedProfileVersion String?
  fusedProfileAt      DateTime?

  /// Master parsed-resume content (FK to shared Resume table — the seeker's
  /// master resume is one row in `Resume` with source='seeker_upload').
  /// Tailored variants live in SeekerResumeVersion.
  masterResumeId String?
  masterResume   Resume? @relation("SeekerMasterResume", fields: [masterResumeId], references: [id], onDelete: SetNull)

  /// User-overridable target role/seniority — used by matcher even when
  /// inferred role from resume contradicts (Scenario 6).
  overrideTargetRole  String?
  overrideTargetLevel String? // 'entry' | 'mid' | 'senior' | 'lead' | 'executive'

  /// Visibility toggles (Persona 4 / Scenario 10).
  visibilityInternal Boolean  @default(true) // discoverable in RoboHire job bank
  visibilityExternal Boolean  @default(true) // can auto-apply to external boards
  /// Set of company NAMES this seeker has excluded (no internal visibility,
  /// no external auto-apply to roles where company matches). Names because the
  /// recruiter-side `Job` doesn't have a strict company-id; matched case-insensitively.
  excludedCompanies  String[] @default([])
  /// Stealth from the originally inviting company (Persona 10 specific control).
  stealthFromInviter Boolean  @default(false)

  /// Locale + market — drives interview language, training language, regional pricing.
  locale String? // 'en' | 'zh' | 'zh-TW' | 'ja' | 'es' | 'fr' | 'pt' | 'de'
  market String? // 'us' | 'cn' | 'tw' | 'jp' | 'eu' | 'other'

  /// Opt-out of the weekly "prep for next week's interviews" Friday nudge email.
  /// Renewal/transactional billing emails are NOT governed by this flag.
  weeklyNudgeOptOut Boolean @default(false)

  /// Notification preferences JSON. Shape:
  /// `{ matchAlerts: boolean, applicationUpdates: boolean, weeklyDigest: boolean }`.
  /// Defaults applied at read-time by routes/profile.ts when null.
  notificationPreferences Json?

  /// Soft-delete marker (stamped by the account-delete routes via
  /// SeekerAuthService.softDeleteAccount; makes login throw). Hard-delete runs
  /// via the nightly SeekerAccountPurgeService sweep once the retention window
  /// (default 30d, ACCOUNT_PURGE_RETENTION_DAYS) elapses: R2 artifacts first,
  /// then the User row (cascade).
  deletedAt              DateTime?
  deletionConfirmationId String?   @unique
  deletionEmailSentAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation("SeekerProfileUser", fields: [userId], references: [id], onDelete: Cascade)

  // Backrefs
  preferences         SeekerJobPreferences?
  jobMatches          SeekerJobMatch[]
  applications        SeekerApplication[]
  resumeVersions      SeekerResumeVersion[]
  mockInterviews      SeekerMockInterview[]
  onboardingInterviews SeekerOnboardingInterview[]
  profileVideos       SeekerProfileVideo[]
  trainingProgress    SeekerTrainingProgress[]
  subscription        SeekerSubscription?
  autoApplySettings   SeekerAutoApplySettings?
  boardConnections    SeekerBoardConnection[]
  skillGaps           SeekerSkillGap[]
  consentRecords      SeekerConsentRecord[]
  activityLogs        SeekerActivityLog[]
  notifications       SeekerNotification[]
  mockCreditLedger    MockInterviewCreditLedger[]

  @@index([userId])
  @@index([source])
  @@index([deletedAt])
  @@index([readinessScore])
}

/// Job preferences. 1:1 with SeekerProfile.
model SeekerJobPreferences {
  id              String @id @default(cuid())
  seekerProfileId String @unique

  targetRoles    String[] @default([]) // free-form titles + canonicalized aliases
  targetLevels   String[] @default([]) // ['entry', 'mid', 'senior']
  industries     String[] @default([])
  /// Locations expressed as `{ country, region, city, remoteOk }`. Array of JSON.
  locations      Json     @default("[]")
  workType       String[] @default([]) // ['remote', 'hybrid', 'onsite']
  employmentType String[] @default([]) // ['full-time', 'contract', 'internship']
  salaryMin      Int?
  salaryMax      Int?
  salaryCurrency String? // 'USD', 'CNY', 'TWD', 'JPY', 'EUR' ...
  salaryPeriod   String? // 'monthly' | 'yearly'
  workAuth       String[] @default([]) // ['us_citizen', 'h1b_sponsor_needed', 'eu_eligible', ...]
  availability   String? // 'immediate' | '2_weeks' | '1_month' | '3_months' | 'passive'
  /// Free-text "tell us anything else" — fed to fusion agent.
  notes          String?  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  seekerProfile SeekerProfile @relation(fields: [seekerProfileId], references: [id], onDelete: Cascade)

  @@index([seekerProfileId])
}

/// Seeker × Job match (distinct from recruiter-side JobMatch).
/// Computed by SeekerMatchOrchestratorService on profile update + periodic
/// background refresh + new-job triggers.
model SeekerJobMatch {
  id              String @id @default(cuid())
  seekerProfileId String
  /// FK to shared Job table — the seeker side READS recruiter-owned jobs.
  jobId           String

  /// Score 0–100. Match grade A+ / A / B+ / B / C derived from score band.
  score        Int?
  grade        String?
  /// Full match output from SeekerMatchExplainAgent: { skills, experience,
  /// gaps[], whyMatched, blockers[] }.
  matchData    Json?
  matchVersion String?

  /// User-flag for "wrong direction" (Scenario 6 — Switcher Priya).
  dismissed       Boolean @default(false)
  dismissedReason String?

  /// User-flag for save-for-later.
  saved   Boolean   @default(false)
  savedAt DateTime?

  /// Has the seeker seen this match card?
  viewedAt DateTime?

  /// Cached output from SeekerJobMatchExplainerAgent (Agent #8). Shape
  /// matches SeekerJobMatchExplainerOutput in 03-architecture.md §2.1.
  /// Cache key is implicit on (matchVersion, jobUpdatedAt): we invalidate
  /// by setting this to null when the match row is upserted with a new
  /// score. Reads on `/matches/:matchId/why` short-circuit when present.
  explainerCache Json?
  /// When the explainerCache was produced. Used to age out stale entries
  /// (e.g. if the seeker re-runs onboarding and the fused profile shifts).
  explainerCachedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  seekerProfile SeekerProfile @relation(fields: [seekerProfileId], references: [id], onDelete: Cascade)
  job           Job           @relation("SeekerJobMatchJob", fields: [jobId], references: [id], onDelete: Cascade)

  /// Backref: applications submitted for this match.
  applications SeekerApplication[]

  @@unique([seekerProfileId, jobId])
  @@index([seekerProfileId, score])
  @@index([seekerProfileId, dismissed])
  @@index([seekerProfileId, saved])
  @@index([jobId])
  @@index([createdAt])
}

/// Resume version — tailored for a job / company / archetype. The seeker's
/// MASTER resume lives in the shared Resume table; this stores variants.
model SeekerResumeVersion {
  id              String @id @default(cuid())
  seekerProfileId String

  /// FK to the master Resume row this variant derives from.
  baseResumeId String
  baseResume   Resume @relation("SeekerResumeVersionBase", fields: [baseResumeId], references: [id], onDelete: Cascade)

  /// Human label: e.g. "Backend at Stripe" or "Tailored — Acme Senior PM".
  label String

  /// Optional target metadata used at apply time + reuse-suggestions.
  targetJobId   String?
  targetCompany String?
  archetype     String? // 'backend-saas' | 'product-mgr-fintech' | etc.

  /// Tailored content (markdown + parsedData snapshot).
  resumeText String @db.Text
  parsedData Json?

  /// AI explanations for the diff (line-level). Shape: { changes: [
  /// { kind: 'added'|'removed'|'moved', lineBefore, lineAfter, reason } ] }.
  /// Used for "Why this change?" hover in ResumeDiffView.
  changeLog Json?

  /// Soft-cap key — used by the Free-tier 5-versions cap.
  status String @default("active") // 'active' | 'archived' | 'temporary'

  /// Set when version is used by an auto-apply submission (forensics).
  lastUsedAt DateTime?
  useCount   Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  seekerProfile SeekerProfile @relation(fields: [seekerProfileId], references: [id], onDelete: Cascade)

  applications SeekerApplication[]

  @@index([seekerProfileId, status])
  @@index([seekerProfileId, lastUsedAt])
  @@index([baseResumeId])
  @@index([targetJobId])
}

/// One application — auto or manual — to one job (internal or external board).
model SeekerApplication {
  id              String @id @default(cuid())
  seekerProfileId String

  /// At least one of (jobId, externalJobUrl) is non-null. Internal apps have
  /// jobId; external boards usually only have a URL we record.
  jobId            String?
  externalJobUrl   String?
  externalJobTitle String?
  externalCompany  String?

  /// 'internal' | 'linkedin' | 'indeed' | 'greenhouse' | 'lever' | 'workday' | 'manual_email'.
  /// 'internal' = RoboHire job bank — the application is a DB write.
  board String

  /// 'manual' | 'auto' — was this submitted by the seeker tapping Apply, or
  /// by SeekerAutoApplyOrchestrator?
  mode String @default("manual")

  /// Which match drove this (nullable for purely manual "I found this myself").
  matchId String?

  /// Which resume version we sent.
  resumeVersionId String?

  /// Submission lifecycle. See lib/seekerApplicationStatus.ts for the closed
  /// set + bucket mapping.
  /// 'queued' → 'submitting' → 'submitted' → 'recruiter_viewed' →
  /// 'interview_scheduled' → 'interview_completed' → 'offer' | 'rejected' | 'withdrawn'.
  /// Failure terminals: 'failed_rate_limit' | 'failed_form_changed' |
  /// 'failed_duplicate' | 'failed_other'.
  status String @default("queued")

  /// Board-specific submission metadata (returned IDs, links, error payloads).
  boardMetadata Json?

  /// Recruiter signal — true if the board surfaces a "viewed" event.
  recruiterViewedAt DateTime?

  submittedAt   DateTime?
  failedAt      DateTime?
  failureReason String?

  /// For the duplicate-detection check (same job across 3 boards).
  /// Built from (lowercase company + lowercase job title + url-host).
  dedupKey String?

  /// Free-form notes from the seeker (Scenario 11 — per-recruiter notes).
  notes String? @db.Text

  /// Cached output from SeekerApplicationCoachAgent (Agent #9). Shape
  /// matches SeekerApplicationCoachOutput in 03-architecture.md §2.1.
  /// Stored once per stage transition; re-coaching invokes the agent
  /// again and overwrites the row. V1: no streaming, one-shot.
  coachOutput Json?
  /// Stage the coach output was produced for. When the application
  /// status changes, the cached coach output is invalidated by setting
  /// this to null so the next /coach call regenerates.
  coachOutputForStage String?
  /// When the coachOutput was produced.
  coachOutputAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  seekerProfile SeekerProfile        @relation(fields: [seekerProfileId], references: [id], onDelete: Cascade)
  job           Job?                 @relation("SeekerApplicationJob", fields: [jobId], references: [id], onDelete: SetNull)
  match         SeekerJobMatch?      @relation(fields: [matchId], references: [id], onDelete: SetNull)
  resumeVersion SeekerResumeVersion? @relation(fields: [resumeVersionId], references: [id], onDelete: SetNull)

  @@index([seekerProfileId, status])
  @@index([seekerProfileId, board])
  @@index([seekerProfileId, createdAt])
  @@index([seekerProfileId, dedupKey])
  @@index([jobId])
  @@index([matchId])
}

/// 20-minute onboarding interview session — the climax of the seeker
/// onboarding flow (Scenarios 1, 2, 10). One per seeker per lifetime in the
/// happy path; multiple rows exist only if a previous attempt aborted or
/// failed before signal extraction completed. Drives `SeekerProfile.fusedProfile`
/// via `SeekerOnboardingInterviewSummaryAgent`.
///
/// Distinct from `SeekerMockInterview` (the practice-interview SKILL) — that
/// is opt-in, monthly-capped, and tied to a specific role/style/template.
/// This table is signal-gathering for the seeker's overall profile, runs
/// once, and has no per-question scoring.
model SeekerOnboardingInterview {
  id              String @id @default(cuid())
  seekerProfileId String
  userId          String

  /// Lifecycle: 'scheduled' → 'in_progress' → 'processing' → 'complete'
  ///                                            → 'failed'  (terminal)
  /// 'scheduled' is set on `/start` (room minted, agent dispatched, seeker
  /// hasn't connected yet). 'in_progress' once a participant joins. 'processing'
  /// after `/finalize` (post-processing async). 'complete'/'failed' final.
  status String @default("scheduled")

  /// Was video allowed for this session? Captured for analytics + future
  /// "redo with camera" UX.
  withVideo Boolean @default(false)

  /// LiveKit room name (e.g. `seeker-onboarding-<seekerProfileId>-<short>`).
  /// Unique so concurrent sessions for the same seeker can't collide.
  roomName String @unique

  /// LiveKit JWT given to the seeker's client. Stored only while the room is
  /// live; cleared once status transitions to 'processing' to keep the row
  /// from acting as a long-lived credential.
  accessToken String? @db.Text

  /// Locale the interview ran in (from User.locale fallback to SeekerProfile.locale).
  language String?

  /// Seconds. Set by `/finalize` from the reported `durationSeconds`, or by
  /// the post-processing pass from the transcript timestamps.
  durationSeconds Int?

  /// Why the session ended: 'completed' | 'skipped' | 'disconnected' | 'timeout' | 'agent_error'
  endedReason String?

  /// Append-only transcript captured by the agent worker via `/transcript-chunk`,
  /// or posted in bulk at finalize. Shape: `Array<{ speaker: 'agent'|'seeker',
  /// text: string, ts: number }>`. Read-only after status === 'complete'.
  transcript Json?

  /// 2–3 sentence positioning summary produced by `SeekerOnboardingInterviewSummaryAgent`.
  summary String? @db.Text

  /// 0–100 per-dimension scores produced by the summary agent. Shape:
  /// `{ clarity, depth, structure, confidence, domainFit }`.
  scores Json?

  /// Skills mentioned in the interview that weren't on the master resume.
  /// Surface in SeekerProfileFusionAgent later (Phase 1 week 3+).
  inferredSkills String[] @default([])

  /// Concerns or follow-ups the seeker raised explicitly. NEVER fabricated —
  /// only logged when the seeker brought it up themselves.
  notedConcerns String[] @default([])

  /// Async processing tracking. Set when the summary agent starts, cleared
  /// or replaced with the error message if it fails. Surfaced to the UI as
  /// "processing failed — try again" only when status === 'failed'.
  processingError String? @db.Text

  startedAt   DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  seekerProfile SeekerProfile @relation(fields: [seekerProfileId], references: [id], onDelete: Cascade)
  user          User          @relation("SeekerOnboardingInterviewUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([seekerProfileId, createdAt])
  @@index([seekerProfileId, status])
  @@index([userId, status])
  @@index([status])
}

/// Mock interview session.
model SeekerMockInterview {
  id              String @id @default(cuid())
  seekerProfileId String

  /// 'library' | 'on_the_fly' — source of this session.
  origin String

  /// Templates: 'technical' | 'hr' | 'hiring_manager' | 'panel' | 'behavioral'
  template String
  /// Styles: 'rigorous' | 'relaxed' | 'easy' | 'picky'
  style    String

  /// Target shape: { role, level, company?, jdUrl?, jdText? }.
  target Json

  /// LiveKit room metadata at session time.
  liveKitRoom String?
  liveKitSid  String?

  /// Storage keys for the recording (audio + optional video) and full transcript.
  recordingKey  String?
  transcriptKey String?

  /// Computed scores after feedback agents run.
  overallScore    Int?
  dimensionScores Json? // { clarity, depth, structure, confidence, domainFit }

  /// Top-level summary (SeekerMockSummaryAgent output).
  summary Json? // { strengths[], weaknesses[], improvementPlan[], nextStepCards[] }

  /// 'scheduled' | 'in_progress' | 'completed' | 'aborted'.
  status      String    @default("scheduled")
  startedAt   DateTime?
  completedAt DateTime?

  /// Language the mock ran in. Locale per session — seeker can mix.
  language String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  seekerProfile SeekerProfile                 @relation(fields: [seekerProfileId], references: [id], onDelete: Cascade)
  questions     SeekerMockInterviewQuestion[]

  @@index([seekerProfileId, createdAt])
  @@index([seekerProfileId, status])
}

/// Per-question detail for a mock interview.
model SeekerMockInterviewQuestion {
  id              String @id @default(cuid())
  mockInterviewId String

  /// Position in the session (1-based).
  index Int

  /// The question text as asked, plus its rubric category.
  question String  @db.Text
  category String? // 'sql' | 'sys-design' | 'behavioral' | etc.

  /// The seeker's verbatim transcribed answer.
  answerText     String? @db.Text
  answerAudioKey String?

  /// Per-question critique + an "ideal answer" model.
  critique    Json? // { feedback, lineAnnotations[], scoreOutOf10 }
  idealAnswer String? @db.Text

  /// Scoring 0–10 per dimension (subset of overall dimensions).
  scores Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mockInterview SeekerMockInterview @relation(fields: [mockInterviewId], references: [id], onDelete: Cascade)

  @@index([mockInterviewId, index])
}

/// Catalog of training modules. Admin-managed seed table + AI-generated rows.
model SeekerTrainingModule {
  id              String    @id @default(cuid())
  slug            String    @unique
  title           String
  /// 'video' | 'article' | 'youtube' | 'audio'
  kind            String
  /// 'beginner' | 'intermediate' | 'advanced'
  level           String?
  /// Tag set for matching to skill gaps (e.g. 'sql', 'behavioral', 'systems-design').
  tags            String[]  @default([])
  /// Free / Premium gate.
  freeTier        Boolean   @default(false)
  /// Estimated minutes to consume.
  durationMinutes Int?
  /// For 'youtube' modules — the embed ID + curated metadata.
  youtubeId       String?
  youtubeNotes    Json? // { timestamps[], takeaways[] }
  /// For internally-produced 'video'/'audio' — the storage key.
  mediaKey        String?
  /// Full text content for 'article' kind.
  body            String?   @db.Text
  /// Locale this module is in.
  language        String    @default("en")
  /// Soft-delete.
  publishedAt     DateTime?
  retiredAt       DateTime?

