# RoboHire Interview Engine — voice worker (Node/TS) env.
# Copy to .env.local. The worker reads ONLY infra creds here; everything
# per-interview (prompt, language, voice, models) arrives at runtime via the
# LiveKit room/job metadata from the control plane.

# ── LiveKit Cloud (SAME project as the control plane) ──────────────────────
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Worker registration name. MUST match the control plane's
# INTERVIEW_ENGINE_AGENT_NAME. Deliberately NOT LIVEKIT_AGENT_NAME (that is
# "Agent Alex" — a different agent). Default: RoboHire-Interview.
INTERVIEW_ENGINE_AGENT_NAME=RoboApply-Interview

# Shared secret echoed on transcript/lifecycle callbacks. MUST match the control
# plane's LIVEKIT_AGENT_CALLBACK_SECRET.
LIVEKIT_AGENT_CALLBACK_SECRET=

# ── TTS ────────────────────────────────────────────────────────────────────
# OpenAI tts-1 (multilingual) is the default voice — needs only this key.
OPENAI_API_KEY=

# NOTE: STT (elevenlabs/scribe_v2_realtime) and LLM (openai/gpt-4o) default to
# LiveKit Inference, which needs no separate provider key — only LIVEKIT_* above.
