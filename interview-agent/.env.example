# RoboHire Interview Engine — voice worker (Node/TS) env.
# Copy to .env.local. The worker reads ONLY infra creds here; everything
# per-interview (prompt, language, voice, models) arrives at runtime via the
# LiveKit room/job metadata from the control plane.

# ── LiveKit Cloud (SAME project as the control plane) ──────────────────────
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Worker registration name. MUST match the control plane's
# INTERVIEW_ENGINE_AGENT_NAME. Deliberately NOT LIVEKIT_AGENT_NAME (that is
# "Agent Alex" — a different agent). Default: RoboApply-Interview.
INTERVIEW_ENGINE_AGENT_NAME=RoboApply-Interview

# Shared secret echoed on transcript/lifecycle callbacks. MUST match the control
# plane's LIVEKIT_AGENT_CALLBACK_SECRET.
LIVEKIT_AGENT_CALLBACK_SECRET=

# ── TTS ────────────────────────────────────────────────────────────────────
# OpenAI tts-1 (multilingual) is the LOCAL floor. It backs the gateway voice via
# a client-side FallbackAdapter, so if the gateway rejects the voice or errors
# MID-TURN the session fails over to this instead of going mute — needs only
# this key. Keep it set in every deployment.
OPENAI_API_KEY=

# NOTE: STT (deepgram/nova-3, with a server-side deepgram/nova-2 fallback), LLM
# (per metadata; control-plane default openai/gpt-5.4), and TTS (the resolved
# native voice, e.g. cartesia/sonic-3) all run through LiveKit Inference, which
# needs no separate provider key — only LIVEKIT_* above.

# ── Tuning (all optional; sensible defaults in code) ───────────────────────
# How long the worker holds the greeting waiting for the browser's `client_ready`
# signal (audio playback unlocked) before greeting anyway. Fail-open. (ms)
# WORKER_CLIENT_READY_TIMEOUT_MS=12000
# Graceful drain window on SIGTERM. SDK default is 1h so a live interview is
# never cut by a redeploy; shorten only if fast rollouts matter more. (ms)
# WORKER_DRAIN_TIMEOUT_MS=
# Prewarmed idle job subprocesses (small VMs: 1). SDK production default is 3.
# WORKER_NUM_IDLE_PROCESSES=
# Reported-load ceiling (0..1) above which LiveKit routes to other replicas.
# WORKER_LOAD_THRESHOLD=
