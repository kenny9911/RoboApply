{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "prisma generate && tsc -p server/tsconfig.json && next build",
  "functions": {
    "api/index.mts": {
      "maxDuration": 300,
      "memory": 2048,
      "includeFiles": "server/**"
    }
  },
  "rewrites": [
    { "source": "/api/v1/:path*", "destination": "/api/index" }
  ],
  "crons": [
    { "path": "/api/v1/cron/daily-matcher", "schedule": "0 5 * * *" },
    { "path": "/api/v1/cron/digest", "schedule": "0 * * * *" },
    { "path": "/api/v1/cron/submitter", "schedule": "0 * * * *" },
    { "path": "/api/v1/cron/catchup", "schedule": "*/15 9-15 * * *" },
    { "path": "/api/v1/cron/cache-cleanup", "schedule": "0 3 * * 0" },
    { "path": "/api/v1/cron/billing-renewal-reminder", "schedule": "0 6 * * *" },
    { "path": "/api/v1/cron/billing-friday-nudge", "schedule": "0 16 * * 5" }
  ]
}
