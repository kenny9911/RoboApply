{
  "name": "roboapply",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "description": "RoboApply \u2014 AI candidate-facing job-application app (Next.js frontend + Express API, deployed on Vercel).",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "concurrently --kill-others --kill-signal SIGINT \"npm run dev:server\" \"npm run dev:web\"",
    "dev:web": "next dev -p 3611",
    "dev:server": "tsx watch server/src/app.ts",
    "dev:interview-agent": "npm --prefix interview-agent run dev",
    "build": "prisma generate && npm run build:server && next build",
    "build:server": "tsc -p server/tsconfig.json",
    "build:web": "next build",
    "start": "next start -p ${PORT:-3611}",
    "lint": "next lint",
    "typecheck:server": "tsc -p server/tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:plans-i18n": "node scripts/check-plans-i18n-parity.mjs",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate"
  },
  "//": "Build-time deps (tailwind/postcss/autoprefixer/typescript/@types) live in dependencies so a production (NODE_ENV=production) install does not prune what `next build` and `tsc -p server` need.",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.86.1",
    "@aws-sdk/client-s3": "^3.1013.0",
    "@aws-sdk/client-sts": "^3.1045.0",
    "@aws-sdk/s3-request-presigner": "^3.1045.0",
    "@google/genai": "^1.47.0",
    "@google/generative-ai": "^0.21.0",
    "@heroicons/react": "^2.2.0",
    "@livekit/components-react": "^2.9.21",
    "@livekit/components-styles": "^1.2.0",
    "@livekit/protocol": "^1.46.6",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@tanstack/react-query": "^5.59.0",
    "@tavily/core": "^0.7.2",
    "@types/node": "^22.10.5",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "autoprefixer": "^10.4.20",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csv-parse": "^6.1.0",
    "disposable-email-domains": "^1.0.62",
    "docx": "^9.7.1",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "free-email-domains": "^1.9.50",
    "html-to-text": "^10.0.0",
    "jsonrepair": "^3.14.1",
    "jsonwebtoken": "^9.0.3",
    "libphonenumber-js": "^1.12.39",
    "livekit-client": "^2.19.0",
    "livekit-server-sdk": "^2.15.0",
    "mammoth": "^1.11.0",
    "multer": "^1.4.5-lts.1",
    "next": "16.2.6",
    "next-intl": "^4.12.0",
    "node-cron": "^4.2.1",
    "openai": "^4.67.1",
    "pdf-parse": "^1.1.1",
    "pdf-to-img": "^6.2.0",
    "pdfkit": "^0.18.0",
    "pg": "^8.13.1",
    "postcss": "^8.5.1",
    "prisma": "^7.7.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "stripe": "^20.3.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "word-extractor": "^1.0.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.12",
    "@types/node-cron": "^3.0.11",
    "@types/passport": "^1.0.17",
    "@types/pg": "^8.11.10",
    "@types/qrcode": "^1.5.6",
    "concurrently": "^9.1.0",
    "jsdom": "^25.0.1",
    "tsx": "^4.19.1",
    "vitest": "^2.1.9"
  }
}
