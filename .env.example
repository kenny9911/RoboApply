# ─────────────────────────────────────────────────────────────────────────────
# RoboApply — environment variables
#
# Local dev: copy to `.env` (loaded by server/src/app.ts + prisma) and put the
# NEXT_PUBLIC_* vars in `.env.local` for Next.js. On Vercel, set these in
# Project → Settings → Environment Variables (never commit real secrets).
# ─────────────────────────────────────────────────────────────────────────────

# ── Core ────────────────────────────────────────────────────────────────────
NODE_ENV=development
# Express API port for local dev (the Next app runs on 3611).
PORT=4607

# ── Database (shared Neon with RoboHire for now) ────────────────────────────
# Runtime uses the POOLED (pgbouncer) Neon endpoint. For serverless, append
# ?pgbouncer=true&connection_limit=1 to the pooled URL.
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/DB?sslmode=require&pgbouncer=true&connection_limit=1
# DIRECT (non-pooler) endpoint — used ONLY by `prisma db push` / migrations
# (DDL over the transaction pooler silently no-ops).
DIRECT_DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/DB?sslmode=require

# ── Auth / cookies ──────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
SESSION_EXPIRES_IN=30d
# For same-site cookies across roboapply.io and its api. Leave unset in dev.
# COOKIE_DOMAIN=.roboapply.io

# ── Public URLs (Next.js — put these in .env.local for dev) ─────────────────
# In PRODUCTION keep NEXT_PUBLIC_API_URL EMPTY so the browser calls same-origin
# /api/v1/* (Vercel rewrites route them to the Express function). In dev, the
# Next rewrite proxies /api/* to this backend at NEXT_PUBLIC_API_URL.
NEXT_PUBLIC_API_URL=http://localhost:4607
NEXT_PUBLIC_ROBOAPPLY_URL=http://localhost:3611
# R2 public bucket URL for resumes/avatars via next/image. Optional.
NEXT_PUBLIC_R2_PUBLIC_URL=
# LiveKit signaling URL — needed for the mock-interview client. Optional.
NEXT_PUBLIC_LIVEKIT_URL=
# Used by outbound emails / OAuth redirects / public links in production.
APP_URL=https://roboapply.io
PUBLIC_APP_URL=https://roboapply.io

# ── Vercel Cron ─────────────────────────────────────────────────────────────
# Vercel sends `Authorization: Bearer $CRON_SECRET` to /api/v1/cron/* routes.
CRON_SECRET=change-me-to-a-long-random-string
# The in-process node-cron is auto-disabled on Vercel (VERCEL is set). Set this
# to true to disable it on any other always-on host too.
# ROBOAPPLY_CRON_DISABLED=false

# ── LLM providers ───────────────────────────────────────────────────────────
LLM_PROVIDER=openrouter
LLM_MODEL=google/gemini-3-flash-preview
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
# Optional DB-backed LLM settings kill-switch (true = pure-env behaviour).
# LLM_SETTINGS_DB_DISABLED=false

# ── Web search (RA insights / interview grounding) ──────────────────────────
TAVILY_API_KEY=

# ── Stripe (RoboApply consumer billing) ─────────────────────────────────────
STRIPE_SECRET_KEY=
# Webhook: point a Stripe endpoint at /api/v1/roboapply/stripe/webhook
STRIPE_WEBHOOK_SECRET=
# Or a RoboApply-specific secret if you split the endpoint:
# ROBOAPPLY_STRIPE_WEBHOOK_SECRET=
STRIPE_ROBOAPPLY_STARTER_PRICE_ID=
STRIPE_ROBOAPPLY_GROWTH_PRICE_ID=
STRIPE_ROBOAPPLY_PREMIUM_PRICE_ID=
STRIPE_ROBOAPPLY_PREMIUM_PLUS_PRICE_ID=
STRIPE_BILLING_PORTAL_URL=

# ── Alipay (RMB market) ─────────────────────────────────────────────────────
ALIPAY_API_URL=
ALIPAY_CALLBACK_SECRET=

# ── Interview Engine (LiveKit voice/video mock interviews) ──────────────────
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ── Object storage (R2 / S3 — resume originals + Egress recordings) ─────────
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true
# AWS_* fall-backs are also read by the AWS SDK.
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Email ───────────────────────────────────────────────────────────────────
RESEND_API_KEY=
ROBOAPPLY_EMAIL_FROM=RoboApply <noreply@roboapply.io>

# ── External job boards / enrichment (optional) ─────────────────────────────
RAPID_API_KEY=
GREENHOUSE_API_KEY=
LINKEDIN_ENRICH_API_KEY=

# ── Interview engine (LiveKit voice worker contract) ────────────────────────
# The control plane (this .env) and the worker (interview-agent/.env.local)
# MUST agree on these two values, or dispatches go to nobody / callbacks are
# rejected (empty transcripts + all-zero reports).
INTERVIEW_ENGINE_AGENT_NAME=RoboApply-Interview
LIVEKIT_AGENT_CALLBACK_SECRET=   # openssl rand -hex 24; same value in interview-agent/.env.local
